# Cloudflare Pages cache headers
# https://developers.cloudflare.com/pages/configuration/headers/

# Statik il sayfaları — 1 saat edge, 1 gün stale-while-revalidate
/veri/*
  Cache-Control: public, s-maxage=3600, stale-while-revalidate=86400

# Anasayfa ve statik sayfalar — 30 dk edge, 1 gün stale
/
  Cache-Control: public, s-maxage=1800, stale-while-revalidate=86400

/fiyat
  Cache-Control: public, s-maxage=1800, stale-while-revalidate=86400

/sss
  Cache-Control: public, s-maxage=3600, stale-while-revalidate=86400

# Sitemap — 1 saat edge cache
/sitemap.xml
  Cache-Control: public, max-age=3600, s-maxage=86400

# robots.txt — 1 gün
/robots.txt
  Cache-Control: public, max-age=86400

# Admin sayfası — cache yok, search engine'lere kapalı
/admin/*
  Cache-Control: no-store, no-cache, must-revalidate
  X-Robots-Tag: noindex, nofollow
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer

# Statik assets (JS/CSS, hash'li dosya isimleri) — 1 yıl immutable
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Resimler — 1 hafta
/*.png
  Cache-Control: public, max-age=604800

/*.svg
  Cache-Control: public, max-age=604800
