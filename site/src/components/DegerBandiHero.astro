---
// Animasyonlu "Değer & Dürüst Güven" bandı — site hero/section için.
// Değer sayarak yükselir; güven, bant genişliğine dürüstçe yansır (güçlü emsal → dar+yeşil,
// zayıf veri → geniş+amber "manuel doğrula"). İki durum arasında otomatik geçiş yapar.
// Extension'daki DegerBandi.tsx ile aynı tasarım dili (tek marka).
---

<div class="dbh relative mx-auto max-w-md">
  <div
    class="absolute -inset-5 rounded-[2rem] bg-gradient-to-tr from-imperial/15 via-champagne/15 to-emerald-500/10 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div
    id="dbhCard"
    class="dbh-card relative rounded-2xl border border-white/5 bg-[#0E1729] p-5 text-slate-200 shadow-2xl ring-1 ring-imperial/20"
  >
    <div class="flex items-start justify-between gap-3">
      <div>
        <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500">
          Muğla · Bodrum · Yalıkavak
        </div>
        <div class="mt-0.5 text-xs text-slate-400">Ada 152 / Parsel 7 · Arsa 1.240 m²</div>
      </div>
      <span
        id="dbhPill"
        class="dbh-pill flex items-center gap-1.5 whitespace-nowrap rounded-full border border-emerald-400/30 bg-emerald-400/10 px-2.5 py-1 text-[11px] font-semibold text-emerald-300"
      >
        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-current"></span>
        <span id="dbhPillT">Güçlü emsal</span>
      </span>
    </div>

    <div class="mt-4 text-[10px] font-semibold uppercase tracking-wider text-slate-500">
      Tahmini piyasa değeri
    </div>
    <div
      id="dbhVal"
      class="font-display text-4xl font-extrabold tabular-nums tracking-tight text-white"
    >
      ₺0
    </div>
    <div class="text-xs text-slate-400">
      <span id="dbhPm2">12.500</span> ₺/m² · <span id="dbhGuven">güven 84/100</span>
    </div>

    <!-- Dürüst belirsizlik bandı -->
    <div class="mt-5">
      <div class="relative h-3 overflow-visible rounded-lg bg-[#1A2238]">
        <div
          id="dbhFill"
          class="dbh-fill absolute inset-y-0 rounded-lg bg-emerald-500/40"
          style="left:30%;right:30%"
        >
        </div>
        <div
          id="dbhMark"
          class="dbh-mark absolute -top-1 h-5 w-1 -translate-x-1/2 rounded bg-emerald-400"
          style="left:50%"
        >
        </div>
        <span class="dbh-cmp" style="--l:22%"></span>
        <span class="dbh-cmp" style="--l:41%"></span>
        <span class="dbh-cmp" style="--l:58%"></span>
        <span class="dbh-cmp" style="--l:73%"></span>
      </div>
      <div class="mt-2 flex justify-between text-[11px] tabular-nums text-slate-500">
        <span id="dbhLo">₺13,4M</span>
        <span class="font-semibold text-slate-300">beklenen</span>
        <span id="dbhHi">₺17,6M</span>
      </div>
    </div>

    <!-- Güven metre -->
    <div id="dbhMeter" class="mt-4 flex gap-1.5">
      <i class="h-1.5 flex-1 rounded-full bg-[#1A2238]"></i>
      <i class="h-1.5 flex-1 rounded-full bg-[#1A2238]"></i>
      <i class="h-1.5 flex-1 rounded-full bg-[#1A2238]"></i>
      <i class="h-1.5 flex-1 rounded-full bg-[#1A2238]"></i>
      <i class="h-1.5 flex-1 rounded-full bg-[#1A2238]"></i>
    </div>

    <p
      id="dbhNote"
      class="dbh-note mt-3 rounded-lg bg-[#13203B] px-3 py-2 text-[11px] leading-snug text-slate-400"
    >
      Bant dar · yüksek güven — 9 taze emsal, düşük dağılım.
    </p>
  </div>

  <div class="mt-3 text-center text-[11px] text-slate-500">
    Bant, verinin gücüne göre <span class="text-slate-300">dürüstçe</span> daralır/genişler —
    “confidently wrong” yok.
  </div>
</div>

<style>
  .dbh-fill { transition: left .9s cubic-bezier(.2,.7,.2,1), right .9s cubic-bezier(.2,.7,.2,1), background-color .6s; }
  .dbh-mark { transition: left .9s cubic-bezier(.2,.7,.2,1), background-color .6s; }
  .dbh-pill, .dbh-note { transition: background-color .6s, color .6s, border-color .6s; }
  .dbh-cmp {
    position: absolute; top: 50%; left: var(--l); width: 8px; height: 8px; border-radius: 9999px;
    transform: translate(-50%, -50%); background: #cbd5e1; opacity: .4;
    transition: left .9s ease, background-color .6s;
  }
  .dbh-meter-on { background-color: #10b981 !important; }
  .dbh-meter-warn { background-color: #f59e0b !important; }
  @media (prefers-reduced-motion: reduce) {
    .dbh-fill, .dbh-mark, .dbh-cmp, .dbh-pill, .dbh-note { transition: none; }
  }
</style>

<script>
  (function () {
    const card = document.getElementById("dbhCard");
    if (!card) return;
    const $ = (id: string) => document.getElementById(id)!;
    const elVal = $("dbhVal"), elPm2 = $("dbhPm2"), elGuven = $("dbhGuven");
    const elPill = $("dbhPill"), elPillT = $("dbhPillT");
    const elFill = $("dbhFill"), elMark = $("dbhMark");
    const elLo = $("dbhLo"), elHi = $("dbhHi"), elNote = $("dbhNote");
    const meter = Array.from($("dbhMeter").querySelectorAll("i"));
    const cmps = Array.from(card.querySelectorAll<HTMLElement>(".dbh-cmp"));

    type State = {
      low: boolean; val: number; pm2: string; guven: number; pill: string;
      lo: string; hi: string; note: string; fill: [number, number]; mark: number;
      cmp: number[]; on: number;
    };
    const states: State[] = [
      { low: false, val: 15500000, pm2: "12.500", guven: 84, pill: "Güçlü emsal",
        lo: "₺13,4M", hi: "₺17,6M", note: "Bant dar · yüksek güven — 9 taze emsal, düşük dağılım.",
        fill: [30, 30], mark: 50, cmp: [22, 41, 58, 73], on: 5 },
      { low: true, val: 9200000, pm2: "7.400", guven: 38, pill: "Zayıf veri · manuel doğrula",
        lo: "₺5,1M", hi: "₺13,3M", note: "Bant geniş · düşük güven — 2 emsal, il-baseline ağırlıklı. Dürüst belirsizlik: manuel doğrulayın.",
        fill: [8, 8], mark: 50, cmp: [14, 33, 64, 86], on: 2 },
    ];

    let i = 0, raf = 0;
    const fmt = (n: number) => "₺" + Math.round(n).toLocaleString("tr-TR");
    function countTo(target: number) {
      cancelAnimationFrame(raf);
      const start = parseInt(elVal.textContent!.replace(/\D/g, "")) || 0;
      let t0 = 0;
      const step = (t: number) => {
        if (!t0) t0 = t;
        const p = Math.min((t - t0) / 900, 1), e = 1 - Math.pow(1 - p, 3);
        elVal.textContent = fmt(start + (target - start) * e);
        if (p < 1) raf = requestAnimationFrame(step);
      };
      raf = requestAnimationFrame(step);
    }
    function apply(s: State) {
      countTo(s.val);
      elPm2.textContent = s.pm2;
      elGuven.textContent = "güven " + s.guven + "/100";
      elPillT.textContent = s.pill;
      elLo.textContent = s.lo; elHi.textContent = s.hi; elNote.textContent = s.note;
      elFill.style.left = s.fill[0] + "%"; elFill.style.right = s.fill[1] + "%";
      elMark.style.left = s.mark + "%";

      const warn = s.low;
      elFill.classList.toggle("bg-emerald-500/40", !warn);
      elFill.classList.toggle("bg-amber-500/30", warn);
      elMark.classList.toggle("bg-emerald-400", !warn);
      elMark.classList.toggle("bg-amber-400", warn);
      elPill.className = "dbh-pill flex items-center gap-1.5 whitespace-nowrap rounded-full border px-2.5 py-1 text-[11px] font-semibold "
        + (warn ? "border-amber-400/30 bg-amber-400/10 text-amber-300" : "border-emerald-400/30 bg-emerald-400/10 text-emerald-300");
      elNote.className = "dbh-note mt-3 rounded-lg px-3 py-2 text-[11px] leading-snug "
        + (warn ? "bg-amber-500/10 text-amber-200" : "bg-[#13203B] text-slate-400");

      meter.forEach((m, idx) => {
        m.classList.remove("dbh-meter-on", "dbh-meter-warn");
        if (idx < s.on) m.classList.add(warn ? "dbh-meter-warn" : "dbh-meter-on");
      });
      cmps.forEach((c, idx) => {
        if (s.cmp[idx] != null) c.style.setProperty("--l", s.cmp[idx] + "%");
        c.style.background = warn ? "#fbbf24" : "#cbd5e1";
      });
    }

    apply(states[0]);
    setInterval(() => { i = (i + 1) % states.length; apply(states[i]); }, 3800);
  })();
</script>
