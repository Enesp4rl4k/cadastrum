---
import Logo from "./Logo.astro";

// Nav sadeleştirildi — 6 madde, net hiyerarşi
// Çıkarılanlar: Hesaplayıcılar (sorgu içinde), Arsa talebi (redirect),
//               Kaynaklar (footer), Örnek (noindex), API (footer'da)
const navItems = [
  { href: "/sorgu",  label: "Sorgu" },
  { href: "/harita", label: "Harita" },
  { href: "/veri",   label: "Veri" },
  { href: "/fiyat",  label: "Fiyat" },
  { href: "/blog",   label: "Blog" },
];
---

<!-- Email doğrulama bandı -->
<div id="dogrulama-band" class="hidden bg-amber-50 border-b border-amber-200 text-amber-900 text-xs">
  <div class="container-prose py-2 flex items-center justify-between gap-4">
    <span>📧 Email adresinizi doğrulayın — Pro özelliklere geçiş için zorunlu.</span>
    <a href="/dogrulama" class="font-semibold underline hover:text-amber-700">Şimdi doğrula →</a>
  </div>
</div>

<header
  id="site-header"
  class="header-root sticky top-0 z-40 border-b border-slate-200/80 bg-white/80 backdrop-blur-md supports-[backdrop-filter]:bg-white/60"
>
  <!-- Scroll progress line — champagne, thin, purposeful -->
  <div
    id="scroll-progress"
    class="absolute bottom-0 left-0 h-[2px] w-0 bg-gradient-to-r from-imperial via-champagne to-imperial opacity-0 transition-opacity duration-300"
    aria-hidden="true"
  ></div>

  <div class="container-prose flex h-16 items-center justify-between gap-4 transition-all duration-300" id="header-inner">
    <a href="/" class="flex items-center gap-2 group" aria-label="Cadastrum Ana Sayfa">
      <Logo size={32} className="shadow-sm rounded-md transition-transform duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:scale-110 group-hover:rotate-[-3deg]" />
      <span class="font-display text-lg font-semibold text-ink tracking-tight transition-colors duration-200 group-hover:text-imperial-700">
        Cadastrum
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1 relative" id="main-nav">
      <!-- Active indicator pill — slides under the active link -->
      <span
        id="nav-indicator"
        class="absolute bottom-[-1px] h-[2px] rounded-full bg-imperial transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] opacity-0"
        aria-hidden="true"
      ></span>

      {navItems.map((item) => (
        <a
          href={item.href}
          class="nav-link relative px-3 py-1.5 text-sm font-medium text-slate-600 rounded-md transition-colors duration-150 hover:text-ink hover:bg-slate-50/80"
          data-href={item.href}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="mobile-nav-btn"
      aria-label="Menüyü aç"
      class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-slate-600 hover:bg-slate-100 transition-colors"
    >
      <svg id="burger-icon" class="h-5 w-5 transition-transform duration-300" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"/>
      </svg>
    </button>

    <div class="flex items-center gap-2">
      <!-- Misafir görünümü -->
      <div id="nav-misafir" class="flex items-center gap-2">
        <a href="/giris" class="hidden sm:inline-flex text-sm font-medium text-slate-600 hover:text-ink transition-colors duration-150">
          Giriş
        </a>
        <a href="/kayit" class="btn-primary text-xs sm:text-sm py-2 px-3 sm:px-4">
          Hesap aç
        </a>
      </div>

      <!-- Giriş yapılmış görünümü -->
      <div id="nav-kullanici" class="hidden items-center gap-2 relative">
        <span id="nav-tier-rozet" class="hidden text-[10px] font-semibold px-2 py-0.5 rounded-full bg-champagne-100 text-champagne-700 uppercase tracking-wide"></span>
        <button
          id="nav-menu-btn"
          class="flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 hover:border-slate-300 hover:shadow-sm transition-all duration-200"
        >
          <span id="nav-avatar" class="flex h-6 w-6 items-center justify-center rounded-full bg-imperial text-white text-[11px] font-semibold">?</span>
          <span id="nav-ad" class="text-sm font-medium text-slate-700 max-w-[140px] truncate hidden sm:inline"></span>
          <svg class="h-3.5 w-3.5 text-slate-400 transition-transform duration-200" id="nav-chevron" viewBox="0 0 20 20" fill="currentColor">
            <path d="M5.5 7.5L10 12l4.5-4.5z"/>
          </svg>
        </button>
        <div
          id="nav-menu"
          class="hidden absolute right-0 top-full mt-2 w-56 rounded-xl border border-slate-200 bg-white shadow-xl shadow-slate-200/50 overflow-hidden origin-top-right"
          style="animation: menu-open 220ms cubic-bezier(0.34,1.56,0.64,1) forwards;"
        >
          <div class="px-4 py-3 border-b border-slate-100">
            <div id="nav-menu-ad" class="text-sm font-semibold text-slate-800 truncate"></div>
            <div id="nav-menu-email" class="text-xs text-slate-500 truncate"></div>
          </div>
          <a href="/hesap" class="block px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors">Hesabım</a>
          <a href="/hesap/bildirimler" class="block px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors">Bildirimlerim</a>
          <a href="/musteriler" id="nav-musteriler" class="hidden px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors">Müşterilerim</a>
          <a href="/hesap/api-tokens" id="nav-api-tokens" class="hidden px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors">API Tokenları</a>
          <a href="/fiyat" class="block px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors">Aboneliğim</a>
          <button id="nav-cikis" class="w-full text-left px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition-colors">Çıkış yap</button>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Mobile drawer -->
<div
  id="mobile-nav-drawer"
  class="md:hidden fixed inset-0 z-50 hidden"
  aria-hidden="true"
>
  <div id="mobile-nav-overlay" class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
  <aside class="absolute right-0 top-0 bottom-0 w-72 max-w-[85%] bg-white shadow-2xl overflow-y-auto translate-x-full transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]" id="mobile-nav-aside">
    <div class="flex items-center justify-between p-4 border-b border-slate-200">
      <span class="font-display text-lg font-semibold">Menü</span>
      <button id="mobile-nav-close" aria-label="Kapat" class="rounded-md p-2 hover:bg-slate-100 transition-colors">
        <svg class="h-5 w-5 text-slate-600" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </button>
    </div>
    <nav class="flex flex-col py-2">
      {navItems.map((item) => (
        <a href={item.href} class="px-4 py-3 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors">
          {item.label}
        </a>
      ))}
      <div class="border-t border-slate-200 my-2"></div>
      <a href="/hesap" class="px-4 py-3 text-sm text-slate-700 hover:bg-slate-50 transition-colors" id="mob-hesap">Hesabım</a>
      <a href="/hesap/bildirimler" class="px-4 py-3 text-sm text-slate-700 hover:bg-slate-50 transition-colors" id="mob-bildirim">Bildirimlerim</a>
      <a href="/musteriler" class="hidden px-4 py-3 text-sm text-slate-700 hover:bg-slate-50 transition-colors" id="mob-musteri">Müşterilerim</a>
      <a href="/hesap/api-tokens" class="hidden px-4 py-3 text-sm text-slate-700 hover:bg-slate-50 transition-colors" id="mob-apitok">API Tokenları</a>
      <a href="/giris" class="px-4 py-3 text-sm text-slate-700 hover:bg-slate-50 transition-colors" id="mob-giris">Giriş Yap</a>
      <a href="/kayit" class="px-4 py-3 text-sm font-semibold text-imperial hover:bg-slate-50 transition-colors" id="mob-kayit">Hesap Aç</a>
      <button id="mob-cikis" class="hidden text-left px-4 py-3 text-sm text-red-600 hover:bg-red-50 transition-colors">Çıkış Yap</button>
    </nav>
  </aside>
</div>

<style>
  /* Menu open animation */
  @keyframes menu-open {
    from { opacity: 0; transform: scale(0.92) translateY(-8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* Header scroll-shrink — JS adds .scrolled class */
  .header-root.scrolled {
    background-color: rgba(255, 255, 255, 0.95);
    box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06), 0 4px 16px rgba(15, 23, 42, 0.04);
    border-color: rgba(203, 213, 225, 0.6);
  }
  .header-root.scrolled #header-inner {
    height: 56px; /* shrink from 64px */
  }
  .header-root {
    transition:
      background-color 300ms ease,
      box-shadow       300ms ease,
      border-color     300ms ease;
  }
  #header-inner {
    transition: height 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Nav indicator transition */
  #nav-indicator {
    will-change: left, width;
  }

  /* Active nav link */
  .nav-link.active {
    color: #1B2A4A;
    font-weight: 600;
  }

  /* Mobile drawer open state */
  #mobile-nav-drawer.open #mobile-nav-overlay {
    opacity: 1;
  }
  #mobile-nav-drawer.open #mobile-nav-aside {
    transform: translateX(0);
  }

  /* Scroll progress */
  #scroll-progress.visible {
    opacity: 1;
  }

  /* Nav chevron open state */
  #nav-kullanici.menu-open #nav-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  import { kullaniciAl, cikisYap, tazele } from "../lib/auth";

  /* ── Scroll: header shrink + progress bar ── */
  function initScrollBehavior() {
    const header = document.getElementById("site-header");
    const progress = document.getElementById("scroll-progress") as HTMLElement | null;
    if (!header) return;

    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const y = window.scrollY;
          // Shrink
          header.classList.toggle("scrolled", y > 20);
          // Progress bar
          if (progress) {
            const doc = document.documentElement;
            const total = doc.scrollHeight - doc.clientHeight;
            const pct = total > 0 ? (y / total) * 100 : 0;
            progress.style.width = `${pct}%`;
            progress.classList.toggle("visible", pct > 1);
          }
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll(); // run once on init
  }

  /* ── Active nav indicator pill ── */
  function initNavIndicator() {
    const nav = document.getElementById("main-nav");
    const indicator = document.getElementById("nav-indicator") as HTMLElement | null;
    if (!nav || !indicator) return;

    const links = nav.querySelectorAll<HTMLAnchorElement>(".nav-link");
    const current = location.pathname + location.hash;

    function moveTo(el: HTMLElement) {
      const navRect = nav!.getBoundingClientRect();
      const elRect = el.getBoundingClientRect();
      indicator!.style.left = `${elRect.left - navRect.left}px`;
      indicator!.style.width = `${elRect.width}px`;
      indicator!.style.opacity = "1";
    }

    // Find active link
    let activeLink: HTMLAnchorElement | null = null;
    links.forEach((link) => {
      const href = link.getAttribute("data-href") || link.getAttribute("href") || "";
      const isActive =
        href === current ||
        (href !== "/" && current.startsWith(href.split("#")[0])) ||
        (href.includes("#") && current.includes(href.split("#")[1]));
      if (isActive) {
        link.classList.add("active");
        activeLink = link;
      }
    });

    if (activeLink) {
      // Defer until layout is stable
      requestAnimationFrame(() => moveTo(activeLink!));
    }

    // Hover: indicator follows cursor
    links.forEach((link) => {
      link.addEventListener("mouseenter", () => moveTo(link));
    });
    nav.addEventListener("mouseleave", () => {
      if (activeLink) {
        moveTo(activeLink);
      } else {
        indicator.style.opacity = "0";
      }
    });
  }

  /* ── Mobile drawer with smooth transitions ── */
  function mobileNavInit() {
    const btn = document.getElementById("mobile-nav-btn");
    const drawer = document.getElementById("mobile-nav-drawer");
    const overlay = document.getElementById("mobile-nav-overlay");
    const closeBtn = document.getElementById("mobile-nav-close");
    if (!btn || !drawer) return;

    const open = () => {
      drawer.classList.remove("hidden");
      drawer.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      // Trigger transitions on next frame
      requestAnimationFrame(() => drawer.classList.add("open"));
    };

    const close = () => {
      drawer.classList.remove("open");
      drawer.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      // Wait for transition then hide
      setTimeout(() => drawer.classList.add("hidden"), 320);
    };

    btn.addEventListener("click", open);
    closeBtn?.addEventListener("click", close);
    overlay?.addEventListener("click", close);
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
    document.getElementById("mob-cikis")?.addEventListener("click", () => {
      cikisYap();
      location.href = "/";
    });
  }

  /* ── Nav auth state ── */
  function navGuncelle() {
    const u = kullaniciAl();
    const misafir = document.getElementById("nav-misafir");
    const kul = document.getElementById("nav-kullanici");
    const band = document.getElementById("dogrulama-band");
    if (!misafir || !kul) return;

    if (band) {
      band.classList.toggle("hidden", !(u && u.emailDogrulandi === false));
    }

    const mobGiris = document.getElementById("mob-giris");
    const mobKayit = document.getElementById("mob-kayit");
    const mobCikis = document.getElementById("mob-cikis");
    const mobHesap = document.getElementById("mob-hesap");
    const mobBildirim = document.getElementById("mob-bildirim");
    const mobMusteri = document.getElementById("mob-musteri");
    const mobApitok = document.getElementById("mob-apitok");

    if (!u) {
      misafir.classList.remove("hidden"); misafir.classList.add("flex");
      kul.classList.add("hidden"); kul.classList.remove("flex");
      mobGiris?.classList.remove("hidden");
      mobKayit?.classList.remove("hidden");
      [mobCikis, mobHesap, mobBildirim, mobMusteri, mobApitok].forEach(el => el?.classList.add("hidden"));
      return;
    }

    mobGiris?.classList.add("hidden");
    mobKayit?.classList.add("hidden");
    mobCikis?.classList.remove("hidden");
    mobHesap?.classList.remove("hidden");
    mobBildirim?.classList.remove("hidden");
    misafir.classList.add("hidden"); misafir.classList.remove("flex");
    kul.classList.remove("hidden"); kul.classList.add("flex");

    const ad = u.ad?.trim() || u.email.split("@")[0];
    const navAd = document.getElementById("nav-ad");
    const navAvatar = document.getElementById("nav-avatar");
    const navMenuAd = document.getElementById("nav-menu-ad");
    const navMenuEmail = document.getElementById("nav-menu-email");
    if (navAd) navAd.textContent = ad;
    if (navAvatar) navAvatar.textContent = ad.charAt(0).toUpperCase();
    if (navMenuAd) navMenuAd.textContent = ad;
    if (navMenuEmail) navMenuEmail.textContent = u.email;

    const rozet = document.getElementById("nav-tier-rozet");
    if (rozet) {
      if (u.tier !== "free") {
        rozet.textContent = u.tier === "pro_plus" ? "Pro+" : u.tier === "kurumsal" ? "Kurumsal" : "Pro";
        rozet.classList.remove("hidden");
      } else {
        rozet.classList.add("hidden");
      }
    }

    const musteriler = document.getElementById("nav-musteriler");
    const apiTokens = document.getElementById("nav-api-tokens");
    const musteriGoster = u.tier === "pro_plus" || u.tier === "kurumsal";
    if (musteriler) { musteriler.classList.toggle("hidden", !musteriGoster); musteriler.classList.toggle("block", musteriGoster); }
    mobMusteri?.classList.toggle("hidden", !musteriGoster);
    const apiGoster = u.tier === "kurumsal";
    if (apiTokens) { apiTokens.classList.toggle("hidden", !apiGoster); apiTokens.classList.toggle("block", apiGoster); }
    mobApitok?.classList.toggle("hidden", !apiGoster);
  }

  /* ── Dropdown menu ── */
  function initDropdown() {
    const menuBtn = document.getElementById("nav-menu-btn");
    const menu = document.getElementById("nav-menu");
    const kul = document.getElementById("nav-kullanici");
    if (!menuBtn || !menu) return;

    menuBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      const isHidden = menu.classList.contains("hidden");
      menu.classList.toggle("hidden", !isHidden);
      kul?.classList.toggle("menu-open", isHidden);
      if (isHidden) {
        // Re-trigger animation
        menu.style.animation = "none";
        requestAnimationFrame(() => {
          menu.style.animation = "menu-open 220ms cubic-bezier(0.34,1.56,0.64,1) forwards";
        });
      }
    });

    document.addEventListener("click", () => {
      menu.classList.add("hidden");
      kul?.classList.remove("menu-open");
    });

    document.getElementById("nav-cikis")?.addEventListener("click", () => {
      cikisYap();
      location.href = "/";
    });
  }

  function init() {
    navGuncelle();
    tazele().then(navGuncelle).catch(() => {});
    mobileNavInit();
    initDropdown();
    initScrollBehavior();
    initNavIndicator();
  }

  document.addEventListener("astro:page-load", init);
  if (document.readyState !== "loading") init();
  else document.addEventListener("DOMContentLoaded", init);
</script>
