---
interface Props {
  tier: string;
  fiyat: string;
  fiyatAlt?: string;
  hedef: string;
  ozellikler: { text: string; vurgulu?: boolean }[];
  cta: string;
  ctaUrl: string;
  populer?: boolean;
  deneme?: boolean;  // 7 gün ücretsiz deneme rozeti
  // LemonSqueezy buy URL placeholder — ENV'den gelecek
  lemonUrl?: string;
}

const { tier, fiyat, fiyatAlt, hedef, ozellikler, cta, ctaUrl, populer = false, deneme = false } = Astro.props;
---

<div
  class:list={[
    "relative rounded-2xl border bg-white p-6 md:p-8 flex flex-col card-lift",
    populer ? "border-brand shadow-lg tier-popular" : "border-slate-200 shadow-sm",
  ]}
>
  {populer && (
    <div class="absolute -top-3 left-1/2 -translate-x-1/2">
      <span class="inline-flex items-center rounded-full bg-brand px-3 py-1 text-xs font-semibold text-white shadow-sm">
        Çoğu kullanıcı
      </span>
    </div>
  )}

  <div class="mb-6">
    <h3 class="font-display text-2xl font-bold text-ink">{tier}</h3>
    <p class="mt-1 text-sm text-slate-500">{hedef}</p>
  </div>

  <div class="mb-6">
    <div class="flex items-baseline gap-1">
      <span class="font-display text-4xl md:text-5xl font-bold text-ink">{fiyat}</span>
      {fiyatAlt && <span class="text-sm text-slate-500">{fiyatAlt}</span>}
    </div>
    {deneme && (
      <div class="mt-2 inline-flex items-center gap-1.5 rounded-md bg-emerald-50 text-emerald-700 px-2 py-1 text-[11px] font-semibold">
        <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a8 8 0 100 16 8 8 0 000-16zm3.707 6.707l-4.5 4.5a1 1 0 01-1.414 0l-2-2a1 1 0 011.414-1.414L8.5 11.086l3.793-3.793a1 1 0 011.414 1.414z"/></svg>
        7 gün ücretsiz dene · kart kesilmez
      </div>
    )}
  </div>

  <ul class="mb-8 space-y-3 flex-1">
    {
      ozellikler.map((o) => (
        <li class="flex items-start gap-2 text-sm">
          <span
            class:list={[
              "mt-0.5 flex h-4 w-4 items-center justify-center rounded-full text-white text-[10px] flex-shrink-0",
              o.vurgulu ? "bg-brand" : "bg-accent-success",
            ]}
            aria-hidden="true"
          >
            ✓
          </span>
          <span class={o.vurgulu ? "text-ink font-medium" : "text-slate-700"}>{o.text}</span>
        </li>
      ))
    }
  </ul>

  <a
    href={ctaUrl}
    class:list={[
      "block w-full text-center rounded-md px-5 py-3 text-sm font-semibold transition",
      populer
        ? "bg-brand text-white hover:bg-brand-700 shadow-sm"
        : "border border-slate-300 bg-white text-ink hover:bg-slate-50",
    ]}
  >
    {cta}
  </a>
</div>
