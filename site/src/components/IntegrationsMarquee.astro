---
// Hangi resmi kaynaklarla konuştuğumuzu gösteren marquee.
// Logoyu basit text + icon olarak hazırladım — gerçek logolar legal risk taşıyabilir.
const integrations = [
  { ad: "TKGM", ust: "Tapu ve Kadastro" },
  { ad: "e-Plan", ust: "ÇŞİDB Resmi" },
  { ad: "Sahibinden", ust: "İlan Verisi" },
  { ad: "Hepsiemlak", ust: "İlan Verisi" },
  { ad: "OpenStreetMap", ust: "Çevre POI" },
  { ad: "Open-Meteo", ust: "Eğim & İklim" },
  { ad: "AFAD", ust: "Risk Skoru" },
  { ad: "Gemini AI", ust: "Derin Analiz" },
];

// Marquee sürekli sırayla aksın diye iki kez render ediyoruz
const items = [...integrations, ...integrations];
---

<section class="border-y border-slate-200 bg-slate-50/50 py-10 overflow-hidden">
  <div class="container-prose mb-6">
    <p class="text-center text-xs uppercase tracking-[0.2em] text-slate-500 font-semibold">
      Resmi & Açık Veri Kaynaklarıyla Bağlantılı
    </p>
  </div>

  <div class="marquee relative">
    <!-- Edge fade -->
    <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-slate-50 to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-slate-50 to-transparent z-10 pointer-events-none"></div>

    <div class="marquee-track flex gap-12 w-max">
      {
        items.map((it) => (
          <div class="flex items-center gap-3 px-2 py-1 text-slate-400 hover:text-ink transition-colors">
            <div class="font-display font-bold text-2xl tracking-tight">
              {it.ad}
            </div>
            <div class="hidden sm:block w-px h-6 bg-slate-300"></div>
            <div class="hidden sm:block text-xs text-slate-500">
              {it.ust}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
