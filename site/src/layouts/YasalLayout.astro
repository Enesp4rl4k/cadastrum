---
import Base from "./Base.astro";

interface Props {
  title: string;
  description: string;
  baslik: string;
  altBaslik?: string;
  guncellendi: string;
}

const { title, description, baslik, altBaslik, guncellendi } = Astro.props;
---

<Base title={title} description={description}>
  <article class="bg-white">
    <!-- Header -->
    <header class="border-b border-slate-200 bg-slate-50">
      <div class="container-prose py-12 md:py-16">
        <nav class="text-xs text-slate-500 mb-4">
          <a href="/" class="hover:text-imperial">Cadastrum</a>
          <span class="mx-1.5 text-slate-300">/</span>
          <span>Yasal</span>
        </nav>
        <h1 class="font-display text-3xl md:text-4xl font-bold text-imperial-700 tracking-tight">{baslik}</h1>
        {altBaslik && <p class="mt-3 text-slate-600 max-w-2xl">{altBaslik}</p>}
        <p class="mt-4 text-xs text-slate-500">Son güncelleme: {guncellendi}</p>
      </div>
    </header>

    <!-- İçerik -->
    <div class="container-prose py-12 md:py-16">
      <div class="prose prose-slate max-w-3xl mx-auto">
        <slot />
      </div>
    </div>
  </article>
</Base>

<style is:global>
  .prose {
    color: #475569;
    line-height: 1.7;
  }
  .prose h2 {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #0F1A33;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }
  .prose h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: #1B2A4A;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose p {
    margin-top: 0;
    margin-bottom: 1rem;
  }
  .prose ul {
    list-style: disc;
    padding-left: 1.25rem;
    margin-bottom: 1rem;
  }
  .prose ol {
    list-style: decimal;
    padding-left: 1.25rem;
    margin-bottom: 1rem;
  }
  .prose li {
    margin-bottom: 0.4rem;
  }
  .prose a {
    color: #2C4275;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover { color: #1B2A4A; }
  .prose strong { color: #0F1A33; font-weight: 600; }
  .prose .uyari {
    background: #FEF3C7;
    border-left: 3px solid #D97706;
    padding: 0.75rem 1rem;
    border-radius: 0.25rem;
    margin: 1.25rem 0;
    font-size: 0.9rem;
  }
  .prose .bilgi {
    background: #EEF1F8;
    border-left: 3px solid #2C4275;
    padding: 0.75rem 1rem;
    border-radius: 0.25rem;
    margin: 1.25rem 0;
    font-size: 0.9rem;
  }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }
  .prose th, .prose td {
    border: 1px solid #E2E8F0;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .prose th {
    background: #F1F5F9;
    font-weight: 600;
    color: #0F1A33;
  }
</style>
