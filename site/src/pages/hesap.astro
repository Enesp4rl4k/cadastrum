---
export const prerender = true;
import Base from "../layouts/Base.astro";
---

<Base title="Hesabım — Cadastrum" description="Cadastrum hesap yönetimi.">
  <section class="bg-slate-50 min-h-[80vh] py-12">
    <div class="max-w-2xl mx-auto px-4 space-y-6">
      <h1 class="font-display text-3xl font-bold text-imperial-700">Hesabım</h1>

      <!-- Profil özeti -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h2 class="font-display text-lg font-semibold text-imperial-700 mb-3">Profil</h2>
        <dl class="grid grid-cols-3 gap-3 text-sm">
          <dt class="text-slate-500">Ad</dt><dd id="prof-ad" class="col-span-2 text-slate-800">—</dd>
          <dt class="text-slate-500">Email</dt><dd id="prof-email" class="col-span-2 text-slate-800">—</dd>
          <dt class="text-slate-500">Plan</dt><dd id="prof-tier" class="col-span-2 text-slate-800">—</dd>
          <dt class="text-slate-500">Email durumu</dt><dd id="prof-email-dogr" class="col-span-2">—</dd>
        </dl>
      </div>

      <!-- Şifre değiştir -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h2 class="font-display text-lg font-semibold text-imperial-700 mb-3">Şifre değiştir</h2>
        <form id="sifre-form" method="post" action="javascript:void(0)" class="space-y-3">
          <input type="password" name="eski" placeholder="Mevcut şifre" required minlength="8"
            class="w-full px-3.5 py-2.5 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-2 focus:ring-imperial/10 focus:outline-none transition" />
          <input type="password" name="yeni" placeholder="Yeni şifre (en az 8 karakter)" required minlength="8"
            class="w-full px-3.5 py-2.5 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-2 focus:ring-imperial/10 focus:outline-none transition" />
          <div id="sifre-durum" class="hidden text-sm rounded-lg px-3 py-2"></div>
          <button type="submit" class="px-4 py-2 rounded-lg bg-imperial text-white font-semibold text-sm hover:bg-imperial-700 transition">
            Şifreyi güncelle
          </button>
        </form>
      </div>

      <!-- Veri export -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h2 class="font-display text-lg font-semibold text-imperial-700 mb-2">Verilerimi indir</h2>
        <p class="text-sm text-slate-600 mb-3">
          KVKK Madde 11 kapsamında, Cadastrum'da tutulan kişisel verilerinizi JSON olarak indirebilirsiniz.
        </p>
        <button id="export-btn" type="button"
          class="px-4 py-2 rounded-lg border border-imperial text-imperial font-semibold text-sm hover:bg-imperial-50 transition">
          📥 Verilerimi indir
        </button>
      </div>

      <!-- Hesap silme -->
      <div class="bg-white rounded-2xl border border-red-200 p-6">
        <h2 class="font-display text-lg font-semibold text-red-700 mb-2">Hesabımı sil</h2>
        <p class="text-sm text-slate-600 mb-3">
          Hesabınızı kalıcı olarak siler, tüm verilerinizi temizler. <strong>Bu işlem geri alınamaz.</strong>
          Onaylamak için <code class="bg-slate-100 px-1.5 py-0.5 rounded text-xs">HESABIMI SIL</code> yazmalısınız.
        </p>
        <form id="sil-form" class="space-y-3">
          <input type="text" name="onay" placeholder="Onay için yazın: HESABIMI SIL" required
            class="w-full px-3.5 py-2.5 border border-red-200 rounded-lg text-sm focus:border-red-500 focus:ring-2 focus:ring-red-500/10 focus:outline-none transition" />
          <div id="sil-durum" class="hidden text-sm rounded-lg px-3 py-2"></div>
          <button type="submit" class="px-4 py-2 rounded-lg bg-red-600 text-white font-semibold text-sm hover:bg-red-700 transition">
            Hesabımı kalıcı sil
          </button>
        </form>
      </div>
    </div>
  </section>
</Base>

<script>
  import { tazele, kullaniciAl, sifreDegistir, veriDisaAktar, hesabimiSil } from "../lib/auth";

  // Login kontrol
  (async () => {
    const u = await tazele();
    if (!u) { location.href = "/giris?dön=/hesap"; return; }
    document.getElementById("prof-ad")!.textContent = u.ad ?? "—";
    document.getElementById("prof-email")!.textContent = u.email;
    const tierAd = u.tier === "free" ? "Free" : u.tier === "pro" ? "Pro" : u.tier === "pro_plus" ? "Pro+" : "Kurumsal";
    document.getElementById("prof-tier")!.textContent = tierAd;
    document.getElementById("prof-email-dogr")!.innerHTML = u.emailDogrulandi
      ? '<span class="text-emerald-700">✓ Doğrulandı</span>'
      : '<a href="/dogrulama" class="text-amber-700 underline">⚠ Doğrula</a>';
  })();

  // Şifre değiştir
  const sifreForm = document.getElementById("sifre-form") as HTMLFormElement;
  const sifreDurum = document.getElementById("sifre-durum") as HTMLDivElement;
  sifreForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    sifreDurum.classList.add("hidden");
    const fd = new FormData(sifreForm);
    try {
      await sifreDegistir(fd.get("eski") as string, fd.get("yeni") as string);
      sifreDurum.textContent = "Şifre güncellendi.";
      sifreDurum.className = "text-sm rounded-lg px-3 py-2 bg-emerald-50 border border-emerald-200 text-emerald-800";
      sifreForm.reset();
    } catch (err: any) {
      sifreDurum.textContent = err.message;
      sifreDurum.className = "text-sm rounded-lg px-3 py-2 bg-red-50 border border-red-200 text-red-800";
    }
  });

  // Veri export
  document.getElementById("export-btn")?.addEventListener("click", async () => {
    try {
      const data = await veriDisaAktar();
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = `cadastrum-veri-${Date.now()}.json`;
      a.click();
      URL.revokeObjectURL(url);
    } catch (err: any) {
      alert("Hata: " + err.message);
    }
  });

  // Hesap sil
  const silForm = document.getElementById("sil-form") as HTMLFormElement;
  const silDurum = document.getElementById("sil-durum") as HTMLDivElement;
  silForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    silDurum.classList.add("hidden");
    const onay = (new FormData(silForm).get("onay") as string).trim();
    if (!confirm("Hesabınız kalıcı silinecek. Onaylıyor musunuz?")) return;
    try {
      await hesabimiSil(onay);
      alert("Hesap silindi. Yönlendiriliyorsunuz.");
      location.href = "/";
    } catch (err: any) {
      silDurum.textContent = err.message;
      silDurum.className = "text-sm rounded-lg px-3 py-2 bg-red-50 border border-red-200 text-red-800";
    }
  });
</script>
