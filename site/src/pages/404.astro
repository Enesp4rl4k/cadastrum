---
export const prerender = true;
import Base from "../layouts/Base.astro";
---

<Base
  title="Sayfa Bulunamadı — Cadastrum"
  description="Aradığınız sayfa bulunamadı. Parsel sorgusu, harita ve veri kataloguna geri dönebilirsiniz."
  robots="noindex, follow"
>
  <section class="min-h-[70vh] flex items-center justify-center px-4">
    <div class="text-center max-w-lg mx-auto">
      <!-- İkon -->
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-slate-100 mb-6">
        <svg class="w-10 h-10 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
        </svg>
      </div>

      <!-- Başlık -->
      <h1 class="font-display text-4xl font-bold text-imperial-700 mb-3">404</h1>
      <h2 class="text-xl font-semibold text-slate-700 mb-3">Sayfa bulunamadı</h2>
      <p class="text-slate-500 text-sm leading-relaxed mb-8">
        Aradığınız sayfa taşınmış, silinmiş veya hiç olmamış olabilir.
        Parsel sorgusu ve harita her zaman burada.
      </p>

      <!-- CTA'lar -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/sorgu"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-imperial text-white rounded-lg text-sm font-semibold hover:bg-imperial-700 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-imperial"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Parsel Sorgusu
        </a>
        <a
          href="/harita"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-slate-200 text-slate-700 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
          </svg>
          İşlem Haritası
        </a>
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-slate-200 text-slate-700 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400"
        >
          Ana Sayfa
        </a>
      </div>

      <!-- Popüler linkler -->
      <div class="mt-12 pt-8 border-t border-slate-100">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-400 mb-4">Sık Kullanılanlar</p>
        <div class="flex flex-wrap justify-center gap-2">
          {[
            { href: "/arsa-yatirimi", label: "Arsa yatırımı" },
            { href: "/tarla-yatirimi", label: "Tarla yatırımı" },
            { href: "/imar-sorgu", label: "İmar sorgu" },
            { href: "/tkgm-parsel-sorgu", label: "TKGM parsel sorgu" },
            { href: "/kat-karsiligi", label: "Kat karşılığı" },
            { href: "/veri", label: "Veri katalogu" },
            { href: "/fiyat", label: "Fiyatlandırma" },
            { href: "/blog", label: "Blog" },
          ].map((link) => (
            <a
              href={link.href}
              class="px-3 py-1.5 bg-slate-100 text-slate-600 rounded-full text-xs hover:bg-slate-200 transition-colors"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>
