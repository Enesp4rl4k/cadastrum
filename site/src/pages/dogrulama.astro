---
export const prerender = true;
import Base from "../layouts/Base.astro";
---

<Base title="Email Doğrulama — Cadastrum" description="Cadastrum hesabınızı doğrulayın.">
  <section class="min-h-[80vh] flex items-center justify-center py-16 bg-slate-50">
    <div class="w-full max-w-md mx-auto px-4">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <div class="text-center mb-6">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600 mb-3">
            <svg class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor"><path d="M2.94 4.94a1.5 1.5 0 011.06-.44h12a1.5 1.5 0 011.06.44L10 11.5 2.94 4.94zM2 6.4V15a2 2 0 002 2h12a2 2 0 002-2V6.4l-7.34 6.78a1 1 0 01-1.32 0L2 6.4z"/></svg>
          </div>
          <h1 class="font-display text-2xl font-bold text-imperial-700">Email doğrulama</h1>
          <p id="durum-text" class="text-sm text-slate-500 mt-1">Kayıt sırasında gönderilen 6 haneli kodu girin.</p>
        </div>

        <form id="dogrula-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Doğrulama Kodu</label>
            <input type="text" name="kod" required maxlength="6" inputmode="numeric" pattern="[0-9]{6}"
              autocomplete="one-time-code"
              class="w-full px-3.5 py-3 border border-slate-200 rounded-lg text-center text-2xl font-mono tracking-[0.5em] focus:border-imperial focus:ring-2 focus:ring-imperial/10 focus:outline-none transition" />
          </div>
          <div id="hata" class="hidden text-sm text-red-700 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
          <div id="basarili" class="hidden text-sm text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-lg px-3 py-2"></div>
          <button type="submit" id="submit-btn"
            class="w-full py-2.5 rounded-lg bg-imperial text-white font-semibold text-sm hover:bg-imperial-700 transition disabled:opacity-50">
            Doğrula
          </button>
        </form>

        <div class="text-center mt-6 text-sm text-slate-500">
          Kod gelmedi mi?
          <button id="yeniden-gonder" class="text-imperial font-medium hover:underline">Yeniden gönder</button>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { dogrula, dogrulamaKodGonder, kullaniciAl, tazele } from "../lib/auth";

  // Zaten doğrulanmışsa ana sayfaya
  tazele().then(u => {
    if (!u) { location.href = "/giris"; return; }
    if (u.emailDogrulandi) location.href = "/";
  });

  const form = document.getElementById("dogrula-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const hataEl = document.getElementById("hata") as HTMLDivElement;
  const basariliEl = document.getElementById("basarili") as HTMLDivElement;
  const yenidenBtn = document.getElementById("yeniden-gonder") as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    hataEl.classList.add("hidden");
    basariliEl.classList.add("hidden");
    btn.disabled = true;

    const fd = new FormData(form);
    try {
      await dogrula((fd.get("kod") as string).trim());
      basariliEl.textContent = "Email başarıyla doğrulandı. Yönlendiriliyorsunuz...";
      basariliEl.classList.remove("hidden");
      setTimeout(() => location.href = "/", 1500);
    } catch (err: any) {
      hataEl.textContent = err.message ?? "Hata";
      hataEl.classList.remove("hidden");
      btn.disabled = false;
    }
  });

  yenidenBtn?.addEventListener("click", async () => {
    yenidenBtn.disabled = true;
    yenidenBtn.textContent = "Gönderiliyor...";
    try {
      await dogrulamaKodGonder();
      basariliEl.textContent = "Yeni kod gönderildi. Email kutunuzu kontrol edin.";
      basariliEl.classList.remove("hidden");
    } catch (err: any) {
      hataEl.textContent = err.message ?? "Hata";
      hataEl.classList.remove("hidden");
    }
    setTimeout(() => {
      yenidenBtn.disabled = false;
      yenidenBtn.textContent = "Yeniden gönder";
    }, 30000);
  });
</script>
