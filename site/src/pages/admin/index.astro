---
export const prerender = true;
import Base from "../../layouts/Base.astro";
---

<Base title="Admin Dashboard — Cadastrum" description="Cadastrum yönetim paneli" robots="noindex, nofollow">
  <section class="min-h-[80vh] py-12 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4">
      <header class="flex items-center justify-between mb-8">
        <div>
          <h1 class="font-display text-3xl font-bold text-imperial-700">Admin Dashboard</h1>
          <p class="text-sm text-slate-500 mt-1">Sistem sağlığı, kullanıcı yönetimi ve güvenlik izleme.</p>
        </div>
        <div class="flex items-center gap-3">
          <span id="admin-email" class="text-xs text-slate-500"></span>
          <button id="cikis-btn" class="text-xs text-rose-600 hover:underline">Çıkış</button>
        </div>
      </header>

      <!-- Login overlay -->
      <div id="login-overlay" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-center justify-center">
        <div class="bg-white rounded-xl shadow-xl p-8 w-full max-w-md">
          <h2 class="font-display text-xl font-bold text-imperial-700 mb-4">Admin Girişi</h2>
          <p class="text-xs text-slate-500 mb-4">Bu panel sadece admin yetkili kullanıcılar içindir.</p>
          <form id="admin-login-form" method="post" action="javascript:void(0)" class="space-y-3">
            <input type="email" id="email-input" required placeholder="email"
                   class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" />
            <input type="password" id="sifre-input" required placeholder="şifre"
                   class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" />
            <button type="submit" class="w-full bg-imperial text-white rounded-md py-2 text-sm font-semibold hover:bg-imperial-700">
              Giriş Yap
            </button>
            <p id="login-msg" class="text-xs text-rose-600 hidden"></p>
          </form>
        </div>
      </div>

      <div id="dashboard" class="hidden space-y-6">
        <!-- Özet kartları -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <div class="text-xs uppercase tracking-wide text-slate-500">Toplam Kullanıcı</div>
            <div id="m-kullanici" class="text-2xl font-bold text-ink mt-1">—</div>
            <div id="m-kullanici-yeni" class="text-xs text-emerald-600 mt-1"></div>
          </div>
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <div class="text-xs uppercase tracking-wide text-slate-500">Toplam İlan</div>
            <div id="m-ilan" class="text-2xl font-bold text-ink mt-1">—</div>
            <div id="m-ilan-24" class="text-xs text-emerald-600 mt-1"></div>
          </div>
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <div class="text-xs uppercase tracking-wide text-slate-500">AI Sorgu (7g)</div>
            <div id="m-ai" class="text-2xl font-bold text-ink mt-1">—</div>
            <div id="m-ai-cost" class="text-xs text-amber-600 mt-1"></div>
          </div>
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <div class="text-xs uppercase tracking-wide text-slate-500">Başarısız Giriş (24s)</div>
            <div id="m-guvenlik" class="text-2xl font-bold text-ink mt-1">—</div>
            <div id="m-guvenlik-ip" class="text-xs text-rose-600 mt-1"></div>
          </div>
        </div>

        <!-- Tab nav -->
        <div class="border-b border-slate-200">
          <nav class="flex gap-1 -mb-px">
            <button data-tab="trend" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-imperial text-imperial">Trend</button>
            <button data-tab="kullanicilar" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-ink">Kullanıcılar</button>
            <button data-tab="ai" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-ink">AI Kullanım</button>
            <button data-tab="ilan" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-ink">İlan Telemetri</button>
            <button data-tab="kpi" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-ink">Operasyon KPI</button>
            <button data-tab="outlier" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-ink">Veri Kalitesi</button>
            <button data-tab="abonelik" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-ink">Abonelik</button>
            <button data-tab="blast" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-ink">📧 Blast</button>
            <button data-tab="guvenlik" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-ink">Güvenlik</button>
            <button data-tab="log" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-ink">Denetim Logu</button>
            <button data-tab="saglik" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-ink">Sistem</button>
          </nav>
        </div>

        <!-- Tab panels -->
        <div id="tab-trend" class="tab-panel">
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <div class="flex justify-between items-center mb-4">
              <h3 class="font-semibold text-sm">Son 30 Gün</h3>
              <button id="cron-tetikle-btn" class="text-xs bg-imperial text-white px-3 py-1.5 rounded hover:bg-imperial-700">⟳ İstatistik Yenile</button>
            </div>
            <div id="trend-content" class="text-sm text-slate-600">Yükleniyor…</div>
          </div>
        </div>

        <div id="tab-outlier" class="tab-panel hidden">
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <h3 class="font-semibold text-sm mb-3">Şüpheli İlanlar (Son 30 Gün)</h3>
            <div id="outlier-content" class="text-sm text-slate-600">Yükleniyor…</div>
          </div>
        </div>

        <div id="tab-abonelik" class="tab-panel hidden">
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <h3 class="font-semibold text-sm mb-3">Abonelik Yönetimi</h3>
            <div id="abonelik-content" class="text-sm text-slate-600">Yükleniyor…</div>
          </div>
        </div>

        <div id="tab-blast" class="tab-panel hidden">
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <h3 class="font-semibold text-sm mb-3">📧 Newsletter Blast — Waitlist'e duyuru gönder</h3>
            <div class="mb-3 p-3 bg-amber-50 border border-amber-200 rounded text-xs text-amber-900">
              ⚠️ Önce <strong>"Test (sadece bana)"</strong> ile dene. Mail geldi mi doğrula. Sonra <strong>"Hepsine Gönder"</strong> aktifleşir.
            </div>
            <form id="blast-form" class="space-y-3">
              <div>
                <label class="block text-xs font-semibold text-slate-700 mb-1">Konu</label>
                <input id="blast-konu" type="text" required class="w-full rounded border border-slate-300 px-3 py-2 text-sm"
                  value="🚀 Cadastrum Chrome Web Store'da — ERKEN100 ile %40 indirim" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-700 mb-1">Düz metin (text fallback)</label>
                <textarea id="blast-metin" rows="3" required class="w-full rounded border border-slate-300 px-3 py-2 text-xs font-mono">Cadastrum bugün Chrome Web Store'da canlıya çıktı. İlk 100 üyeye 6 ay %40 indirim. Kod: ERKEN100. Yükle: https://chromewebstore.google.com/detail/cadastrum-arsa-tkgm-parsel-zekasi/aelbnillaapmecnopkoojcolecbdhiej</textarea>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-700 mb-1">HTML (Lansman template önyüklenmiş)</label>
                <textarea id="blast-html" rows="10" required class="w-full rounded border border-slate-300 px-3 py-2 text-[10px] font-mono"></textarea>
              </div>
              <div class="flex gap-2">
                <button type="button" id="blast-test-btn" class="flex-1 bg-amber-500 text-white rounded px-3 py-2 text-sm font-medium hover:bg-amber-600">
                  Test (sadece bana)
                </button>
                <button type="button" id="blast-send-btn" disabled class="flex-1 bg-imperial text-white rounded px-3 py-2 text-sm font-medium hover:bg-imperial-700 disabled:opacity-40 disabled:cursor-not-allowed">
                  Hepsine Gönder (kilitli)
                </button>
              </div>
              <p id="blast-msg" class="hidden text-xs"></p>
            </form>
          </div>
        </div>

        <!-- Kullanıcı detay drawer -->
        <div id="user-drawer" class="hidden fixed inset-0 bg-slate-900/40 z-40" onclick="if(event.target===this){this.classList.add('hidden')}">
          <div class="absolute right-0 top-0 bottom-0 w-full max-w-lg bg-white shadow-2xl overflow-y-auto p-6">
            <button id="drawer-close" class="text-slate-400 hover:text-rose-600 text-2xl float-right leading-none">×</button>
            <div id="drawer-content" class="text-sm">Yükleniyor…</div>
          </div>
        </div>

        <div id="tab-kullanicilar" class="tab-panel hidden">
          <div class="bg-white rounded-lg border border-slate-200">
            <div class="p-4 border-b border-slate-200 flex gap-2">
              <input id="user-search" type="search" placeholder="Email veya isim ara…"
                     class="flex-1 rounded-md border border-slate-300 px-3 py-2 text-sm" />
              <button id="user-search-btn" class="bg-imperial text-white rounded-md px-4 py-2 text-sm font-medium">Ara</button>
              <button id="user-csv-btn" class="bg-emerald-600 text-white rounded-md px-4 py-2 text-sm font-medium hover:bg-emerald-700">↓ CSV</button>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-slate-50 text-xs uppercase text-slate-500">
                  <tr>
                    <th class="text-left p-3">ID</th>
                    <th class="text-left p-3">Email</th>
                    <th class="text-left p-3">İsim</th>
                    <th class="text-left p-3">Tier</th>
                    <th class="text-left p-3">Durum</th>
                    <th class="text-left p-3">Doğrulama</th>
                    <th class="text-left p-3">Kayıt</th>
                    <th class="text-left p-3">Aksiyon</th>
                  </tr>
                </thead>
                <tbody id="user-tbody"></tbody>
              </table>
            </div>
          </div>
        </div>

        <div id="tab-ai" class="tab-panel hidden">
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <h3 class="font-semibold text-sm mb-3">Top AI Tüketicileri (Son 7 gün)</h3>
            <div id="ai-content" class="text-sm text-slate-600">Yükleniyor…</div>
          </div>
        </div>

        <div id="tab-ilan" class="tab-panel hidden">
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <div id="ilan-content" class="text-sm text-slate-600">Yükleniyor…</div>
          </div>
        </div>

        <div id="tab-kpi" class="tab-panel hidden">
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <div id="kpi-content" class="text-sm text-slate-600">Yükleniyor…</div>
          </div>
        </div>

        <div id="tab-guvenlik" class="tab-panel hidden">
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <div id="guvenlik-content" class="text-sm text-slate-600">Yükleniyor…</div>
          </div>
        </div>

        <div id="tab-log" class="tab-panel hidden">
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <div id="log-content" class="text-sm text-slate-600">Yükleniyor…</div>
          </div>
        </div>

        <div id="tab-saglik" class="tab-panel hidden">
          <div class="bg-white rounded-lg border border-slate-200 p-4">
            <div id="saglik-content" class="text-sm text-slate-600">Yükleniyor…</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const API = "https://cadastrum-api.cadastrum-tr.workers.dev/v1";
  const TOKEN_KEY = "cadastrum_token";

  function token(): string | null { return localStorage.getItem(TOKEN_KEY); }

  async function fetchJSON(path: string, init: RequestInit = {}) {
    const t = token();
    const res = await fetch(`${API}${path}`, {
      ...init,
      headers: {
        ...(init.headers || {}),
        Authorization: t ? `Bearer ${t}` : "",
        "Content-Type": "application/json",
      },
    });
    const j = await res.json();
    if (!res.ok) throw new Error(j.hata ?? `HTTP ${res.status}`);
    return j;
  }

  function tarih(ts: number | null | undefined): string {
    if (!ts) return "—";
    return new Date(ts).toLocaleDateString("tr-TR");
  }
  function tarihSaat(ts: number | null | undefined): string {
    if (!ts) return "—";
    return new Date(ts).toLocaleString("tr-TR");
  }
  function escape(s: string | null | undefined): string {
    if (s == null) return "";
    // Tüm tehlikeli karakterleri ve backtick'i (template injection) escape et
    return String(s).replace(/[&<>"'`/]/g, c => ({
      "&": "&amp;", "<": "&lt;", ">": "&gt;",
      '"': "&quot;", "'": "&#39;", "`": "&#96;", "/": "&#47;",
    }[c]!));
  }
  // Sayısal alanlar için katı validasyon — innerHTML attribute'larında kullanılan değerler
  function intOnly(v: any): number {
    const n = parseInt(String(v), 10);
    return Number.isFinite(n) ? n : 0;
  }

  // ── Login flow ──
  async function girisDogrula(): Promise<boolean> {
    if (!token()) return false;
    try {
      await fetchJSON("/admin/ozet");
      return true;
    } catch {
      return false;
    }
  }

  function loginGoster() {
    document.getElementById("login-overlay")!.classList.remove("hidden");
    document.getElementById("dashboard")!.classList.add("hidden");
  }
  function dashGoster() {
    document.getElementById("login-overlay")!.classList.add("hidden");
    document.getElementById("dashboard")!.classList.remove("hidden");
    yukle();
  }

  document.getElementById("admin-login-form")!.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = (document.getElementById("email-input") as HTMLInputElement).value.trim();
    const sifre = (document.getElementById("sifre-input") as HTMLInputElement).value;
    const msg = document.getElementById("login-msg")!;
    msg.classList.add("hidden");
    try {
      const res = await fetch(`${API}/auth/giris`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, sifre }),
      });
      const j = await res.json();
      if (!res.ok) throw new Error(j.hata ?? "Giriş hatası");
      localStorage.setItem(TOKEN_KEY, j.token);
      // Admin doğrulamasını yap
      const ok = await girisDogrula();
      if (!ok) {
        localStorage.removeItem(TOKEN_KEY);
        throw new Error("Bu hesap admin yetkisine sahip değil.");
      }
      document.getElementById("admin-email")!.textContent = j.kullanici.email;
      dashGoster();
    } catch (err: any) {
      msg.textContent = err.message;
      msg.classList.remove("hidden");
    }
  });

  document.getElementById("cikis-btn")!.addEventListener("click", () => {
    localStorage.removeItem(TOKEN_KEY);
    location.reload();
  });

  // ── Tab nav ──
  document.querySelectorAll(".tab-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const tab = (btn as HTMLElement).dataset.tab!;
      document.querySelectorAll(".tab-btn").forEach(b => {
        b.classList.remove("border-imperial", "text-imperial");
        b.classList.add("border-transparent", "text-slate-500");
      });
      btn.classList.remove("border-transparent", "text-slate-500");
      btn.classList.add("border-imperial", "text-imperial");
      document.querySelectorAll(".tab-panel").forEach(p => p.classList.add("hidden"));
      document.getElementById(`tab-${tab}`)!.classList.remove("hidden");
      tabYukle(tab);
    });
  });

  // ── Yükleyiciler ──
  async function yukleOzet() {
    try {
      const o = await fetchJSON("/admin/ozet");
      document.getElementById("m-kullanici")!.textContent = o.kullanici.toplam.toLocaleString("tr-TR");
      document.getElementById("m-kullanici-yeni")!.textContent = `+${o.kullanici.yeni24s} son 24s`;
      document.getElementById("m-ilan")!.textContent = o.ilan.toplam.toLocaleString("tr-TR");
      document.getElementById("m-ilan-24")!.textContent = `+${o.ilan.son24s} son 24s`;
      document.getElementById("m-ai")!.textContent = (o.ai.son7gun ?? 0).toLocaleString("tr-TR");
    } catch (e: any) {
      console.error(e);
    }
  }

  async function yukleKullanicilar(q = "") {
    const o = await fetchJSON(`/admin/kullanicilar?limit=100${q ? `&q=${encodeURIComponent(q)}` : ""}`);
    const tbody = document.getElementById("user-tbody")!;
    tbody.innerHTML = o.kullanicilar.map((u: any) => {
      const rozetTier = u.tier === "free" ? "bg-slate-100 text-slate-700" :
                        u.tier === "pro" ? "bg-imperial-50 text-imperial-700" :
                        u.tier === "pro_plus" ? "bg-amber-50 text-amber-700" :
                        "bg-emerald-50 text-emerald-700";
      const rozetDurum = u.durum === "aktif" ? "bg-emerald-50 text-emerald-700" :
                         u.durum === "banli" ? "bg-rose-50 text-rose-700" :
                         "bg-slate-100 text-slate-600";
      return `
        <tr class="border-t border-slate-100 hover:bg-slate-50">
          <td class="p-3 text-xs text-slate-500"><button class="hover:underline text-imperial" onclick="userDetayAc(${intOnly(u.id)})">${intOnly(u.id)}</button></td>
          <td class="p-3"><button class="hover:underline text-left" onclick="userDetayAc(${intOnly(u.id)})">${escape(u.email)}</button>${u.admin ? ' <span class="ml-1 px-1.5 py-0.5 rounded text-[10px] bg-rose-100 text-rose-700">ADMIN</span>' : ""}</td>
          <td class="p-3 text-slate-600">${escape(u.ad) || "—"}</td>
          <td class="p-3"><span class="px-2 py-0.5 rounded text-xs ${rozetTier}">${u.tier}</span></td>
          <td class="p-3"><span class="px-2 py-0.5 rounded text-xs ${rozetDurum}">${u.durum ?? "aktif"}</span></td>
          <td class="p-3 text-xs">${u.email_dogrulandi ? '✓' : '✗'}</td>
          <td class="p-3 text-xs text-slate-500">${tarih(u.olusturuldu)}</td>
          <td class="p-3 text-xs">
            <button class="text-imperial hover:underline mr-2" data-action="tier" data-id="${intOnly(u.id)}">Tier</button>
            <button class="text-rose-600 hover:underline" data-action="durum" data-id="${intOnly(u.id)}">Durum</button>
          </td>
        </tr>`;
    }).join("");

    tbody.querySelectorAll("[data-action='tier']").forEach(b => {
      b.addEventListener("click", async () => {
        const id = (b as HTMLElement).dataset.id;
        const tier = prompt("Yeni tier (free/pro/pro_plus/kurumsal):");
        if (!tier) return;
        const gun = prompt("Süre (gün, boş=süresiz):");
        try {
          await fetchJSON(`/admin/kullanici/${id}/tier`, {
            method: "POST",
            body: JSON.stringify({ tier, gun: gun ? parseInt(gun) : undefined }),
          });
          yukleKullanicilar(q);
        } catch (e: any) { alert(e.message); }
      });
    });
    tbody.querySelectorAll("[data-action='durum']").forEach(b => {
      b.addEventListener("click", async () => {
        const id = (b as HTMLElement).dataset.id;
        const durum = prompt("Yeni durum (aktif/banli/dondurulmus):");
        if (!durum) return;
        try {
          await fetchJSON(`/admin/kullanici/${id}/durum`, {
            method: "POST",
            body: JSON.stringify({ durum }),
          });
          yukleKullanicilar(q);
        } catch (e: any) { alert(e.message); }
      });
    });
  }

  document.getElementById("user-search-btn")!.addEventListener("click", () => {
    const q = (document.getElementById("user-search") as HTMLInputElement).value.trim();
    yukleKullanicilar(q);
  });

  // CSV indir
  document.getElementById("user-csv-btn")!.addEventListener("click", async () => {
    const res = await fetch(`${API}/admin/export/kullanicilar`, {
      headers: { Authorization: `Bearer ${token()}` },
    });
    if (!res.ok) { alert("CSV indirilemedi"); return; }
    const blob = await res.blob();
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url; a.download = `kullanicilar-${Date.now()}.csv`; a.click();
    URL.revokeObjectURL(url);
  });

  // Drawer kapat
  document.getElementById("drawer-close")!.addEventListener("click", () => {
    document.getElementById("user-drawer")!.classList.add("hidden");
  });

  // Cron tetikle
  document.getElementById("cron-tetikle-btn")!.addEventListener("click", async () => {
    const btn = document.getElementById("cron-tetikle-btn") as HTMLButtonElement;
    btn.disabled = true; btn.textContent = "Çalışıyor…";
    try {
      const o = await fetchJSON("/admin/cron-tetikle", { method: "POST" });
      btn.textContent = `✓ Yenilendi (${JSON.stringify(o.sonuc).slice(0, 40)})`;
      setTimeout(() => { btn.textContent = "⟳ İstatistik Yenile"; btn.disabled = false; }, 3000);
    } catch (e: any) {
      alert(e.message); btn.disabled = false; btn.textContent = "⟳ İstatistik Yenile";
    }
  });

  // Kullanıcı detay drawer aç
  async function userDetayAc(id: number) {
    document.getElementById("user-drawer")!.classList.remove("hidden");
    const el = document.getElementById("drawer-content")!;
    el.innerHTML = "Yükleniyor…";
    try {
      const o = await fetchJSON(`/admin/kullanici/${id}/detay`);
      const u = o.kullanici;
      el.innerHTML = `
        <h3 class="font-display text-xl font-bold text-imperial-700 mb-1">${escape(u.email)}</h3>
        <p class="text-xs text-slate-500 mb-4">ID: ${u.id} · ${escape(u.ad) || "(isim yok)"} · ${u.admin ? '<span class="text-rose-600 font-bold">ADMIN</span>' : ''}</p>

        <div class="grid grid-cols-2 gap-3 mb-5">
