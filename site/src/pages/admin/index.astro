  function sparkSVG(data: number[], renk = "#1B2A4A", h = 60): string {
    if (!data.length) return "";
    const max = Math.max(...data, 1);
    const w = Math.max(data.length * 8, 200);
    const points = data.map((v, i) => `${(i / (data.length - 1 || 1)) * w},${h - (v / max) * h}`).join(" ");
    return `<svg width="100%" viewBox="0 0 ${w} ${h}" preserveAspectRatio="none" class="block">
      <polyline fill="none" stroke="${renk}" stroke-width="2" points="${points}"/>
    </svg>`;
  }

