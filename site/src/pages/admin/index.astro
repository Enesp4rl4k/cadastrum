  (async () => {
    const ok = await girisDogrula();
    if (ok) {
      try {
        const me = await fetchJSON("/auth/ben");
        document.getElementById("admin-email")!.textContent = me.kullanici.email;
      } catch {}
      dashGoster();
    } else {
      loginGoster();
    }
  })();
