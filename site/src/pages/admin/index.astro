  async function blastGonder(test: boolean) {
    const konu = (document.getElementById("blast-konu") as HTMLInputElement).value.trim();
    const metin = (document.getElementById("blast-metin") as HTMLTextAreaElement).value.trim();
    const html = (document.getElementById("blast-html") as HTMLTextAreaElement).value.trim();
    const msg = document.getElementById("blast-msg")!;
    if (!konu || !metin || !html) {
      msg.textContent = "Tüm alanlar zorunlu";
      msg.className = "text-xs text-rose-600";
      msg.classList.remove("hidden");
      return;
    }
    const btn = test
      ? document.getElementById("blast-test-btn") as HTMLButtonElement
      : document.getElementById("blast-send-btn") as HTMLButtonElement;
    const onceki = btn.textContent;
    btn.disabled = true;
    btn.textContent = "Gönderiliyor…";
    try {
      const r = await fetchJSON("/admin/newsletter-blast", {
        method: "POST",
        body: JSON.stringify({ konu, metin, html, test }),
      });
      msg.textContent = `✓ ${r.gonderildi}/${r.alici} gönderildi${r.hata > 0 ? ` (${r.hata} hata)` : ""}`;
      msg.className = "text-xs text-emerald-700 font-medium";
      msg.classList.remove("hidden");
      if (test && r.gonderildi > 0) {
        // Test başarılı → Send butonunu aç
        const sendBtn = document.getElementById("blast-send-btn") as HTMLButtonElement;
        sendBtn.disabled = false;
        sendBtn.textContent = `🚀 Hepsine Gönder (${r.alici} kişi)`;
      }
    } catch (e: any) {
      msg.textContent = `Hata: ${e.message}`;
      msg.className = "text-xs text-rose-600";
      msg.classList.remove("hidden");
    } finally {
      btn.disabled = false;
      btn.textContent = onceki || "Gönder";
    }
  }
  document.getElementById("blast-test-btn")?.addEventListener("click", () => blastGonder(true));
  document.getElementById("blast-send-btn")?.addEventListener("click", () => {
    if (confirm("EMIN MISIN? Tüm waitlist'e mail gidecek. Bu işlem geri alınamaz.")) {
      blastGonder(false);
    }
  });

  const yukleyici: Record<string, () => Promise<void>> = {
    trend: yukleTrend,
    kullanicilar: () => yukleKullanicilar(),
    ai: yukleAi,
    ilan: yukleIlan,
    kpi: yukleKpi,
    outlier: yukleOutlier,
    abonelik: yukleAbonelik,
    blast: yukleBlast,
    guvenlik: yukleGuvenlik,
    log: yukleLog,
    saglik: yukleSaglik,
  };
  const yuklendi: Record<string, boolean> = {};

  function tabYukle(tab: string) {
    if (yuklendi[tab]) return;
    yuklendi[tab] = true;
    yukleyici[tab]?.();
  }

  async function yukle() {
    yukleOzet();
    yukleGuvenlik();
    yukleAi();
    tabYukle("trend");
  }

