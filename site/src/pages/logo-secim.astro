---
export const prerender = true;
---
<!doctype html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <title>Cadastrum — Logo Seçim</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:wght@500;600;700&display=swap" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Inter, sans-serif; background: #F1F5F9; color: #1B2A4A; padding: 60px 20px; }
    .container { max-width: 900px; margin: 0 auto; }
    h1 { font-family: 'Source Serif 4', Georgia, serif; font-size: 32px; margin-bottom: 8px; }
    .sub { color: #64748B; margin-bottom: 40px; }
    .grid { display: grid; gap: 24px; grid-template-columns: 1fr; }
    .card { background: #fff; border-radius: 12px; padding: 32px; border: 1px solid #E2E8F0; }
    .card h2 { font-family: 'Source Serif 4', serif; font-size: 18px; margin-bottom: 4px; color: #1B2A4A; }
    .card .desc { color: #64748B; font-size: 13px; margin-bottom: 20px; line-height: 1.5; }
    .preview { display: flex; align-items: center; gap: 32px; flex-wrap: wrap; }
    .size-32, .size-64, .size-128 {
      display: flex; flex-direction: column; align-items: center; gap: 6px;
    }
    .size-32 .img { width: 32px; height: 32px; }
    .size-64 .img { width: 64px; height: 64px; }
    .size-128 .img { width: 128px; height: 128px; }
    .size-label { font-size: 10px; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.05em; }
    .dark-bg { background: #1B2A4A; padding: 16px; border-radius: 8px; }
    .light-bg { background: #FBFAF7; padding: 16px; border-radius: 8px; border: 1px solid #E2E8F0; }
    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 16px; }
    .row > div { padding: 24px; border-radius: 8px; }
    .wordmark-card img { max-width: 320px; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Cadastrum — Logo Önerileri</h1>
    <p class="sub">3 farklı kurumsal yaklaşım. Hangisini seçtiğini söyle.</p>

    <div class="grid">
      <!-- V1: Klasik Monogram -->
      <div class="card">
        <h2>V1 — Klasik Monogram (Sotheby's tarzı)</h2>
        <p class="desc">Beyaz arka plan, ince imperial blue çerçeve, içinde altın detay çerçeve, serif "C" + champagne mühür noktası. Klasik gayrimenkul/finans hissi.</p>
        <div class="preview">
          <div class="size-32"><img class="img" src="/logo-v1.svg" /><span class="size-label">32px (favicon)</span></div>
          <div class="size-64"><img class="img" src="/logo-v1.svg" /><span class="size-label">64px</span></div>
          <div class="size-128"><img class="img" src="/logo-v1.svg" /><span class="size-label">128px</span></div>
        </div>
        <div class="row">
          <div class="dark-bg"><img class="img" style="width:64px;height:64px" src="/logo-v1.svg" /></div>
          <div class="light-bg"><img class="img" style="width:64px;height:64px" src="/logo-v1.svg" /></div>
        </div>
      </div>

      <!-- V2: Solid Modern -->
      <div class="card">
        <h2>V2 — Solid Modern (JLL/CBRE tarzı)</h2>
        <p class="desc">Imperial blue solid kare, beyaz serif "C", altın diagonal aksent + altın altçizgi. Modern kurumsal, dijital mecralarda güçlü.</p>
        <div class="preview">
          <div class="size-32"><img class="img" src="/logo-v2.svg" /><span class="size-label">32px (favicon)</span></div>
          <div class="size-64"><img class="img" src="/logo-v2.svg" /><span class="size-label">64px</span></div>
          <div class="size-128"><img class="img" src="/logo-v2.svg" /><span class="size-label">128px</span></div>
        </div>
        <div class="row">
          <div class="dark-bg"><img class="img" style="width:64px;height:64px" src="/logo-v2.svg" /></div>
          <div class="light-bg"><img class="img" style="width:64px;height:64px" src="/logo-v2.svg" /></div>
        </div>
      </div>

      <!-- V3: Geometric Circle -->
      <div class="card">
        <h2>V3 — Geometric (Compass/fintech tarzı)</h2>
        <p class="desc">Imperial blue daire, beyaz "C" şekli arc olarak, sağ ucunda champagne nokta — parselin "kilitlenen" sınırı sembolü. Modern fintech / SaaS hissi.</p>
        <div class="preview">
          <div class="size-32"><img class="img" src="/logo-v3.svg" /><span class="size-label">32px (favicon)</span></div>
          <div class="size-64"><img class="img" src="/logo-v3.svg" /><span class="size-label">64px</span></div>
          <div class="size-128"><img class="img" src="/logo-v3.svg" /><span class="size-label">128px</span></div>
        </div>
        <div class="row">
          <div class="dark-bg"><img class="img" style="width:64px;height:64px" src="/logo-v3.svg" /></div>
          <div class="light-bg"><img class="img" style="width:64px;height:64px" src="/logo-v3.svg" /></div>
        </div>
      </div>

      <!-- Wordmark -->
      <div class="card wordmark-card">
        <h2>Wordmark — V1 emblem + "CADASTRUM" yazı (header için)</h2>
        <p class="desc">Site header'da, fatura, email imzasında kullanılır. V1 emblemi ile kombo. Tagline "PARSEL ZEKÂSI" küçük altta.</p>
        <div style="background:#FBFAF7;padding:32px;border-radius:8px;border:1px solid #E2E8F0;text-align:center">
          <img src="/logo-wordmark.svg" />
        </div>
      </div>
    </div>

    <div style="margin-top:40px;padding:24px;background:#fff;border-radius:8px;border:1px solid #E2E8F0">
      <strong>Sonraki adım:</strong>
      <p style="margin-top:8px;color:#475569;font-size:14px;line-height:1.6">
        V1, V2, V3'ten hangisini beğendiğini söyle, ben siteye, extension'a ve OG image'a entegre edeyim.<br>
        İstersen değişiklik (örn. "V1 ama daire şeklinde") veya yeni alternatif iste.
      </p>
    </div>
  </div>
</body>
</html>
