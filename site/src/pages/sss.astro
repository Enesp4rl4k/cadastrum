---
export const prerender = true;
import Base from "../layouts/Base.astro";

const kategoriler = [
  {
    baslik: "Genel",
    sorular: [
      {
        q: "Cadastrum ne işe yarar?",
        a: "Sahibinden veya Hepsiemlak'ta arsa ilanı incelerken TKGM resmi parsel kaydı, e-Plan imar durumu, mahalle bazlı emsal fiyat ve TKGM satış yoğunluğu (heatmap) gibi karar destek bilgilerini saniyeler içinde yan panelde gösterir.",
      },
      {
        q: "TKGM, Sahibinden veya Hepsiemlak ile resmi bağlantınız var mı?",
        a: "Hayır. Cadastrum bağımsız bir araçtır; sadece kullanıcının ziyaret ettiği herkese açık sayfalardan veri çıkarır ve TKGM/e-Plan'ın halka açık API/sayfalarını kullanır.",
      },
      {
        q: "Hangi tarayıcılarda çalışır?",
        a: "Şu an sadece Google Chrome (ve Edge, Brave gibi Chromium tabanlı tarayıcılar). Firefox desteği yol haritasında.",
      },
    ],
  },
  {
    baslik: "Veri ve gizlilik",
    sorular: [
      {
        q: "Verilerim sunucularınıza gönderiliyor mu?",
        a: "Hayır. Tüm parsel ve ilan verileri tarayıcınızın yerel veritabanında (IndexedDB) tutulur. Cadastrum sadece lisans doğrulaması için minimal bilgi (e-posta + lisans anahtarı) gönderir.",
      },
      {
        q: "AI fiyat tahmini için verilerim nereye gidiyor?",
        a: "Seçtiğiniz sağlayıcıya. Gemini seçerseniz Google API'sine, Ollama seçerseniz lokal makinenize. Cadastrum sunucusu AI çağrılarını ne görür ne de log'lar.",
      },
      {
        q: "Eklentiyi kaldırırsam verilerim ne olur?",
        a: "Tarayıcı verilerini de temizlerseniz tamamen silinir. Tek başına eklenti kaldırma, IndexedDB'yi de temizler (Chrome standardı).",
      },
    ],
  },
  {
    baslik: "Fiyatlandırma & ödeme",
    sorular: [
      {
        q: "TR'den nasıl ödeyebilirim?",
        a: "LemonSqueezy üzerinden Visa/Mastercard ile USD ödeme yaparsınız. Bankanız TL'ye otomatik çevirir. (Spotify, Netflix, ChatGPT modeli.) TL native ödeme yakında — ileri faz.",
      },
      {
        q: "İptal etmek için ne yapmam gerek?",
        a: "Tek tıkla. Aboneliği LemonSqueezy müşteri portalından dilediğiniz zaman iptal edebilirsiniz. İptal sonrası dönem sonuna kadar Pro özellikler aktif kalır.",
      },
      {
        q: "İade politikası?",
        a: "İlk 7 gün için koşulsuz iade. Memnun kalmazsanız iletisim@cadastrum.com.tr adresinden yazın, sorgu sormadan iade ederiz.",
      },
      {
        q: "Yıllık ödeme indirimi var mı?",
        a: "Yakında — yıllık planlarda 2 ay ücretsiz (yaklaşık %17 indirim).",
      },
      {
        q: "Tier'lar arası geçiş yapabilir miyim?",
        a: "Evet. Yükseltmede aradaki fark prorate edilir. Düşürmede dönem sonunda yeni tier devreye girer.",
      },
    ],
  },
  {
    baslik: "Teknik",
    sorular: [
      {
        q: "TKGM verisi ne kadar günceldir?",
        a: "TKGM'nin canlı API'si çağrılır — yani TKGM'de o anda ne varsa o görüntülenir. Cadastrum 30 gün cache tutar (parsel başına) ama yeni sorguda otomatik yenilenir.",
      },
      {
        q: "e-Plan tüm Türkiye için çalışır mı?",
        a: "e-Plan Bakanlığın resmi portalı; tüm Türkiye kapsanır. Bazı belediyelerin verisi henüz yüklenmemiş olabilir — bu durumda 'kayıt bulunamadı' görürsünüz.",
      },
      {
        q: "Heatmap nasıl çalışır?",
        a: "TKGM ilçe bazlı analiz API'si üzerinden alım-satım yoğunluğu, ipotek, haciz gibi 5 farklı katmanı çeker; harita üzerinde renk-kodlu olarak çizer.",
      },
    ],
  },
];
---

<Base title="Sıkça Sorulanlar — Cadastrum">
  <section class="border-b border-slate-100 bg-slate-50">
    <div class="container-prose py-16 md:py-20 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-ink tracking-tight">
        Sıkça sorulanlar
      </h1>
      <p class="mt-4 text-lg text-slate-600 max-w-2xl mx-auto">
        Aklınıza takılan bir şey kalırsa
        <a href="mailto:iletisim@cadastrum.com.tr" class="text-brand hover:underline">iletisim@cadastrum.com.tr</a>
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container-prose">
      <div class="max-w-3xl mx-auto space-y-12">
        {
          kategoriler.map((k) => (
            <div>
              <h2 class="font-display text-2xl font-bold text-ink mb-6">{k.baslik}</h2>
              <div class="space-y-3">
                {k.sorular.map((s) => (
                  <details class="rounded-lg border border-slate-200 bg-white px-5 py-4 group">
                    <summary class="cursor-pointer font-semibold text-ink flex justify-between items-center list-none">
                      {s.q}
                      <span class="text-slate-400 group-open:rotate-180 transition flex-shrink-0 ml-4" aria-hidden="true">▾</span>
                    </summary>
                    <p class="mt-3 text-sm text-slate-600 leading-relaxed">{s.a}</p>
                  </details>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Base>
