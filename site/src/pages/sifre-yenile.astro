---
export const prerender = true;
import Base from "../layouts/Base.astro";
---

<Base title="Yeni Şifre Belirle — Cadastrum" description="Hesabınız için yeni şifre belirleyin.">
  <section class="min-h-[80vh] flex items-center justify-center py-16 bg-slate-50">
    <div class="w-full max-w-md mx-auto px-4">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <div class="text-center mb-6">
          <h1 class="font-display text-2xl font-bold text-imperial-700">Yeni şifre belirle</h1>
          <p class="text-sm text-slate-500 mt-1">En az 8 karakter girin.</p>
        </div>

        <form id="form" method="post" action="javascript:void(0)" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Yeni Şifre</label>
            <input type="password" name="yeniSifre" required minlength="8" autocomplete="new-password"
              class="w-full px-3.5 py-2.5 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-2 focus:ring-imperial/10 focus:outline-none transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Yeni Şifre (tekrar)</label>
            <input type="password" name="tekrar" required minlength="8" autocomplete="new-password"
              class="w-full px-3.5 py-2.5 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-2 focus:ring-imperial/10 focus:outline-none transition" />
          </div>
          <div id="hata" class="hidden text-sm text-red-700 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
          <div id="basarili" class="hidden text-sm text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-lg px-3 py-2"></div>
          <button type="submit" id="submit-btn"
            class="w-full py-2.5 rounded-lg bg-imperial text-white font-semibold text-sm hover:bg-imperial-700 transition disabled:opacity-50">
            Şifremi yenile
          </button>
        </form>
      </div>
    </div>
  </section>
</Base>

<script>
  import { sifreYenile } from "../lib/auth";

  const params = new URLSearchParams(location.search);
  const token = params.get("token");

  if (!token) {
    document.body.innerHTML = `<div style="text-align:center;padding:80px 20px;font-family:Inter,sans-serif">
      <h1 style="color:#1B2A4A;font-size:24px;margin-bottom:12px;">Geçersiz bağlantı</h1>
      <p style="color:#64748b;">Şifre sıfırlama bağlantısında token yok.</p>
      <a href="/sifre-sifirla" style="color:#1B2A4A;text-decoration:underline;margin-top:16px;display:inline-block">Yeni bağlantı iste</a>
    </div>`;
  }

  const form = document.getElementById("form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const hataEl = document.getElementById("hata") as HTMLDivElement;
  const basariliEl = document.getElementById("basarili") as HTMLDivElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    hataEl.classList.add("hidden");
    basariliEl.classList.add("hidden");

    const fd = new FormData(form);
    const yeniSifre = fd.get("yeniSifre") as string;
    const tekrar = fd.get("tekrar") as string;

    if (yeniSifre !== tekrar) {
      hataEl.textContent = "Şifreler eşleşmiyor";
      hataEl.classList.remove("hidden");
      return;
    }

    btn.disabled = true;
    btn.textContent = "Yenileniyor...";

    try {
      await sifreYenile(token!, yeniSifre);
      basariliEl.textContent = "Şifre yenilendi. Giriş ekranına yönlendiriliyorsunuz...";
      basariliEl.classList.remove("hidden");
      setTimeout(() => location.href = "/giris", 2000);
    } catch (err: any) {
      hataEl.textContent = err.message ?? "Hata";
      hataEl.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "Şifremi yenile";
    }
  });
</script>
