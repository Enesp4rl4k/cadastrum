---
export const prerender = true;
import Base from "../layouts/Base.astro";
---

<Base title="Kayıt Ol — Cadastrum" description="Cadastrum hesabı oluşturun, ücretsiz başlayın.">
  <section class="min-h-[80vh] flex items-center justify-center py-16 bg-slate-50">
    <div class="w-full max-w-md mx-auto px-4">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <div class="text-center mb-6">
          <h1 class="font-display text-2xl font-bold text-imperial-700">Hesap oluşturun</h1>
          <p class="text-sm text-slate-500 mt-1">Ücretsiz başlayın, dilediğinizde Pro'ya geçin.</p>
        </div>

        <form id="kayit-form" method="post" action="javascript:void(0)" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Adınız</label>
            <input type="text" name="ad" autocomplete="name"
              class="w-full px-3.5 py-2.5 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-2 focus:ring-imperial/10 focus:outline-none transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
            <input type="email" name="email" required autocomplete="email"
              class="w-full px-3.5 py-2.5 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-2 focus:ring-imperial/10 focus:outline-none transition" />
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="block text-sm font-medium text-slate-700">Şifre</label>
              <span class="text-xs text-slate-400">en az 8 karakter</span>
            </div>
            <input type="password" name="sifre" required minlength="8" autocomplete="new-password"
              class="w-full px-3.5 py-2.5 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-2 focus:ring-imperial/10 focus:outline-none transition" />
          </div>
          <div id="hata" class="hidden text-sm text-red-700 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
          <button type="submit" id="submit-btn"
            class="w-full py-2.5 rounded-lg bg-imperial text-white font-semibold text-sm hover:bg-imperial-700 transition disabled:opacity-50">
            Kayıt ol
          </button>
          <p class="text-xs text-slate-500 text-center leading-relaxed">
            Kayıt olarak <a href="/kullanim-kosullari" class="text-imperial hover:underline">Kullanım Koşulları</a>,
            <a href="/gizlilik" class="text-imperial hover:underline">Gizlilik Politikası</a> ve
            <a href="/mesafeli-satis" class="text-imperial hover:underline">Mesafeli Satış Sözleşmesi</a>'ni okuyup kabul ettiğinizi onaylarsınız.
            Ücretli plana geçmeniz halinde 7 günlük ücretsiz deneme süresi başlar; deneme sonunda ifaya başlanmasıyla
            yasal cayma hakkınızdan feragat etmiş sayılırsınız (Mesafeli Sözleşmeler Yön. Md. 15/ğ). Ücretli döneme geçtikten sonra
            <a href="/iade-iptal" class="text-imperial hover:underline">iade yapılmaz</a>; istediğiniz zaman iptal edebilirsiniz.
          </p>
        </form>

        <div class="text-center mt-6 text-sm text-slate-500">
          Zaten hesabınız var mı?
          <a href="/giris" class="text-imperial font-medium hover:underline">Giriş yapın</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { kayit, tazele } from "../lib/auth";

  tazele().then(u => { if (u) location.href = "/"; });

  const form = document.getElementById("kayit-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const hataEl = document.getElementById("hata") as HTMLDivElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    hataEl.classList.add("hidden");
    btn.disabled = true;
    btn.textContent = "Hesap oluşturuluyor...";

    const fd = new FormData(form);
    try {
      await kayit(
        fd.get("email") as string,
        fd.get("sifre") as string,
        (fd.get("ad") as string) || undefined,
      );
      location.href = "/";
    } catch (err: any) {
      hataEl.textContent = err.message ?? "Bir hata oluştu";
      hataEl.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "Kayıt ol";
    }
  });
</script>
