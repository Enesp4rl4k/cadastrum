<script>
  // Scroll-scrub cinematic hero — --hero-p (0→1) + optional video playhead
  let heroScrubCleanup: (() => void) | null = null;

  function initHeroScrub() {
    heroScrubCleanup?.();
    heroScrubCleanup = null;

    const section = document.querySelector<HTMLElement>("[data-hero-scrub]");
    if (!section) return;

    const video = section.querySelector<HTMLVideoElement>("[data-hero-video]");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (reduceMotion) {
      section.style.setProperty("--hero-p", "1");
      if (video) {
        video.pause();
        const seekEnd = () => {
          if (video.duration && Number.isFinite(video.duration)) {
            video.currentTime = video.duration * 0.85;
          }
        };
        if (video.readyState >= 1) seekEnd();
        else video.addEventListener("loadedmetadata", seekEnd, { once: true });
      }
      return;
    }

    let raf = 0;
    let videoReady = false;

    if (video) {
      video.pause();
      const onMeta = () => { videoReady = Number.isFinite(video.duration) && video.duration > 0; };
      if (video.readyState >= 1) onMeta();
      else video.addEventListener("loadedmetadata", onMeta, { once: true });
    }

    const update = () => {
      raf = 0;
      const total = section.offsetHeight - window.innerHeight;
      if (total <= 0) {
        section.style.setProperty("--hero-p", "0");
        return;
      }
      const scrolled = Math.min(Math.max(-section.getBoundingClientRect().top, 0), total);
      const p = scrolled / total;
      section.style.setProperty("--hero-p", p.toFixed(4));

      if (video && videoReady) {
        const t = p * video.duration * 0.999;
        if (Math.abs(video.currentTime - t) > 0.033) {
          try { video.currentTime = t; } catch { /* seek race */ }
        }
      }
    };

    const onScroll = () => {
      if (!raf) raf = requestAnimationFrame(update);
    };

    update();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });

    heroScrubCleanup = () => {
      window.removeEventListener("scroll", onScroll);
      window.removeEventListener("resize", onScroll);
      if (raf) cancelAnimationFrame(raf);
    };
  }

  initHeroScrub();
  document.addEventListener("astro:page-load", initHeroScrub);

  // Hero waitlist form — backend /v1/newsletter/abone-ol
  const heroForm = document.getElementById("hero-waitlist") as HTMLFormElement | null;
  const heroMsg = document.getElementById("hero-waitlist-msg") as HTMLParagraphElement | null;
  heroForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(heroForm);
    const email = String(data.get("email") || "").trim();
    if (!email) return;
    const btn = heroForm.querySelector("button[type=submit]") as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = "..."; }
    try {
      const r = await fetch("https://cadastrum-api.cadastrum-tr.workers.dev/v1/newsletter/abone-ol", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, kaynak: "hero" }),
      });
      const j = await r.json();
      if (heroMsg) {
        if (r.ok) {
          heroMsg.textContent = `✓ ${email} listede ${j.sira ? `(${j.sira}. sıra)` : ""} — Lansmanda haberdar olacaksın. ERKEN100 ile %40 indirim.`;
          heroMsg.className = "mt-3 text-sm font-medium text-emerald-700";
          heroForm.reset();
          // Sayım güncelle
          guncelleSayim();
        } else {
          heroMsg.textContent = j.hata || "Hata oluştu";
          heroMsg.className = "mt-3 text-sm font-medium text-rose-600";
        }
        heroMsg.classList.remove("hidden");
      }
    } catch (err) {
      if (heroMsg) {
        heroMsg.textContent = "Bağlantı hatası, tekrar dene";
        heroMsg.className = "mt-3 text-sm font-medium text-rose-600";
        heroMsg.classList.remove("hidden");
      }
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = "Erken erişim al →"; }
    }
  });

  // Waitlist sayım — canlı social proof
  async function guncelleSayim() {
    try {
      const r = await fetch("https://cadastrum-api.cadastrum-tr.workers.dev/v1/newsletter/sayim");
      const j = await r.json();
      // Tabandan başla — gerçek sayı + base ekleyebiliriz isteğe bağlı
      const toplam = Math.min(100, Math.max(0, j.toplam ?? 0));
      const cnt = document.getElementById("waitlist-count");
      const bar = document.getElementById("waitlist-bar");
      if (cnt) cnt.textContent = String(toplam);
      if (bar) (bar as HTMLElement).style.width = `${toplam}%`;
    } catch {
      // Sessizce başarısız ol — fallback "23"
      const cnt = document.getElementById("waitlist-count");
      const bar = document.getElementById("waitlist-bar");
      if (cnt) cnt.textContent = "—";
      if (bar) (bar as HTMLElement).style.width = "0%";
    }
  }
  guncelleSayim();
</script>
