---
export const prerender = true;
import Base from "../layouts/Base.astro";
---

<!-- MapLibre GL JS — CDN, build'e girmiyor -->
<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4/dist/maplibre-gl.css" />

<Base title="Parsel Sorgu — Cadastrum" description="Haritaya tıkla, parselin TL değer aralığını, emsal sayısını ve güven seviyesini anında gör.">

  <!-- Page header -->
  <div class="border-b border-slate-100 bg-white/80 backdrop-blur-sm">
    <div class="container-prose py-5">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h1 class="font-display text-2xl md:text-3xl font-bold text-imperial-700 leading-tight">
            Parsel Değer Sorgusu
          </h1>
          <p class="text-slate-500 text-sm mt-1">
            Haritaya tıkla veya adres gir → anında <strong class="text-slate-700">TL değer aralığı</strong>, emsal ve güven skoru
          </p>
        </div>
        <div class="flex items-center gap-2 text-xs text-slate-500 bg-slate-50 rounded-lg px-3 py-2 border border-slate-200">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          Free: 20 sorgu/saat
        </div>
      </div>
    </div>
  </div>

  <!-- Split layout: 2/3 harita + 1/3 panel -->
  <div class="flex flex-col lg:flex-row" style="min-height: calc(100vh - 130px);">

    <!-- ══════════════════════════════════════
         SOL — MapLibre harita (2/3)
    ══════════════════════════════════════ -->
    <div class="relative lg:flex-[2] h-[55vw] lg:h-auto min-h-[340px]">
      <div id="sorgu-harita" class="absolute inset-0 w-full h-full"></div>

      <!-- Harita üstü overlay — adres arama -->
      <div class="absolute top-3 left-3 right-14 z-10">
        <div class="flex gap-2 shadow-lg">
          <input
            type="text"
            id="adres"
            placeholder="Adres veya yer adı ara… (örn: Beykoz Kavacık)"
            class="flex-1 px-3 py-2.5 bg-white/95 backdrop-blur-sm border border-white/60 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-imperial/20 focus:border-imperial placeholder-slate-400 shadow-sm"
            autocomplete="off"
          />
          <button type="button" id="adres-btn"
            class="px-3 py-2.5 bg-white/95 backdrop-blur-sm border border-white/60 rounded-lg text-sm font-medium text-slate-700 hover:bg-white shadow-sm transition-colors whitespace-nowrap">
            Bul
          </button>
        </div>
        <div id="adres-status" class="text-xs mt-1.5 px-1"></div>
      </div>

      <!-- Konum butonu -->
      <button type="button" id="konum-btn"
        class="absolute top-3 right-3 z-10 w-10 h-10 bg-white/95 backdrop-blur-sm border border-white/60 rounded-lg shadow-sm flex items-center justify-center text-slate-600 hover:bg-white hover:text-imperial transition-colors"
        title="Bulunduğum konum">
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 2a8 8 0 100 16A8 8 0 0010 2zm0 2a6 6 0 110 12A6 6 0 0110 4zm0 4a2 2 0 100 4 2 2 0 000-4z" clip-rule="evenodd"/>
        </svg>
      </button>

      <!-- Harita ipucu — ilk açılışta görünür -->
      <div id="harita-ipucu"
        class="absolute bottom-4 left-1/2 -translate-x-1/2 z-10 bg-imperial/90 text-white text-xs px-4 py-2 rounded-full shadow-lg backdrop-blur-sm pointer-events-none transition-opacity duration-500"
        aria-hidden="true">
        Haritaya tıkla → değeri hesapla
      </div>

      <!-- Koordinat göstergesi -->
      <div id="koord-badge"
        class="absolute bottom-4 left-3 z-10 bg-white/90 backdrop-blur-sm text-xs text-slate-600 px-2.5 py-1.5 rounded-md border border-white/60 shadow-sm font-mono hidden">
      </div>
    </div>

    <!-- ══════════════════════════════════════
         SAĞ — Form + Sonuç paneli (1/3)
    ══════════════════════════════════════ -->
    <div class="lg:flex-1 lg:max-w-sm xl:max-w-md border-t lg:border-t-0 lg:border-l border-slate-200 bg-slate-50/60 flex flex-col overflow-y-auto">

      <!-- Form — kompakt, harita tıklaması ile senkron -->
      <form id="sorgu-form" method="post" action="javascript:void(0)"
        class="bg-white border-b border-slate-100 p-4 space-y-3">

        <!-- Koordinat satırı — harita tıklaması otomatik doldurur -->
        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="block text-xs font-medium text-slate-500 mb-1">Enlem</label>
            <input type="number" id="lat" step="0.0001" placeholder="41.0082" required
              class="w-full px-2.5 py-2 border border-slate-200 rounded-lg text-sm font-mono bg-slate-50 focus:bg-white focus:border-imperial focus:ring-1 focus:ring-imperial/20 focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-500 mb-1">Boylam</label>
            <input type="number" id="lng" step="0.0001" placeholder="28.9784" required
              class="w-full px-2.5 py-2 border border-slate-200 rounded-lg text-sm font-mono bg-slate-50 focus:bg-white focus:border-imperial focus:ring-1 focus:ring-imperial/20 focus:outline-none transition-colors" />
          </div>
        </div>

        <!-- m² + Kategori yan yana -->
        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="block text-xs font-medium text-slate-500 mb-1">Parsel m² <span class="text-slate-400">(opsiyonel)</span></label>
            <input type="number" id="m2" min="1" step="1" placeholder="500"
              class="w-full px-2.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-1 focus:ring-imperial/20 focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-500 mb-1">Kategori</label>
            <select id="kategori"
              class="w-full px-2.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-1 focus:ring-imperial/20 focus:outline-none transition-colors bg-white">
              <option value="arsa">Arsa</option>
              <option value="tarla">Tarla</option>
              <option value="konut">Konut</option>
            </select>
          </div>
        </div>

        <button type="submit" id="submit-btn"
          class="w-full px-4 py-2.5 bg-imperial text-white rounded-lg text-sm font-semibold
                 hover:bg-imperial-700 disabled:opacity-50 disabled:cursor-not-allowed
                 transition-all duration-200 flex items-center justify-center gap-2
                 hover:-translate-y-px hover:shadow-lg hover:shadow-imperial/30
                 active:translate-y-0 active:shadow-none">
          <svg id="submit-icon" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
          </svg>
          <span id="submit-label">Değer Hesapla</span>
        </button>
    </form>

      <!-- Sonuç paneli — skeleton → içerik -->
      <div id="sonuc" class="flex-1 overflow-y-auto">

        <!-- Boş state — ilk yüklemede görünür -->
        <div id="sonuc-bos" class="flex flex-col items-center justify-center h-full py-16 px-6 text-center">
          <div class="w-16 h-16 rounded-2xl bg-imperial/8 flex items-center justify-center mb-4">
            <svg class="h-8 w-8 text-imperial/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20.25v-15m0 0L3.75 9.75M9 5.25l5.25 4.5M15 3.75v15m0 0l5.25-4.5M15 18.75l-5.25-4.5"/>
            </svg>
          </div>
          <p class="text-sm font-medium text-slate-600 mb-1">Haritaya tıkla</p>
          <p class="text-xs text-slate-400">veya koordinat girip "Değer Hesapla"</p>
        </div>

        <!-- Skeleton — yüklenirken görünür -->
        <div id="sonuc-skeleton" class="hidden p-4 space-y-3">
          <!-- Büyük değer kartı skeleton -->
          <div class="rounded-xl border border-slate-200 bg-white p-4 space-y-2">
            <div class="skeleton h-3 w-24 rounded"></div>
            <div class="skeleton h-8 w-40 rounded"></div>
            <div class="skeleton h-3 w-32 rounded"></div>
          </div>
          <!-- 3 değer kutusu skeleton -->
          <div class="grid grid-cols-3 gap-2">
            <div class="rounded-lg bg-white border border-slate-200 p-3 space-y-1.5">
              <div class="skeleton h-2.5 w-12 rounded"></div>
              <div class="skeleton h-5 w-16 rounded"></div>
            </div>
            <div class="rounded-lg bg-white border border-slate-200 p-3 space-y-1.5">
              <div class="skeleton h-2.5 w-12 rounded"></div>
              <div class="skeleton h-5 w-16 rounded"></div>
            </div>
            <div class="rounded-lg bg-white border border-slate-200 p-3 space-y-1.5">
              <div class="skeleton h-2.5 w-12 rounded"></div>
              <div class="skeleton h-5 w-16 rounded"></div>
            </div>
          </div>
          <!-- Meta satırlar -->
          <div class="rounded-xl border border-slate-200 bg-white p-4 space-y-2">
            <div class="skeleton h-2.5 w-48 rounded"></div>
            <div class="skeleton h-2.5 w-36 rounded"></div>
            <div class="skeleton h-2.5 w-40 rounded"></div>
          </div>
        </div>

        <!-- Gerçek sonuç içeriği — JS ile doldurulur -->
        <div id="sonuc-icerik" class="hidden p-4 space-y-3"></div>

      </div>

      <!-- Fizibilite accordion — panelin altı -->
      <details id="fizibilite-panel"
        class="border-t border-slate-200 bg-white">
        <summary class="cursor-pointer px-4 py-3 text-sm font-semibold text-imperial-700 flex items-center justify-between list-none hover:bg-slate-50 transition-colors">
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-imperial/60" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2 4h16v2H2V4zm2 4h12v2H4V8zm-2 4h16v2H2v-2zm2 4h12v2H4v-2z"/>
            </svg>
            İmar Fizibilite
          </span>
          <svg class="h-4 w-4 text-slate-400 fizibilite-chevron transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </summary>
        <div class="px-4 pb-4 pt-3 border-t border-slate-100 space-y-3">
          <p class="text-xs text-slate-500">
            TAKS/KAKS gir → inşa edilebilir alan, daire adedi, kârlılık.
          </p>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs text-slate-500 mb-1">Parsel m²</label>
              <input type="number" id="f-m2" min="1" placeholder="500"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs text-slate-500 mb-1">TAKS</label>
              <input type="number" id="f-taks" step="0.05" placeholder="0.30"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs text-slate-500 mb-1">KAKS</label>
              <input type="number" id="f-kaks" step="0.05" placeholder="1.50"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs text-slate-500 mb-1">Arsa ₺</label>
              <input type="number" id="f-arsa" placeholder="otomatik"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs text-slate-500 mb-1">İnşaat ₺/m²</label>
              <input type="number" id="f-insaat" placeholder="18000"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs text-slate-500 mb-1">Satış ₺/m²</label>
              <input type="number" id="f-satis" placeholder="60000"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
            </div>
          </div>
          <button type="button" id="f-hesapla"
            class="w-full px-3 py-2 bg-imperial text-white rounded-lg text-sm font-semibold hover:bg-imperial-700 transition-colors">
            Hesapla
          </button>
          <div id="f-sonuc" class="hidden"></div>
        </div>
      </details>

    </div><!-- /sağ panel -->
  </div><!-- /split layout -->

  <!-- Extension CTA — alt banner -->
  <div class="border-t border-slate-200 bg-slate-50">
    <div class="container-prose py-4 flex items-center justify-between gap-4 flex-wrap">
      <p class="text-xs text-slate-500">
        TKGM parsel doğrulama, e-Plan imar, deprem/taşkın analizi →
        <strong class="text-slate-700">Chrome eklentisinde</strong>
      </p>
      <a href="https://chromewebstore.google.com/"
        class="btn-primary text-xs py-1.5 px-3 whitespace-nowrap">
        Eklentiyi Yükle →
      </a>
    </div>
  </div>

  <script>
    import { PUBLIC_API_BASE } from "../lib/config";
    import { kullaniciAl, tokenAl } from "../lib/auth";
    import { fizibiliteHesapla, varsayilanInsaatMaliyeti } from "../lib/fizibilite";

    // ── Helpers ──
    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const fmt  = (n: number) => n.toLocaleString("tr-TR");
    const fmtK = (n: number) => Math.abs(n) >= 1_000_000
      ? (n / 1_000_000).toFixed(2) + " M ₺"
      : fmt(Math.round(n)) + " ₺";

    const form        = $<HTMLFormElement>("sorgu-form");
    const latInput    = $<HTMLInputElement>("lat");
    const lngInput    = $<HTMLInputElement>("lng");
    const m2Input     = $<HTMLInputElement>("m2");
    const kategoriInput = $<HTMLSelectElement>("kategori");
    const submitBtn   = $<HTMLButtonElement>("submit-btn");
    const submitLabel = $<HTMLSpanElement>("submit-label");
    const adresInput  = $<HTMLInputElement>("adres");
    const adresBtn    = $<HTMLButtonElement>("adres-btn");
    const adresStatus = $<HTMLDivElement>("adres-status");
    const konumBtn    = $<HTMLButtonElement>("konum-btn");
    const haritaIpucu = $<HTMLDivElement>("harita-ipucu");
    const koordBadge  = $<HTMLDivElement>("koord-badge");
    const sonucBos    = $<HTMLDivElement>("sonuc-bos");
    const sonucSkeleton = $<HTMLDivElement>("sonuc-skeleton");
    const sonucIcerik = $<HTMLDivElement>("sonuc-icerik");

    // ── State ──
    let map: any = null;
    let marker: any = null;
    let currentLat = 0, currentLng = 0;

    // ── MapLibre init ──
    function initHarita() {
      const ml = (window as any).maplibregl;
      if (!ml || !document.getElementById("sorgu-harita")) return;

      map = new ml.Map({
        container: "sorgu-harita",
        style: "https://tiles.openfreemap.org/styles/positron",
        center: [35.2433, 38.9637], // Türkiye merkezi
        zoom: 5.5,
        attributionControl: false,
      });

      map.addControl(new ml.AttributionControl({ compact: true }), "bottom-right");
      map.addControl(new ml.NavigationControl({ showCompass: false }), "bottom-right");

      map.on("click", (e: any) => {
        const { lng, lat } = e.lngLat;
        setKoordinat(lat, lng, true);
      });

      map.on("load", () => {
        // İpucunu gizle
        haritaIpucu?.classList.add("opacity-0");
        setTimeout(() => haritaIpucu?.classList.add("hidden"), 500);
      });
    }

    function setKoordinat(lat: number, lng: number, autoSorgu = false) {
      currentLat = lat;
      currentLng = lng;
      latInput.value = lat.toFixed(5);
      lngInput.value = lng.toFixed(5);

      // Badge güncelle
      if (koordBadge) {
        koordBadge.textContent = `${lat.toFixed(4)}, ${lng.toFixed(4)}`;
        koordBadge.classList.remove("hidden");
      }

      // Marker koy/taşı
      const ml = (window as any).maplibregl;
      if (map && ml) {
        if (marker) {
          marker.setLngLat([lng, lat]);
        } else {
          marker = new ml.Marker({ color: "#1B2A4A" })
            .setLngLat([lng, lat])
            .addTo(map);
        }
        // Zoom in eğer çok uzaksa
        if (map.getZoom() < 11) {
          map.flyTo({ center: [lng, lat], zoom: 13, duration: 1200, essential: true });
        } else {
          map.easeTo({ center: [lng, lat], duration: 400 });
        }
      }

      if (autoSorgu) setTimeout(() => form.requestSubmit(), 300);
    }

    // ── Geocoding ──
    async function geocode(q: string): Promise<{ lat: number; lng: number; display: string } | null> {
      const url = `https://nominatim.openstreetmap.org/search?format=json&limit=1&countrycodes=tr&q=${encodeURIComponent(q)}`;
      const res = await fetch(url, { headers: { Accept: "application/json" } });
      if (!res.ok) return null;
      const arr = await res.json();
      if (!Array.isArray(arr) || arr.length === 0) return null;
      return { lat: parseFloat(arr[0].lat), lng: parseFloat(arr[0].lon), display: arr[0].display_name };
    }

    adresBtn.addEventListener("click", async () => {
      const q = adresInput.value.trim();
      if (!q) return;
      adresBtn.textContent = "…";
      adresStatus.textContent = "Aranıyor…";
      adresStatus.className = "text-xs text-slate-400 mt-1.5 px-1";
      try {
        const r = await geocode(q);
        if (!r) {
          adresStatus.textContent = "Bulunamadı — daha geniş bir yer adı deneyin.";
          adresStatus.className = "text-xs text-amber-700 mt-1.5 px-1";
          return;
        }
        adresStatus.textContent = `✓ ${r.display.slice(0, 70)}`;
        adresStatus.className = "text-xs text-emerald-700 mt-1.5 px-1";
        setKoordinat(r.lat, r.lng, true);
      } catch {
        adresStatus.textContent = "Geocoding hatası — koordinat girin.";
        adresStatus.className = "text-xs text-red-700 mt-1.5 px-1";
      } finally {
        adresBtn.textContent = "Bul";
      }
    });
    adresInput.addEventListener("keydown", (e) => { if (e.key === "Enter") { e.preventDefault(); adresBtn.click(); } });

    // ── Konum ──
    konumBtn?.addEventListener("click", () => {
      if (!navigator.geolocation) return;
      konumBtn.classList.add("animate-pulse");
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          konumBtn.classList.remove("animate-pulse");
          setKoordinat(pos.coords.latitude, pos.coords.longitude, true);
        },
        () => konumBtn.classList.remove("animate-pulse"),
      );
    });

    // ─── Sorgu submit ───
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const lat = parseFloat(latInput.value);
      const lng = parseFloat(lngInput.value);
      const m2 = parseFloat(m2Input.value);
      const kategori = kategoriInput.value;
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
        sonuc.classList.remove("hidden");
        sonuc.innerHTML = '<div class="bg-red-50 text-red-700 p-3 rounded-lg text-sm">Lat/lng gerekli.</div>';
        return;
      }

      sonuc.classList.remove("hidden");
      sonuc.innerHTML = '<div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 text-slate-500 text-sm">Sorgulanıyor…</div>';
      submitBtn.disabled = true;

      try {
        const body: Record<string, unknown> = { lat, lng, kategori };
        if (Number.isFinite(m2) && m2 > 0) body.m2 = m2;

        const res = await fetch(`${PUBLIC_API_BASE}/sorgu`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        submitBtn.disabled = false;

        if (!res.ok) {
          sonuc.innerHTML = `<div class="bg-red-50 text-red-700 p-3 rounded-lg text-sm">❌ ${data.error ?? "Sorgu hatası"}</div>`;
          return;
        }

        // Kaynak rozeti
        const kaynakRozet: Record<string, { label: string; class: string }> = {
          "spatial-radius": { label: "Spatial Emsal", class: "bg-emerald-100 text-emerald-800" },
          "mahalle-istatistik": { label: "Mahalle İstatistiği", class: "bg-blue-100 text-blue-800" },
          "il-fallback": { label: "İl Baseline (yaklaşık)", class: "bg-amber-100 text-amber-800" },
        };
        const kr = kaynakRozet[data.kaynak] ?? { label: data.kaynak, class: "bg-slate-100 text-slate-800" };

        // Güven rozeti
        const guven = data.guven_skoru ?? 0;
        const guvenSinif = guven >= 80 ? "bg-emerald-500" : guven >= 60 ? "bg-blue-500" : guven >= 40 ? "bg-amber-500" : "bg-red-500";

        // TL format
        const fmt = (n: number) => n.toLocaleString("tr-TR");
        const fmtKisa = (n: number) => n >= 1_000_000 ? (n / 1_000_000).toFixed(1) + " M ₺" : n >= 1000 ? (n / 1000).toFixed(0) + " bin ₺" : fmt(n) + " ₺";

        // Toplam TL kartı (parsel m² verildiyse)
        const toplamKart = data.toplam_tl ? `
          <div class="bg-gradient-to-br from-imperial-50 to-imperial-100/50 border-2 border-imperial-200 rounded-2xl p-6 mb-4">
            <div class="text-xs text-imperial-700 uppercase tracking-wider font-semibold">Parsel Toplam Değer</div>
            <div class="text-4xl font-bold text-imperial-800 mt-1">${fmtKisa(data.toplam_tl.orta)}</div>
            <div class="text-sm text-imperial-700 mt-2">
              Aralık: <strong>${fmtKisa(data.toplam_tl.alt)}</strong> — <strong>${fmtKisa(data.toplam_tl.ust)}</strong>
            </div>
            <div class="text-xs text-imperial-600 mt-1">${m2 || ""} m² × ortalama ${fmt(data.medyan_tlm2)} ₺/m²</div>
          </div>
        ` : "";

        sonuc.innerHTML = `
          ${toplamKart}
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
              <h2 class="font-display text-xl font-bold text-imperial-700">Birim Fiyat Analizi</h2>
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-xs px-2.5 py-1 rounded-full ${kr.class} font-medium">${kr.label}</span>
                <span class="text-xs px-2.5 py-1 rounded-full bg-slate-100 text-slate-700 font-medium inline-flex items-center gap-1.5">
                  <span class="inline-block w-2 h-2 rounded-full ${guvenSinif}"></span>
                  Güven %${guven}
                </span>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-3 mb-4">
              <div class="bg-slate-50 p-3 rounded-lg">
                <div class="text-xs text-slate-500">Alt sınır</div>
                <div class="text-lg font-bold text-slate-700">${fmt(data.alt_tlm2 ?? 0)} ₺</div>
                <div class="text-xs text-slate-400">/m²</div>
              </div>
              <div class="bg-imperial-50 p-3 rounded-lg ring-2 ring-imperial-200">
                <div class="text-xs text-imperial-700 font-medium">Medyan</div>
                <div class="text-xl font-bold text-imperial-800">${fmt(data.medyan_tlm2 ?? 0)} ₺</div>
                <div class="text-xs text-imperial-600">/m²</div>
              </div>
              <div class="bg-slate-50 p-3 rounded-lg">
                <div class="text-xs text-slate-500">Üst sınır</div>
                <div class="text-lg font-bold text-slate-700">${fmt(data.ust_tlm2 ?? 0)} ₺</div>
                <div class="text-xs text-slate-400">/m²</div>
              </div>
            </div>

            <div class="text-sm text-slate-600 space-y-1.5">
              <div><span class="text-slate-400">📍</span> Yarıçap: <strong>${data.radius_km} km</strong></div>
              <div><span class="text-slate-400">🎯</span> Emsal: <strong>${data.emsal_adet}</strong> ilan
                (0-1km: ${data.halka_dagilimi.r0_1km}, 1-3km: ${data.halka_dagilimi.r1_3km}, 3-5km: ${data.halka_dagilimi.r3_5km})</div>
              <div><span class="text-slate-400">📊</span> Bu saat kalan kotanız: <strong>${data.kalan_kota}/20</strong></div>
            </div>

            <div class="mt-5 pt-4 border-t border-slate-100 flex gap-2 flex-wrap">
              <a href="/rapor?lat=${lat}&lng=${lng}&kategori=${kategori}${m2 ? `&m2=${m2}` : ""}"
                 class="px-4 py-2 bg-imperial text-white rounded-lg text-sm font-medium hover:bg-imperial-700">
                📄 PDF Rapor
              </a>
              <button id="musteri-ekle-btn" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 rounded-lg text-sm font-medium">
                👤 Müşterime Ekle
              </button>
              <button id="link-kopyala-btn" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 rounded-lg text-sm font-medium">
                🔗 Linki Paylaş
              </button>
            </div>
          </div>

          ${(data.emsaller && data.emsaller.length > 0) ? `
            <div class="mt-4 bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
              <h2 class="font-display text-xl font-bold text-imperial-700 mb-3">Karşılaştırmalı Emsaller (CMA)</h2>
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="text-left text-slate-500 border-b border-slate-200">
                      <th class="py-2 pr-3 font-medium">Mahalle</th>
                      <th class="py-2 px-3 font-medium text-right">₺/m²</th>
                      <th class="py-2 px-3 font-medium text-right">m²</th>
                      <th class="py-2 px-3 font-medium text-right">Mesafe</th>
                      <th class="py-2 pl-3 font-medium text-right">Yaş</th>
                    </tr>
                  </thead>
                  <tbody>
                    ${data.emsaller.map((e: any) => `
                      <tr class="border-b border-slate-50">
                        <td class="py-2 pr-3 capitalize">${e.mahalle ?? "—"}</td>
                        <td class="py-2 px-3 text-right font-semibold">${fmt(e.fiyat_per_m2)}</td>
                        <td class="py-2 px-3 text-right text-slate-500">${e.m2 ? fmt(e.m2) : "—"}</td>
                        <td class="py-2 px-3 text-right text-slate-500">${e.mesafe_m >= 1000 ? (e.mesafe_m/1000).toFixed(1)+" km" : e.mesafe_m+" m"}</td>
                        <td class="py-2 pl-3 text-right text-slate-400">${e.yas_gun}g</td>
                      </tr>
                    `).join("")}
                  </tbody>
                </table>
              </div>
            </div>
          ` : ""}

          <div id="trend-bolum" class="mt-4"></div>

          ${data.kaynak === "il-fallback" ? `
            <div class="mt-4 bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-900">
              <strong>⚠ Sınırlı veri:</strong> Bu bölgede henüz yeterli ilan emsali yok — il-bazlı kaba bir tahmin gösteriliyor.
              Daha doğru sonuç için Chrome eklentisi ile parselin tam analizini yapın.
            </div>
          ` : ""}
        `;

        // ── Fizibilite panelini otomatik doldur ──
        if (m2 && Number.isFinite(m2)) (document.getElementById("f-m2") as HTMLInputElement).value = String(m2);
        if (data.toplam_tl?.orta) (document.getElementById("f-arsa") as HTMLInputElement).value = String(data.toplam_tl.orta);
        else if (data.medyan_tlm2 && m2) (document.getElementById("f-arsa") as HTMLInputElement).value = String(Math.round(data.medyan_tlm2 * m2));
        if (data.medyan_tlm2) (document.getElementById("f-satis") as HTMLInputElement).value = String(Math.round(data.medyan_tlm2 * 2.4)); // arsa→bitmiş kaba çarpan

        // ── Trend grafiği (paralel fetch) ──
        fetch(`${PUBLIC_API_BASE}/sorgu/trend?lat=${lat}&lng=${lng}&kategori=${kategori}&ay=12`)
          .then((r) => r.json())
          .then((t) => {
            const el = document.getElementById("trend-bolum");
            if (!el || !t.ok || !t.noktalar || t.noktalar.length < 2) return;
            el.innerHTML = trendKartHTML(t, fmt);
          })
          .catch(() => {});

        // CTA handler'ları
        document.getElementById("link-kopyala-btn")?.addEventListener("click", () => {
          const url = `${location.origin}/sorgu?lat=${lat}&lng=${lng}&kategori=${kategori}${m2 ? `&m2=${m2}` : ""}`;
          navigator.clipboard.writeText(url);
          alert("Link panoya kopyalandı.");
        });

        document.getElementById("musteri-ekle-btn")?.addEventListener("click", async () => {
          const token = tokenAl();
          if (!token) { location.href = "/giris?dön=" + encodeURIComponent(location.pathname + location.search); return; }
          const u = kullaniciAl();
          if (u && u.tier !== "kurumsal" && u.tier !== "pro_plus") {
            alert("CRM Lite için Pro+ veya Kurumsal abonelik gerekli.");
            return;
          }
          location.href = `/musteriler`;
        });

      } catch (err) {
        submitBtn.disabled = false;
        sonuc.innerHTML = `<div class="bg-red-50 text-red-700 p-3 rounded-lg text-sm">❌ Bağlantı hatası: ${err}</div>`;
      }
    });

    // ── Trend kart HTML (mini SVG çizgi grafik) ──
    function trendKartHTML(t: any, fmt: (n: number) => string): string {
      const noktalar = t.noktalar as Array<{ ay: string; medyan: number; adet: number }>;
      const vals = noktalar.map((n) => n.medyan);
      const min = Math.min(...vals), max = Math.max(...vals);
      const range = max - min || 1;
      const W = 600, H = 120, pad = 10;
      const stepX = (W - 2 * pad) / (noktalar.length - 1);
      const points = noktalar.map((n, i) => {
        const x = pad + i * stepX;
        const y = H - pad - ((n.medyan - min) / range) * (H - 2 * pad);
        return `${x.toFixed(1)},${y.toFixed(1)}`;
      }).join(" ");
      const degisim = t.degisim_yuzde;
      const yon = degisim == null ? "" : degisim > 0 ? `<span class="text-emerald-600">▲ %${degisim}</span>` : degisim < 0 ? `<span class="text-red-600">▼ %${Math.abs(degisim)}</span>` : `<span class="text-slate-500">→ %0</span>`;
      return `
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
          <div class="flex items-center justify-between mb-3">
            <h2 class="font-display text-xl font-bold text-imperial-700">Fiyat Trendi (12 ay)</h2>
            <div class="text-sm font-semibold">${yon}</div>
          </div>
          <svg viewBox="0 0 ${W} ${H}" class="w-full h-32" preserveAspectRatio="none">
            <polyline points="${points}" fill="none" stroke="#1B2A4A" stroke-width="2" />
            ${noktalar.map((n, i) => {
              const x = pad + i * stepX;
              const y = H - pad - ((n.medyan - min) / range) * (H - 2 * pad);
              return `<circle cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" r="3" fill="#C9A875" />`;
            }).join("")}
          </svg>
          <div class="flex justify-between text-xs text-slate-400 mt-1">
            <span>${noktalar[0].ay} · ${fmt(noktalar[0].medyan)} ₺</span>
            <span>${noktalar[noktalar.length-1].ay} · ${fmt(noktalar[noktalar.length-1].medyan)} ₺</span>
          </div>
        </div>`;
    }

    // ── İmar Fizibilite hesapla ──
    document.getElementById("f-hesapla")?.addEventListener("click", () => {
      const num = (id: string) => parseFloat((document.getElementById(id) as HTMLInputElement).value);
      const parselM2 = num("f-m2");
      const taks = num("f-taks");
      const kaks = num("f-kaks");
      const arsaMaliyeti = num("f-arsa");
      const insaatBirimMaliyet = Number.isFinite(num("f-insaat")) ? num("f-insaat") : varsayilanInsaatMaliyeti();
      const satisBirimFiyat = num("f-satis");
      const ortalamaDaireM2 = Number.isFinite(num("f-daire")) ? num("f-daire") : 120;
      const fsonuc = document.getElementById("f-sonuc") as HTMLDivElement;

      if (![parselM2, taks, kaks, arsaMaliyeti, satisBirimFiyat].every(Number.isFinite)) {
        fsonuc.classList.remove("hidden");
        fsonuc.innerHTML = '<div class="bg-amber-50 text-amber-800 p-3 rounded-lg text-sm">Parsel m², TAKS, KAKS, arsa değeri ve satış fiyatı zorunlu.</div>';
        return;
      }

      const r = fizibiliteHesapla({ parselM2, taks, kaks, arsaMaliyeti, insaatBirimMaliyet, satisBirimFiyat, ortalamaDaireM2 });
      const fmt = (n: number) => n.toLocaleString("tr-TR");
      const fmtKisa = (n: number) => Math.abs(n) >= 1_000_000 ? (n / 1_000_000).toFixed(2) + " M ₺" : fmt(Math.round(n)) + " ₺";
      const karRenk = r.karlilikYuzde >= 35 ? "text-emerald-700 bg-emerald-50 border-emerald-200" : r.karlilikYuzde >= 20 ? "text-blue-700 bg-blue-50 border-blue-200" : r.karlilikYuzde >= 0 ? "text-amber-700 bg-amber-50 border-amber-200" : "text-red-700 bg-red-50 border-red-200";

      fsonuc.classList.remove("hidden");
      fsonuc.innerHTML = `
        <div class="border ${karRenk} rounded-xl p-4 mb-3">
          <div class="flex items-baseline justify-between flex-wrap gap-2">
            <div>
              <div class="text-xs uppercase tracking-wider font-semibold opacity-70">Brüt Kâr</div>
              <div class="text-3xl font-bold">${fmtKisa(r.brutKar)}</div>
            </div>
            <div class="text-right">
              <div class="text-xs uppercase tracking-wider font-semibold opacity-70">Kârlılık</div>
              <div class="text-3xl font-bold">%${r.karlilikYuzde}</div>
            </div>
          </div>
          <div class="text-sm mt-2 font-medium">${r.yorum}</div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-sm">
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Taban Alanı</div><div class="font-semibold">${fmt(r.tabanAlani)} m²</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Toplam İnşaat</div><div class="font-semibold">${fmt(r.toplamInsaatAlani)} m²</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Kat Adedi</div><div class="font-semibold">~${r.tahminiKatAdedi}</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Daire Adedi</div><div class="font-semibold">~${r.daireAdedi}</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Satılabilir Alan</div><div class="font-semibold">${fmt(r.satilabilirAlan)} m²</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">İnşaat Maliyeti</div><div class="font-semibold">${fmtKisa(r.insaatMaliyetiToplam)}</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Satış Geliri</div><div class="font-semibold">${fmtKisa(r.satisGeliriToplam)}</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Başabaş ₺/m²</div><div class="font-semibold">${fmt(r.basabasSatisFiyati)}</div></div>
        </div>
        <p class="text-xs text-slate-400 mt-2">Arsa payı toplam maliyetin %${r.arsaPayiYuzde}'i. Hesap yaklaşık; gerçek proje maliyeti, vergiler ve finansman dahil değildir.</p>
      `;
    });

    // URL param'lardan otomatik doldur (rapor → sorgu round-trip için)
    const params = new URLSearchParams(location.search);
    if (params.get("lat")) latInput.value = params.get("lat")!;
    if (params.get("lng")) lngInput.value = params.get("lng")!;
    if (params.get("m2")) m2Input.value = params.get("m2")!;
    if (params.get("kategori")) kategoriInput.value = params.get("kategori")!;
    if (params.get("lat") && params.get("lng")) {
      // Otomatik sorgu tetikle
      setTimeout(() => form.requestSubmit(), 100);
    }
  </script>
</Base>
