          <div class="mt-3 rounded-xl border border-imperial/20 bg-imperial/5 p-3 text-xs">
            <div class="font-semibold text-imperial-700 mb-1">Resmi ada/parsel + e-Plan imar</div>
            <p class="text-slate-600 mb-2 leading-snug">Sitede TKGM sorgu yok. KAKS/TAKS ve parsel doğrulama Chrome eklentisinde.</p>
            <a href="${CHROME_STORE_URL}" class="inline-flex items-center gap-1 font-semibold text-imperial-700 hover:underline">
              Eklentiyi aç →
            </a>
            · <a href="/arsa-talep" class="text-slate-600 hover:underline">Arsa talebi bırak</a>
          </div>
        `;

        sonSorguVar = true;

        // Fizibilite panelini doldur
        if (Number.isFinite(m2) && m2 > 0) (document.getElementById("f-m2") as HTMLInputElement).value = String(m2);
        if (Number.isFinite(emsal) && emsal > 0) (document.getElementById("f-kaks") as HTMLInputElement).value = String(emsal);
        if (Number.isFinite(taks) && taks > 0) (document.getElementById("f-taks") as HTMLInputElement).value = String(taks);
        if (data.toplam_tl?.orta) (document.getElementById("f-arsa") as HTMLInputElement).value = String(data.toplam_tl.orta);
        else if (data.medyan_tlm2 && m2) (document.getElementById("f-arsa") as HTMLInputElement).value = String(Math.round(data.medyan_tlm2 * m2));
        if (data.medyan_tlm2) (document.getElementById("f-satis") as HTMLInputElement).value = String(Math.round(data.medyan_tlm2 * 2.4));

        if (Number.isFinite(lat2) && Number.isFinite(lng2)) {
          fetch(`${PUBLIC_API_BASE}/sorgu/trend?lat=${lat2}&lng=${lng2}&kategori=${kategori}&ay=12`)
            .then((r) => r.json())
            .then((t) => {
              const el = document.getElementById("trend-bolum");
              if (!el || !t.ok || !t.noktalar || t.noktalar.length < 2) return;
              el.innerHTML = trendKartHTML(t, fmt);
              const deg = typeof t.degisim_yuzde === "number" ? t.degisim_yuzde : null;
              if (deg != null) {
                const kart = document.getElementById("yatirim-skoru-kart");
                if (kart) {
                  const wrap = document.createElement("div");
                  wrap.innerHTML = yatirimSkoruKartHTML(skorGirdiden(data, deg));
                  kart.replaceWith(wrap.firstElementChild!);
                }
              }
            })
            .catch(() => {});

          // Uydu gelişim trendi (Wayback → API proxy → client pixel analizi)
          void yuklenGelisimTrendi(lat2, lng2);
        }

      } catch (err) {
        submitBtn.disabled = false;
        sonucSkeleton.classList.add("hidden");
        sonucIcerik.classList.remove("hidden");
        sonucIcerik.innerHTML = `<div class="bg-red-50 text-red-700 p-3 rounded-lg text-sm">❌ Bağlantı hatası: ${err}</div>`;
      }
    });

    // ── Uydu gelişim trendi (Esri Wayback via proxy) ──
    async function yuklenGelisimTrendi(lat: number, lng: number): Promise<void> {
      const el = document.getElementById("gelisim-trendi-bolum");
      if (!el) return;
      el.innerHTML = `
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-4">
          <div class="text-xs text-slate-500">Uydu kareleri analiz ediliyor…</div>
        </div>`;
      try {
        const bbox = bboxFromMerkez(lat, lng, 180);
        const sonuc = await gelisimTrendiAnaliz(bbox, async (_url, releaseId) => {
          const q = new URLSearchParams({
            minLng: String(bbox.minLng),
            minLat: String(bbox.minLat),
            maxLng: String(bbox.maxLng),
            maxLat: String(bbox.maxLat),
            releaseId: String(releaseId),
            w: "160",
            h: "120",
          });
          const res = await fetch(`${PUBLIC_API_BASE}/proxy/wayback?${q}`);
          if (!res.ok) throw new Error(`Uydu ${res.status}`);
          return res.blob();
        });
        if (document.getElementById("gelisim-trendi-bolum") !== el) return;
        el.innerHTML = gelisimTrendiKartHTML(sonuc);
      } catch {
        if (document.getElementById("gelisim-trendi-bolum") === el) {
          el.innerHTML = "";
        }
      }
    }

    function gelisimTrendiKartHTML(g: GelisimTrendiSonuc): string {
      const renk = gelisimSkorRenk(g.skor);
      const skorStr = g.skor > 0 ? `+${g.skor}` : String(g.skor);
      const bars = g.yillar
        .map((y) => {
          const px = Math.max(4, Math.round(y.builtUp * 28));
          return `<div class="flex-1 flex flex-col items-center gap-0.5 justify-end">
            <div class="w-full rounded-sm bg-sky-500/80" style="height:${px}px" title="${y.yil}: yapay yüzey ~${(y.builtUp * 100).toFixed(0)}%"></div>
            <span class="text-[8px] text-slate-400 tabular-nums">${y.yil}</span>
          </div>`;
        })
        .join("");
      return `
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-4">
          <div class="flex items-center justify-between mb-3 gap-2">
            <h2 class="font-display text-base font-bold text-imperial-700">Uydu gelişim trendi</h2>
            <span class="text-[10px] text-slate-400">2014–2024</span>
          </div>
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-14 w-14 flex-shrink-0 flex-col items-center justify-center rounded-xl text-white" style="background:${renk}">
              <span class="text-sm font-bold tabular-nums leading-none">${skorStr}</span>
            </div>
            <div class="min-w-0">
              <div class="text-sm font-semibold text-slate-800">${g.etiket}</div>
              <p class="mt-0.5 text-xs leading-relaxed text-slate-500">${g.aciklama}</p>
            </div>
          </div>
          <div class="flex items-end gap-1">${bars}</div>
          <p class="mt-2 text-[10px] text-slate-400 italic">Kaynak: Esri Wayback · görsel proxy (yatırım tavsiyesi değildir) · güven: ${g.guven}</p>
        </div>`;
    }

    // ── Trend kart HTML (mini SVG çizgi grafik) ──
    function trendKartHTML(t: any, fmt: (n: number) => string): string {
      const noktalar = t.noktalar as Array<{ ay: string; medyan: number; adet: number }>;
      const vals = noktalar.map((n) => n.medyan);
      const min = Math.min(...vals), max = Math.max(...vals);
      const range = max - min || 1;
      const W = 600, H = 120, pad = 10;
      const stepX = (W - 2 * pad) / (noktalar.length - 1);
      const points = noktalar.map((n, i) => {
        const x = pad + i * stepX;
        const y = H - pad - ((n.medyan - min) / range) * (H - 2 * pad);
        return `${x.toFixed(1)},${y.toFixed(1)}`;
      }).join(" ");
      const degisim = t.degisim_yuzde;
      const yon = degisim == null ? "" : degisim > 0 ? `<span class="text-emerald-600">▲ %${degisim}</span>` : degisim < 0 ? `<span class="text-red-600">▼ %${Math.abs(degisim)}</span>` : `<span class="text-slate-500">→ %0</span>`;
      return `
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
          <div class="flex items-center justify-between mb-3">
            <h2 class="font-display text-xl font-bold text-imperial-700">Fiyat Trendi (12 ay)</h2>
            <div class="text-sm font-semibold">${yon}</div>
          </div>
          <svg viewBox="0 0 ${W} ${H}" class="w-full h-32" preserveAspectRatio="none">
            <polyline points="${points}" fill="none" stroke="#1B2A4A" stroke-width="2" />
            ${noktalar.map((n, i) => {
              const x = pad + i * stepX;
              const y = H - pad - ((n.medyan - min) / range) * (H - 2 * pad);
              return `<circle cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" r="3" fill="#C9A875" />`;
            }).join("")}
          </svg>
          <div class="flex justify-between text-xs text-slate-400 mt-1">
            <span>${noktalar[0].ay} · ${fmt(noktalar[0].medyan)} ₺</span>
            <span>${noktalar[noktalar.length-1].ay} · ${fmt(noktalar[noktalar.length-1].medyan)} ₺</span>
          </div>
        </div>`;
    }

    // ── İmar Fizibilite hesapla ──
    document.getElementById("f-hesapla")?.addEventListener("click", () => {
      const num = (id: string) => parseFloat((document.getElementById(id) as HTMLInputElement).value);
      const parselM2 = num("f-m2");
      const taks = num("f-taks");
      const kaks = num("f-kaks");
      const arsaMaliyeti = num("f-arsa");
      const insaatBirimMaliyet = Number.isFinite(num("f-insaat")) ? num("f-insaat") : varsayilanInsaatMaliyeti();
      const satisBirimFiyat = num("f-satis");
      const ortalamaDaireM2 = Number.isFinite(num("f-daire")) ? num("f-daire") : 120;
      const fsonuc = document.getElementById("f-sonuc") as HTMLDivElement;

      if (![parselM2, taks, kaks, arsaMaliyeti, satisBirimFiyat].every(Number.isFinite)) {
        fsonuc.classList.remove("hidden");
        fsonuc.innerHTML = '<div class="bg-amber-50 text-amber-800 p-3 rounded-lg text-sm">Parsel m², TAKS, KAKS, arsa değeri ve satış fiyatı zorunlu.</div>';
        return;
      }

      const r = fizibiliteHesapla({ parselM2, taks, kaks, arsaMaliyeti, insaatBirimMaliyet, satisBirimFiyat, ortalamaDaireM2 });
      const fmt = (n: number) => n.toLocaleString("tr-TR");
      const fmtKisa = (n: number) => Math.abs(n) >= 1_000_000 ? (n / 1_000_000).toFixed(2) + " M ₺" : fmt(Math.round(n)) + " ₺";
      const karRenk = r.karlilikYuzde >= 35 ? "text-emerald-700 bg-emerald-50 border-emerald-200" : r.karlilikYuzde >= 20 ? "text-blue-700 bg-blue-50 border-blue-200" : r.karlilikYuzde >= 0 ? "text-amber-700 bg-amber-50 border-amber-200" : "text-red-700 bg-red-50 border-red-200";

      fsonuc.classList.remove("hidden");
      fsonuc.innerHTML = `
        <div class="border ${karRenk} rounded-xl p-4 mb-3">
          <div class="flex items-baseline justify-between flex-wrap gap-2">
            <div>
              <div class="text-xs uppercase tracking-wider font-semibold opacity-70">Brüt Kâr</div>
              <div class="text-3xl font-bold">${fmtKisa(r.brutKar)}</div>
            </div>
            <div class="text-right">
              <div class="text-xs uppercase tracking-wider font-semibold opacity-70">Kârlılık</div>
              <div class="text-3xl font-bold">%${r.karlilikYuzde}</div>
            </div>
          </div>
          <div class="text-sm mt-2 font-medium">${r.yorum}</div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-sm">
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Taban Alanı</div><div class="font-semibold">${fmt(r.tabanAlani)} m²</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Toplam İnşaat</div><div class="font-semibold">${fmt(r.toplamInsaatAlani)} m²</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Kat Adedi</div><div class="font-semibold">~${r.tahminiKatAdedi}</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Daire Adedi</div><div class="font-semibold">~${r.daireAdedi}</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Satılabilir Alan</div><div class="font-semibold">${fmt(r.satilabilirAlan)} m²</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">İnşaat Maliyeti</div><div class="font-semibold">${fmtKisa(r.insaatMaliyetiToplam)}</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Satış Geliri</div><div class="font-semibold">${fmtKisa(r.satisGeliriToplam)}</div></div>
          <div class="bg-slate-50 p-2.5 rounded-lg"><div class="text-xs text-slate-500">Başabaş ₺/m²</div><div class="font-semibold">${fmt(r.basabasSatisFiyati)}</div></div>
        </div>
        <p class="text-xs text-slate-400 mt-2">Arsa payı toplam maliyetin %${r.arsaPayiYuzde}'i. Hesap yaklaşık; gerçek proje maliyeti, vergiler ve finansman dahil değildir.</p>
      `;
    });

    function fizGirdiOku(): {
      parselM2: number; taks: number; kaks: number; arsaMaliyeti: number;
      insaatBirimMaliyet: number; satisBirimFiyat: number;
    } | null {
      const num = (id: string) => parseFloat((document.getElementById(id) as HTMLInputElement)?.value);
      const parselM2 = num("f-m2") || parseFloat(m2Input.value);
      const taks = num("f-taks") || parseFloat(taksInput.value);
      const kaks = num("f-kaks") || parseFloat(emsalInput.value);
      const arsaMaliyeti = num("f-arsa");
      const insaatBirimMaliyet = Number.isFinite(num("f-insaat")) ? num("f-insaat") : varsayilanInsaatMaliyeti();
      const satisBirimFiyat = num("f-satis");
      if (![parselM2, taks, kaks, arsaMaliyeti, satisBirimFiyat].every(Number.isFinite)) return null;
      return { parselM2, taks, kaks, arsaMaliyeti, insaatBirimMaliyet, satisBirimFiyat };
    }

    document.getElementById("tf-hesapla")?.addEventListener("click", () => {
      const g = fizGirdiOku();
      const el = document.getElementById("tf-sonuc") as HTMLDivElement;
      if (!g) {
        el.classList.remove("hidden");
        el.innerHTML = '<div class="bg-amber-50 text-amber-800 p-3 rounded-lg text-xs">Önce İmar Fizibilite alanlarını doldurun (veya değer sorgusu çalıştırın).</div>';
        return;
      }
      const hedef = parseFloat((document.getElementById("tf-hedef") as HTMLInputElement).value) || 25;
      const hedefDaire = parseFloat((document.getElementById("tf-daire") as HTMLInputElement).value);
      const r = tersFizibiliteHesapla({
        ...g,
        mevcutKaks: g.kaks,
        hedefKarlilikYuzde: hedef,
        hedefDaireAdedi: Number.isFinite(hedefDaire) ? hedefDaire : undefined,
      });
      el.classList.remove("hidden");
      el.innerHTML = `
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-3 space-y-1.5 text-xs">
          ${r.minEmsal != null ? `<div>Min emsal (hedef kâr): <strong class="text-imperial-700">${r.minEmsal}</strong></div>` : ""}
          ${r.maxArsaMaliyeti != null ? `<div>Max arsa bedeli: <strong>${fmtK(r.maxArsaMaliyeti)}</strong></div>` : ""}
          ${r.minEmsalDaireIcin != null ? `<div>Min emsal (daire hedefi): <strong>${r.minEmsalDaireIcin}</strong></div>` : ""}
          <p class="text-slate-600 pt-1">${r.yorum}</p>
        </div>`;
    });

    document.getElementById("kk-hesapla")?.addEventListener("click", () => {
      const g = fizGirdiOku();
      const el = document.getElementById("kk-sonuc") as HTMLDivElement;
      if (!g) {
        el.classList.remove("hidden");
        el.innerHTML = '<div class="bg-amber-50 text-amber-800 p-3 rounded-lg text-xs">Önce fizibilite / sorgu alanlarını doldurun.</div>';
        return;
      }
      const pay = parseFloat((document.getElementById("kk-pay") as HTMLInputElement).value) || 50;
      const daireM2 = parseFloat((document.getElementById("kk-daire-m2") as HTMLInputElement).value) || 120;
      const r = katKarsiligiHesapla({
        parselM2: g.parselM2,
        kaks: g.kaks,
        muteahhitPayYuzde: pay,
        insaatBirimMaliyet: g.insaatBirimMaliyet,
        satisBirimFiyat: g.satisBirimFiyat,
        ortalamaDaireM2: daireM2,
        arsaDegeri: g.arsaMaliyeti,
      });
      el.classList.remove("hidden");
      el.innerHTML = `
        <div class="grid grid-cols-2 gap-2 text-xs mb-2">
          <div class="rounded-lg bg-emerald-50 border border-emerald-100 p-2">
            <div class="text-emerald-700 font-semibold">Malik %${r.malikPayYuzde}</div>
            <div>${fmt(r.malikAlanM2)} m² · ~${r.malikDaire} daire</div>
            <div class="text-slate-500 mt-0.5">≈ ${fmtK(r.malikSatisDegeri)}</div>
          </div>
          <div class="rounded-lg bg-slate-50 border border-slate-200 p-2">
            <div class="text-slate-700 font-semibold">Müteahhit %${r.muteahhitPayYuzde}</div>
            <div>${fmt(r.muteahhitAlanM2)} m² · ~${r.muteahhitDaire} daire</div>
            <div class="text-slate-500 mt-0.5">Kâr ≈ ${fmtK(r.muteahhitBrutKar)}</div>
          </div>
        </div>
        <p class="text-[11px] text-slate-500">${r.yorum}</p>`;
    });

    document.getElementById("senaryo-hesapla")?.addEventListener("click", () => {
      const g = fizGirdiOku();
      const el = document.getElementById("senaryo-sonuc") as HTMLDivElement;
      const num = (id: string) => parseFloat((document.getElementById(id) as HTMLInputElement).value);
      const parselM2 = g?.parselM2 || parseFloat(m2Input.value) || 500;
      const arsaMaliyeti = g?.arsaMaliyeti
        || (Number.isFinite(parseFloat((document.getElementById("f-arsa") as HTMLInputElement)?.value))
          ? parseFloat((document.getElementById("f-arsa") as HTMLInputElement).value)
          : parselM2 * 15000);
      const insaat = g?.insaatBirimMaliyet ?? varsayilanInsaatMaliyeti();
      const satis = g?.satisBirimFiyat
        || parseFloat((document.getElementById("f-satis") as HTMLInputElement)?.value)
        || 60000;
      const a = {
        parselM2, taks: num("sa-taks"), kaks: num("sa-kaks"),
        arsaMaliyeti, insaatBirimMaliyet: insaat, satisBirimFiyat: satis,
      };
      const b = {
        parselM2, taks: num("sb-taks"), kaks: num("sb-kaks"),
        arsaMaliyeti, insaatBirimMaliyet: insaat, satisBirimFiyat: satis,
      };
      if (![a.taks, a.kaks, b.taks, b.kaks].every(Number.isFinite)) {
        el.classList.remove("hidden");
        el.innerHTML = '<div class="bg-amber-50 text-amber-800 p-3 rounded-lg text-xs">A ve B emsal/TAKS girin.</div>';
        return;
      }
      const r = senaryoKarsilastir(a, b);
      const kazananMetin = r.kazanan === "berabere" ? "Berabere" : `Senaryo ${r.kazanan} önde`;
      el.classList.remove("hidden");
      el.innerHTML = `
        <div class="text-xs font-semibold text-imperial-700 mb-2">${kazananMetin}</div>
        <table class="w-full text-xs">
          <thead><tr class="text-slate-500 border-b"><th class="py-1 text-left"></th><th class="py-1 text-right">A</th><th class="py-1 text-right">B</th></tr></thead>
          <tbody>
            <tr class="border-b border-slate-50"><td class="py-1">Kârlılık</td><td class="text-right font-semibold">%${r.a.karlilikYuzde}</td><td class="text-right font-semibold">%${r.b.karlilikYuzde}</td></tr>
            <tr class="border-b border-slate-50"><td class="py-1">Brüt kâr</td><td class="text-right">${fmtK(r.a.brutKar)}</td><td class="text-right">${fmtK(r.b.brutKar)}</td></tr>
            <tr class="border-b border-slate-50"><td class="py-1">Daire</td><td class="text-right">~${r.a.daireAdedi}</td><td class="text-right">~${r.b.daireAdedi}</td></tr>
            <tr><td class="py-1">İnşaat m²</td><td class="text-right">${fmt(r.a.toplamInsaatAlani)}</td><td class="text-right">${fmt(r.b.toplamInsaatAlani)}</td></tr>
          </tbody>
        </table>
        <p class="text-[11px] text-slate-400 mt-2">Δ kârlılık: ${r.deltaKarlilik > 0 ? "+" : ""}${r.deltaKarlilik} puan · Δ daire: ${r.deltaDaire > 0 ? "+" : ""}${r.deltaDaire}</p>`;
    });

    // URL param'lardan otomatik doldur (rapor → sorgu round-trip için)
    const params = new URLSearchParams(location.search);
    if (params.get("lat")) latInput.value = params.get("lat")!;
    if (params.get("lng")) lngInput.value = params.get("lng")!;
    if (params.get("m2")) m2Input.value = params.get("m2")!;
    if (params.get("kategori")) kategoriInput.value = params.get("kategori")!;
    if (params.get("il")) {
      const ilVal = params.get("il")!;
      ilCombo.setValue(ilVal);
      void ilceYukle(ilVal).then(() => {
        if (params.get("ilce")) {
          const ilceVal = params.get("ilce")!;
          ilceCombo.setValue(ilceVal);
        }
      });
    }
    if (params.get("mahalle")) {
      const mVal = params.get("mahalle")!;
      mahalleHidden.value = mVal;
      mahalleInput2.value = mVal;
    }
    if (params.get("emsal")) {
      emsalInput.value = params.get("emsal")!;
      syncSliderFromInput(emsalInput, emsalSlider);
    }
    if (params.get("taks")) {
      taksInput.value = params.get("taks")!;
      syncSliderFromInput(taksInput, taksSlider);
    }
    if (params.get("imar_tipi")) imarTipiSelect.value = params.get("imar_tipi")!;
    syncSliderFromInput(emsalInput, emsalSlider);
    syncSliderFromInput(taksInput, taksSlider);

    // MapLibre CDN + init (harita boş kalmasın)
    function loadMapLibreThenInit() {
      if ((window as any).maplibregl) {
        initHarita();
        return;
      }
      const s = document.createElement("script");
      s.src = "https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js";
      s.onload = () => initHarita();
      document.head.appendChild(s);
    }
    loadMapLibreThenInit();

    if (params.get("lat") && params.get("lng")) {
      setTimeout(() => {
        setKoordinat(parseFloat(params.get("lat")!), parseFloat(params.get("lng")!), false);
        form.requestSubmit();
      }, 400);
    } else if (params.get("il") && (params.get("ilce") || params.get("mahalle"))) {
      setTimeout(() => form.requestSubmit(), 600);
    }
  </script>
</Base>
