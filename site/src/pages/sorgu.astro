      <!-- Kat karşılığı -->
      <details id="kat-panel" class="border-t border-slate-200 bg-white">
        <summary class="cursor-pointer px-4 py-3 text-sm font-semibold text-imperial-700 flex items-center justify-between list-none hover:bg-slate-50 transition-colors">
          <span>Kat Karşılığı</span>
          <span class="text-slate-400 text-xs font-normal">malik / müteahhit</span>
        </summary>
