                <div class="text-[10px] text-slate-400">₺/m²</div>
              </div>
              <div class="bg-imperial-50 p-2.5 rounded-lg ring-2 ring-imperial-200">
                <div class="text-xs text-imperial-700 font-medium">Medyan</div>
                <div class="text-lg font-bold text-imperial-800">${fmt(data.medyan_tlm2 ?? 0)}</div>
