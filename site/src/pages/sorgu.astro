            <div class="bg-white border border-slate-200 rounded-lg p-2"><div class="text-slate-400">İnşaat</div><div class="font-semibold">${fmt(data.fizibilite_ozet.insaat_m2)} m²</div></div>
            <div class="bg-white border border-slate-200 rounded-lg p-2"><div class="text-slate-400">~Kat</div><div class="font-semibold">${data.fizibilite_ozet.tahmini_kat}</div></div>
          </div>
        ` : "";

        const skorKart = yatirimSkoruKartHTML(skorGirdiden(data));

        sonucIcerik.classList.remove("hidden");
        sonucIcerik.innerHTML = `
          ${toplamKart}
          ${skorKart}
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-4">
            <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
              <h2 class="font-display text-lg font-bold text-imperial-700">Birim Fiyat</h2>
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-xs px-2.5 py-1 rounded-full ${kr.class} font-medium">${kr.label}</span>
                <span class="text-xs px-2.5 py-1 rounded-full bg-slate-100 text-slate-700 font-medium inline-flex items-center gap-1.5">
                  <span class="inline-block w-2 h-2 rounded-full ${guvenSinif}"></span>
                  Güven %${guven}
                </span>
              </div>
            </div>
            ${data.lokasyon ? `<div class="text-xs text-slate-500 mb-2 capitalize">📍 ${data.lokasyon}</div>` : ""}
            ${ayarBlok}
