---
export const prerender = true;
import Base from "../layouts/Base.astro";
import { CHROME_STORE_URL } from "../config/launch";
---

<!-- MapLibre GL JS — CDN, build'e girmiyor -->
<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4/dist/maplibre-gl.css" />

<Base
  title="Arsa & Tarla Parsel Sorgu — İmar, Emsal, TL/m² | Cadastrum"
  description="Parsel sorgu ve imar hesaplayıcı: lokasyon + emsal/TAKS ile arsa-tarla TL/m² bandı, kat karşılığı ve fizibilite. TKGM doğrulama Chrome eklentisinde."
  keywords={[
    "parsel sorgu",
    "arsa değer sorgu",
    "tarla fiyat hesaplama",
    "imar emsal hesaplama",
    "kat karşılığı hesaplama",
    "TL/m² arsa",
    "Cadastrum sorgu",
  ]}
  breadcrumb={[
    { ad: "Ana Sayfa", url: "/" },
    { ad: "Parsel Sorgu", url: "/sorgu" },
  ]}
>

  <!-- Page-level WebApplication schema — sorgu aracı -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cadastrum Parsel Sorgu & Hesaplayıcı",
    "url": "https://cadastrum.com.tr/sorgu",
    "description": "Lokasyon + imar parametreleri (emsal/TAKS) ile arsa-tarla TL/m² bandı. Fizibilite ve kat karşılığı hesaplayıcıları dahil.",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web Browser",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "TRY" },
    "featureList": ["TL/m² fiyat bandı", "Emsal/TAKS hesaplayıcı", "Fizibilite", "Kat karşılığı", "Fiyat trendi"],
    "provider": { "@id": "https://cadastrum.com.tr/#organization" },
    "inLanguage": "tr-TR"
  })} />

  <!-- Page header + dürüst bölge ticker -->
  <div class="border-b border-slate-100 bg-white/80 backdrop-blur-sm">
    <div class="container-prose py-5">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h1 class="font-display text-2xl md:text-3xl font-bold text-imperial-700 leading-tight">
            Arsa & tarla parsel sorgu
          </h1>
          <p class="text-slate-500 text-sm mt-1">
            Lokasyon + imar (emsal/TAKS) → <strong class="text-slate-700">TL/m² bandı</strong> · TKGM ada/parsel eklentide
          </p>
        </div>
        <div class="flex items-center gap-2 text-xs text-slate-500 bg-slate-50 rounded-lg px-3 py-2 border border-slate-200">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          Free: 20 sorgu/saat
        </div>
      </div>
      <div class="mt-3 flex items-center gap-2 text-xs text-slate-500 overflow-hidden">
        <span class="shrink-0 font-semibold text-imperial-600 uppercase tracking-wide text-[10px]">Bölgeler</span>
        <div id="bolge-ticker" class="truncate text-slate-600 transition-opacity duration-300" aria-live="polite">
          Veri katalogundan örnek medyanlar yükleniyor…
        </div>
      </div>
    </div>
  </div>

  <!-- Split layout: 2/3 harita + 1/3 panel -->
  <div class="flex flex-col lg:flex-row" style="min-height: calc(100vh - 130px);">

    <!-- ══════════════════════════════════════
         SOL — MapLibre harita (2/3)
    ══════════════════════════════════════ -->
    <div class="relative lg:flex-[2] h-[55vw] lg:h-auto min-h-[340px]">
      <div id="sorgu-harita" class="absolute inset-0 w-full h-full"></div>

      <!-- Harita üstü overlay — adres arama -->
      <div class="absolute top-3 left-3 right-14 z-10">
        <div class="flex gap-2 shadow-lg">
          <input
            type="text"
            id="adres"
            placeholder="Adres veya yer adı ara… (örn: Beykoz Kavacık)"
            class="flex-1 px-3 py-2.5 bg-white/95 backdrop-blur-sm border border-white/60 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-imperial/20 focus:border-imperial placeholder-slate-400 shadow-sm"
            autocomplete="off"
          />
          <button type="button" id="adres-btn"
            class="px-3 py-2.5 bg-white/95 backdrop-blur-sm border border-white/60 rounded-lg text-sm font-medium text-slate-700 hover:bg-white shadow-sm transition-colors whitespace-nowrap">
            Bul
          </button>
        </div>
        <div id="adres-status" class="text-xs mt-1.5 px-1"></div>
      </div>

      <!-- Konum butonu -->
      <button type="button" id="konum-btn"
        class="absolute top-3 right-3 z-10 w-10 h-10 bg-white/95 backdrop-blur-sm border border-white/60 rounded-lg shadow-sm flex items-center justify-center text-slate-600 hover:bg-white hover:text-imperial transition-colors"
        title="Bulunduğum konum">
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 2a8 8 0 100 16A8 8 0 0010 2zm0 2a6 6 0 110 12A6 6 0 0110 4zm0 4a2 2 0 100 4 2 2 0 000-4z" clip-rule="evenodd"/>
        </svg>
      </button>

      <!-- Harita ipucu — ilk açılışta görünür -->
      <div id="harita-ipucu"
        class="absolute bottom-4 left-1/2 -translate-x-1/2 z-10 bg-imperial/90 text-white text-xs px-4 py-2 rounded-full shadow-lg backdrop-blur-sm pointer-events-none transition-opacity duration-500"
        aria-hidden="true">
        Haritaya tıkla → değeri hesapla
      </div>

      <!-- TUCBS ÇDP imar ipucu (üst plan — resmi 1/1000 değil) -->
      <div id="tucbs-ipucu"
        class="absolute bottom-4 right-3 z-10 max-w-[220px] bg-white/95 backdrop-blur-sm text-xs text-slate-700 px-3 py-2 rounded-lg border border-slate-200 shadow-md hidden">
        <div class="text-[10px] font-semibold uppercase tracking-wide text-imperial-600 mb-0.5">ÇDP ipucu</div>
        <div id="tucbs-ipucu-metin" class="leading-snug">—</div>
        <p class="text-[10px] text-slate-400 mt-1.5 leading-snug">Üst ölçek TUCBS. Resmi KAKS/TAKS → Chrome eklentisi.</p>
      </div>

      <!-- Koordinat göstergesi -->
      <div id="koord-badge"
        class="absolute bottom-4 left-3 z-10 bg-white/90 backdrop-blur-sm text-xs text-slate-600 px-2.5 py-1.5 rounded-md border border-white/60 shadow-sm font-mono hidden">
      </div>
    </div>

    <!-- ══════════════════════════════════════
         SAĞ — Form + Sonuç paneli (1/3)
    ══════════════════════════════════════ -->
    <div class="lg:flex-1 lg:max-w-sm xl:max-w-md border-t lg:border-t-0 lg:border-l border-slate-200 bg-slate-50/60 flex flex-col overflow-y-auto">

      <!-- Form — kompakt, harita tıklaması ile senkron -->
      <form id="sorgu-form" method="post" action="javascript:void(0)"
        class="bg-white border-b border-slate-100 p-4 space-y-3">

        <!-- Kolayimar kalıbı: sekme — Ada → eklenti (TKGM sitede yok) -->
        <div class="flex rounded-lg border border-slate-200 p-0.5 bg-slate-50" role="tablist" aria-label="Sorgu modu">
          <button type="button" role="tab" data-mod="lokasyon" aria-selected="true"
            class="sorgu-mod flex-1 px-2 py-1.5 text-xs font-semibold rounded-md bg-white text-imperial-700 shadow-sm">
            Lokasyon
          </button>
          <button type="button" role="tab" data-mod="harita" aria-selected="false"
            class="sorgu-mod flex-1 px-2 py-1.5 text-xs font-medium rounded-md text-slate-500 hover:text-slate-700">
            Harita
          </button>
          <button type="button" role="tab" data-mod="ada" aria-selected="false"
            class="sorgu-mod flex-1 px-2 py-1.5 text-xs font-medium rounded-md text-slate-500 hover:text-slate-700">
            Ada / Parsel
          </button>
        </div>

        <div id="mod-ada-panel" class="hidden rounded-lg border border-imperial/20 bg-imperial/5 p-3 text-xs space-y-2">
          <p class="text-slate-700 leading-snug">
            Resmi <strong>ada/parsel + e-Plan KAKS/TAKS</strong> sitede yok — Chrome eklentisinde.
            Burada lokasyon ve imar varsayımıyla değer bandı hesaplanır.
          </p>
          <a href={CHROME_STORE_URL} class="inline-flex font-semibold text-imperial-700 hover:underline">
            Eklentiyi aç → resmi sorgu
          </a>
          <a href="/sorgu" class="block text-slate-500 hover:text-imperial-600">Arazi avcısına git →</a>
        </div>

        <div id="mod-form-alanlari">
        <!-- Lokasyon — searchable combobox -->

        <!-- İl combobox -->
        <div>
          <label class="block text-xs font-medium text-slate-500 mb-1" for="il-input">İl</label>
          <div class="combobox-wrap" id="il-combo">
            <div class="combobox-field">
              <input type="text" id="il-input" placeholder="İl ara…" autocomplete="off" role="combobox"
                aria-expanded="false" aria-haspopup="listbox" aria-controls="il-listbox"
                class="combobox-input" />
              <svg class="combobox-caret" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 011.06 0L8 8.94l2.72-2.72a.75.75 0 111.06 1.06l-3.25 3.25a.75.75 0 01-1.06 0L4.22 7.28a.75.75 0 010-1.06z"/></svg>
            </div>
            <ul id="il-listbox" role="listbox" aria-label="İl seçenekleri" class="combobox-list hidden"></ul>
          </div>
          <!-- hidden value for form logic -->
          <input type="hidden" id="il" />
        </div>

        <div class="grid grid-cols-2 gap-2">
          <!-- İlçe combobox -->
          <div>
            <label class="block text-xs font-medium text-slate-500 mb-1" for="ilce-input">İlçe</label>
            <div class="combobox-wrap" id="ilce-combo">
              <div class="combobox-field combobox-disabled" id="ilce-field">
                <input type="text" id="ilce-input" placeholder="Önce il seçin" autocomplete="off" role="combobox"
                  aria-expanded="false" aria-haspopup="listbox" aria-controls="ilce-listbox"
                  disabled class="combobox-input" />
                <svg class="combobox-caret" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 011.06 0L8 8.94l2.72-2.72a.75.75 0 111.06 1.06l-3.25 3.25a.75.75 0 01-1.06 0L4.22 7.28a.75.75 0 010-1.06z"/></svg>
              </div>
              <ul id="ilce-listbox" role="listbox" aria-label="İlçe seçenekleri" class="combobox-list hidden"></ul>
            </div>
            <input type="hidden" id="ilce" />
          </div>

          <!-- Mahalle combobox -->
          <div>
            <label class="block text-xs font-medium text-slate-500 mb-1" for="mahalle-input">Mahalle</label>
            <div class="combobox-wrap" id="mahalle-combo">
              <div class="combobox-field combobox-disabled" id="mahalle-field">
                <input type="text" id="mahalle-input" placeholder="Önce ilçe seçin" autocomplete="off" role="combobox"
                  aria-expanded="false" aria-haspopup="listbox" aria-controls="mahalle-listbox"
                  disabled class="combobox-input" />
                <svg class="combobox-caret" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 011.06 0L8 8.94l2.72-2.72a.75.75 0 111.06 1.06l-3.25 3.25a.75.75 0 01-1.06 0L4.22 7.28a.75.75 0 010-1.06z"/></svg>
              </div>
              <ul id="mahalle-listbox" role="listbox" aria-label="Mahalle seçenekleri" class="combobox-list hidden"></ul>
            </div>
            <input type="hidden" id="mahalle" />
          </div>
        </div>

        <!-- İmar parametreleri -->
        <div>
          <label class="block text-xs font-medium text-slate-500 mb-1">İmar tipi</label>
          <select id="imar-tipi"
            class="w-full px-2.5 py-2 border border-slate-200 rounded-lg text-sm bg-white focus:border-imperial focus:ring-1 focus:ring-imperial/20 focus:outline-none">
            <option value="konut">Konut</option>
            <option value="ticari">Ticari</option>
            <option value="sanayi">Sanayi / Depo</option>
            <option value="karma">Karma</option>
            <option value="tarim">Tarım</option>
            <option value="belirsiz">Bilmiyorum</option>
          </select>
        </div>
        <div class="grid grid-cols-3 gap-2">
          <div>
            <label class="block text-xs font-medium text-slate-500 mb-1">Emsal <span class="text-slate-400">(KAKS)</span></label>
            <input type="number" id="emsal" step="0.05" min="0.1" max="15" placeholder="1.50" value="1.50"
              class="w-full px-2.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-1 focus:ring-imperial/20 focus:outline-none" />
            <input type="range" id="emsal-slider" min="0.1" max="5" step="0.05" value="1.50"
              class="mt-1.5 w-full accent-imperial h-1.5 cursor-pointer" aria-label="Emsal kaydırıcı" />
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-500 mb-1">TAKS</label>
            <input type="number" id="taks" step="0.05" min="0.05" max="1" placeholder="0.30" value="0.30"
              class="w-full px-2.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-1 focus:ring-imperial/20 focus:outline-none" />
            <input type="range" id="taks-slider" min="0.05" max="0.80" step="0.05" value="0.30"
              class="mt-1.5 w-full accent-imperial h-1.5 cursor-pointer" aria-label="TAKS kaydırıcı" />
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-500 mb-1">Parsel m²</label>
            <input type="number" id="m2" min="1" step="1" placeholder="500"
              class="w-full px-2.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-1 focus:ring-imperial/20 focus:outline-none" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-500 mb-1">Kategori</label>
          <select id="kategori"
            class="w-full px-2.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-imperial focus:ring-1 focus:ring-imperial/20 focus:outline-none bg-white">
            <option value="arsa">Arsa</option>
            <option value="tarla">Tarla</option>
            <option value="konut">Konut</option>
          </select>
        </div>

        <!-- Koordinat — harita senkronu (opsiyonel) -->
        <details class="rounded-lg border border-slate-100 bg-slate-50/80 px-2.5 py-2">
          <summary class="cursor-pointer text-xs font-medium text-slate-500 list-none flex items-center justify-between">
            <span>Harita / koordinat <span class="text-slate-400 font-normal">(opsiyonel)</span></span>
            <span class="text-slate-400">▾</span>
          </summary>
          <div class="grid grid-cols-2 gap-2 mt-2 pt-2 border-t border-slate-100">
            <div>
              <label class="block text-[10px] text-slate-400 mb-0.5">Enlem</label>
              <input type="number" id="lat" step="0.0001" placeholder="41.0082"
                class="w-full px-2 py-1.5 border border-slate-200 rounded-md text-xs font-mono bg-white focus:border-imperial focus:outline-none" />
            </div>
            <div>
              <label class="block text-[10px] text-slate-400 mb-0.5">Boylam</label>
              <input type="number" id="lng" step="0.0001" placeholder="28.9784"
                class="w-full px-2 py-1.5 border border-slate-200 rounded-md text-xs font-mono bg-white focus:border-imperial focus:outline-none" />
            </div>
          </div>
        </details>

        <button type="submit" id="submit-btn"
          class="w-full px-4 py-2.5 bg-imperial text-white rounded-lg text-sm font-semibold
                 hover:bg-imperial-700 disabled:opacity-50 disabled:cursor-not-allowed
                 transition-all duration-200 flex items-center justify-center gap-2
                 hover:-translate-y-px hover:shadow-lg hover:shadow-imperial/30
                 active:translate-y-0 active:shadow-none">
          <svg id="submit-icon" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
          </svg>
          <span id="submit-label">Değer Hesapla</span>
        </button>
        </div><!-- /mod-form-alanlari -->
    </form>

      <!-- Sonuç paneli — skeleton → içerik -->
      <div id="sonuc" class="flex-1 overflow-y-auto">

        <!-- Boş state — ilk yüklemede görünür -->
        <div id="sonuc-bos" class="flex flex-col items-center justify-center h-full py-16 px-6 text-center">
          <div class="w-16 h-16 rounded-2xl bg-imperial/8 flex items-center justify-center mb-4">
            <svg class="h-8 w-8 text-imperial/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20.25v-15m0 0L3.75 9.75M9 5.25l5.25 4.5M15 3.75v15m0 0l5.25-4.5M15 18.75l-5.25-4.5"/>
            </svg>
          </div>
          <p class="text-sm font-medium text-slate-600 mb-1">Lokasyon ve imar gir</p>
          <p class="text-xs text-slate-400">veya haritaya tıkla → "Değer Hesapla"</p>
        </div>

        <!-- Skeleton — yüklenirken görünür -->
        <div id="sonuc-skeleton" class="hidden p-4 space-y-3">
          <!-- Büyük değer kartı skeleton -->
          <div class="rounded-xl border border-slate-200 bg-white p-4 space-y-2">
            <div class="skeleton h-3 w-24 rounded"></div>
            <div class="skeleton h-8 w-40 rounded"></div>
            <div class="skeleton h-3 w-32 rounded"></div>
          </div>
          <!-- 3 değer kutusu skeleton -->
          <div class="grid grid-cols-3 gap-2">
            <div class="rounded-lg bg-white border border-slate-200 p-3 space-y-1.5">
              <div class="skeleton h-2.5 w-12 rounded"></div>
              <div class="skeleton h-5 w-16 rounded"></div>
            </div>
            <div class="rounded-lg bg-white border border-slate-200 p-3 space-y-1.5">
              <div class="skeleton h-2.5 w-12 rounded"></div>
              <div class="skeleton h-5 w-16 rounded"></div>
            </div>
            <div class="rounded-lg bg-white border border-slate-200 p-3 space-y-1.5">
              <div class="skeleton h-2.5 w-12 rounded"></div>
              <div class="skeleton h-5 w-16 rounded"></div>
            </div>
          </div>
          <!-- Meta satırlar -->
          <div class="rounded-xl border border-slate-200 bg-white p-4 space-y-2">
            <div class="skeleton h-2.5 w-48 rounded"></div>
            <div class="skeleton h-2.5 w-36 rounded"></div>
            <div class="skeleton h-2.5 w-40 rounded"></div>
          </div>
        </div>

        <!-- Gerçek sonuç içeriği — JS ile doldurulur -->
        <div id="sonuc-icerik" class="hidden p-4 space-y-3"></div>

      </div>

      <!-- Belediye portal — seçili il için deep-link -->
      <div id="belediye-portal" class="hidden border-t border-slate-200 bg-white px-4 py-2.5 text-xs">
        <a id="belediye-portal-link" href="#" target="_blank" rel="noopener"
          class="font-semibold text-imperial-700 hover:underline">Belediye e-imar →</a>
        <span class="text-slate-400 ml-1">(görsel / resmi belge belediyeden)</span>
      </div>

      <!-- Fizibilite accordion — panelin altı -->
      <div id="hesaplayicilar" class="scroll-mt-20"></div>
      <details id="fizibilite-panel"
        class="border-t border-slate-200 bg-white">
        <summary class="cursor-pointer px-4 py-3 text-sm font-semibold text-imperial-700 flex items-center justify-between list-none hover:bg-slate-50 transition-colors">
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-imperial/60" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2 4h16v2H2V4zm2 4h12v2H4V8zm-2 4h16v2H2v-2zm2 4h12v2H4v-2z"/>
            </svg>
            İmar Fizibilite
          </span>
          <svg class="h-4 w-4 text-slate-400 fizibilite-chevron transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </summary>
        <div class="px-4 pb-4 pt-3 border-t border-slate-100 space-y-3">
          <p class="text-xs text-slate-500">
            Formdaki TAKS/Emsal otomatik gelir → inşa edilebilir alan, daire adedi, kârlılık.
          </p>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs text-slate-500 mb-1">Parsel m²</label>
              <input type="number" id="f-m2" min="1" placeholder="500"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs text-slate-500 mb-1">TAKS</label>
              <input type="number" id="f-taks" step="0.05" placeholder="0.30"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs text-slate-500 mb-1">KAKS</label>
              <input type="number" id="f-kaks" step="0.05" placeholder="1.50"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs text-slate-500 mb-1">Arsa ₺</label>
              <input type="number" id="f-arsa" placeholder="otomatik"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs text-slate-500 mb-1">İnşaat ₺/m²</label>
              <input type="number" id="f-insaat" placeholder="18000"
