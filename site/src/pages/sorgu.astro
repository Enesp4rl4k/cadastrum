      <!-- Ters fizibilite -->
      <details id="ters-fiz-panel" class="border-t border-slate-200 bg-white">
        <summary class="cursor-pointer px-4 py-3 text-sm font-semibold text-imperial-700 flex items-center justify-between list-none hover:bg-slate-50 transition-colors">
          <span>Ters Fizibilite</span>
          <span class="text-slate-400 text-xs font-normal">hedef kâr → min emsal</span>
        </summary>
        <div class="px-4 pb-4 pt-3 border-t border-slate-100 space-y-3">
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs text-slate-500 mb-1">Hedef kâr %</label>
              <input type="number" id="tf-hedef" value="25" min="0" max="100"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs text-slate-500 mb-1">Hedef daire (opsiyonel)</label>
              <input type="number" id="tf-daire" min="1" placeholder="—"
                class="w-full px-2.5 py-1.5 border border-slate-200 rounded-md text-sm focus:border-imperial focus:outline-none" />
