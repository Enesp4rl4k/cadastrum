  <script>
    import { PUBLIC_API_BASE } from "../lib/config";
    import {
      fizibiliteHesapla,
      varsayilanInsaatMaliyeti,
      tersFizibiliteHesapla,
      senaryoKarsilastir,
    } from "../lib/fizibilite";
    import { katKarsiligiHesapla } from "../lib/kat-karsiligi";
    import { tucbsSlugIlIcin, tucbsFeatureOzet } from "../lib/tucbs-slug";
    import { belediyePortalIlIcin } from "../lib/belediye-wms";
    import { CHROME_STORE_URL } from "../config/launch";
    import { yatirimSkoruHesapla, type YatirimSkoruSonuc } from "../lib/yatirim-skoru";
    import {
      bboxFromMerkez,
      gelisimTrendiAnaliz,
      gelisimSkorRenk,
      type GelisimTrendiSonuc,
    } from "../lib/gelisim-trendi";

    // ── Helpers ──
    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const fmt  = (n: number) => n.toLocaleString("tr-TR");
    const fmtK = (n: number) => Math.abs(n) >= 1_000_000
      ? (n / 1_000_000).toFixed(2) + " M ₺"
      : fmt(Math.round(n)) + " ₺";

    const form        = $<HTMLFormElement>("sorgu-form");
    const latInput    = $<HTMLInputElement>("lat");
    const lngInput    = $<HTMLInputElement>("lng");
    const m2Input     = $<HTMLInputElement>("m2");
    const kategoriInput = $<HTMLSelectElement>("kategori");
    // Combobox hidden value inputs (gerçek değer buraya yazılır)
    const ilHidden    = $<HTMLInputElement>("il");
    const ilceHidden  = $<HTMLInputElement>("ilce");
    const mahalleHidden = $<HTMLInputElement>("mahalle");
    // Combobox display inputs
    const ilInput     = $<HTMLInputElement>("il-input");
    const ilceInput   = $<HTMLInputElement>("ilce-input");
    const mahalleInput2 = $<HTMLInputElement>("mahalle-input");
    const imarTipiSelect = $<HTMLSelectElement>("imar-tipi");
    // Legacy aliases — form submit kodunu değiştirmeden çalışsın
    const ilSelect    = { get value() { return ilHidden.value; }, set value(v: string) { ilHidden.value = v; } };
    const ilceSelect  = { get value() { return ilceHidden.value; }, set value(v: string) { ilceHidden.value = v; } };
    const mahalleInput = { get value() { return mahalleHidden.value; }, set value(v: string) { mahalleHidden.value = v; },
      get textContent() { return mahalleHidden.value; } };
    const emsalInput  = $<HTMLInputElement>("emsal");
    const taksInput   = $<HTMLInputElement>("taks");
    const emsalSlider = $<HTMLInputElement>("emsal-slider");
    const taksSlider  = $<HTMLInputElement>("taks-slider");
    const submitBtn   = $<HTMLButtonElement>("submit-btn");
    const submitLabel = $<HTMLSpanElement>("submit-label");
    const adresInput  = $<HTMLInputElement>("adres");
    const adresBtn    = $<HTMLButtonElement>("adres-btn");
    const adresStatus = $<HTMLDivElement>("adres-status");
    const konumBtn    = $<HTMLButtonElement>("konum-btn");
    const haritaIpucu = $<HTMLDivElement>("harita-ipucu");
    const tucbsIpucu  = $<HTMLDivElement>("tucbs-ipucu");
    const tucbsMetin  = $<HTMLDivElement>("tucbs-ipucu-metin");
    const koordBadge  = $<HTMLDivElement>("koord-badge");
    const sonucBos    = $<HTMLDivElement>("sonuc-bos");
    const sonucSkeleton = $<HTMLDivElement>("sonuc-skeleton");
    const sonucIcerik = $<HTMLDivElement>("sonuc-icerik");
    const sonuc       = $<HTMLDivElement>("sonuc");

    let debounceTimer: ReturnType<typeof setTimeout> | null = null;
    let sonSorguVar = false;

    // ── Bölge ticker (dürüst — veri kataloğu medyanları, sahte “şimdi sorgu” değil) ──
    const TICKER = [
      { t: "İstanbul · Beşiktaş", href: "/veri/istanbul" },
      { t: "Ankara · Çankaya", href: "/veri/ankara" },
      { t: "İzmir · Konak", href: "/veri/izmir" },
      { t: "Antalya · Muratpaşa", href: "/veri/antalya" },
      { t: "Muğla · Bodrum", href: "/veri/mugla" },
      { t: "Bursa · Nilüfer", href: "/veri/bursa" },
      { t: "Veri kataloğu → kaynaklar", href: "/veri-katalogu" },
    ];
    let tickerI = 0;
    const tickerEl = document.getElementById("bolge-ticker");
    function tickerTick() {
      if (!tickerEl) return;
      const item = TICKER[tickerI % TICKER.length]!;
      tickerEl.style.opacity = "0";
      setTimeout(() => {
        tickerEl.innerHTML = `<a href="${item.href}" class="hover:text-imperial-700 hover:underline">${item.t}</a> · medyan & emsal → katalog`;
        tickerEl.style.opacity = "1";
      }, 200);
      tickerI++;
    }
    tickerTick();
    setInterval(tickerTick, 4000);

    // ── Sorgu mod sekmeleri ──
    document.querySelectorAll<HTMLButtonElement>(".sorgu-mod").forEach((btn) => {
      btn.addEventListener("click", () => {
        const mod = btn.dataset["mod"];
        document.querySelectorAll<HTMLButtonElement>(".sorgu-mod").forEach((b) => {
          const on = b === btn;
          b.setAttribute("aria-selected", on ? "true" : "false");
          b.classList.toggle("bg-white", on);
          b.classList.toggle("text-imperial-700", on);
          b.classList.toggle("shadow-sm", on);
          b.classList.toggle("font-semibold", on);
          b.classList.toggle("font-medium", !on);
          b.classList.toggle("text-slate-500", !on);
        });
        const ada = document.getElementById("mod-ada-panel");
        const formAlan = document.getElementById("mod-form-alanlari");
        if (mod === "ada") {
          ada?.classList.remove("hidden");
          formAlan?.classList.add("hidden");
        } else {
          ada?.classList.add("hidden");
          formAlan?.classList.remove("hidden");
          if (mod === "harita") {
            document.getElementById("sorgu-harita")?.scrollIntoView({ behavior: "smooth", block: "center" });
            haritaIpucu?.classList.remove("hidden", "opacity-0");
          }
        }
      });
    });

    function skorEtiketSinif(etiket: string): string {
      if (etiket === "Güçlü") return "text-emerald-700 bg-emerald-50 border-emerald-200";
      if (etiket === "İyi") return "text-sky-700 bg-sky-50 border-sky-200";
      if (etiket === "Dengeli") return "text-imperial-700 bg-imperial/5 border-imperial/20";
      if (etiket === "Temkinli") return "text-amber-800 bg-amber-50 border-amber-200";
      return "text-red-700 bg-red-50 border-red-200";
    }

    function skorHalkaRenk(skor: number): string {
      if (skor >= 80) return "#059669";
      if (skor >= 65) return "#0284c7";
      if (skor >= 50) return "#1B2A4A";
      if (skor >= 35) return "#d97706";
      return "#dc2626";
    }

    function yatirimSkoruKartHTML(ys: YatirimSkoruSonuc): string {
      const r = 42;
      const c = 2 * Math.PI * r;
      const offset = c * (1 - ys.skor / 100);
      const renk = skorHalkaRenk(ys.skor);
      const bars = ys.bilesenler
        .map((b) => {
          const pct = Math.round((b.puan / b.max) * 100);
          return `
            <div class="space-y-0.5">
              <div class="flex justify-between gap-2 text-[11px]">
                <span class="text-slate-700 font-medium">${b.ad}</span>
                <span class="font-mono text-slate-500">${b.puan}/${b.max}</span>
              </div>
              <div class="h-1.5 rounded-full bg-slate-100 overflow-hidden">
                <div class="h-full rounded-full bg-imperial-600/80 transition-all" style="width:${pct}%"></div>
              </div>
              <div class="text-[10px] text-slate-400 truncate">${b.not}</div>
            </div>`;
        })
        .join("");
      return `
        <div id="yatirim-skoru-kart" class="bg-white rounded-2xl shadow-sm border border-slate-200 p-4 mb-3">
          <div class="flex items-start gap-4">
            <div class="relative shrink-0 w-[100px] h-[100px]">
              <svg viewBox="0 0 100 100" class="w-full h-full -rotate-90" aria-hidden="true">
                <circle cx="50" cy="50" r="${r}" fill="none" stroke="#e2e8f0" stroke-width="8"/>
                <circle cx="50" cy="50" r="${r}" fill="none" stroke="${renk}" stroke-width="8"
                  stroke-linecap="round" stroke-dasharray="${c}" stroke-dashoffset="${offset}"
                  style="transition: stroke-dashoffset 0.6s ease"/>
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center rotate-0">
                <span class="text-2xl font-bold text-imperial-800 leading-none">${ys.skor}</span>
                <span class="text-[9px] text-slate-400 uppercase tracking-wide mt-0.5">/ 100</span>
              </div>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <h2 class="font-display text-base font-bold text-imperial-700">Yatırım skoru</h2>
                <span class="text-[10px] px-2 py-0.5 rounded-full border font-semibold ${skorEtiketSinif(ys.etiket)}">${ys.etiket}</span>
              </div>
              <p class="text-xs text-slate-600 leading-snug mb-3">${ys.yorum}</p>
              <div class="space-y-2">${bars}</div>
              <p class="text-[10px] text-slate-400 mt-2">Bilgilendirme amaçlıdır; resmi ekspertiz / yatırım tavsiyesi değildir.</p>
            </div>
          </div>
        </div>`;
    }

    function skorGirdiden(data: any, trendDegisimYuzde?: number | null): YatirimSkoruSonuc {
      if (data.yatirim_skoru && trendDegisimYuzde == null) {
        return data.yatirim_skoru as YatirimSkoruSonuc;
      }
      return yatirimSkoruHesapla({
        guvenSkoru: data.guven_skoru ?? 0,
        kaynak: data.kaynak ?? "il-fallback",
        emsalAdet: data.emsal_adet ?? 0,
        imarTipi: data.imar_tipi ?? "belirsiz",
        emsal: data.emsal ?? null,
        taks: data.taks ?? null,
        toplamCarpan: data.toplam_carpan ?? 1,
        altTlm2: data.alt_tlm2 ?? null,
        ustTlm2: data.ust_tlm2 ?? null,
        medyanTlm2: data.medyan_tlm2 ?? null,
        trendDegisimYuzde: trendDegisimYuzde ?? null,
      });
    }

    function yatirimHikayesi(data: any, imarTipi: string, m2: number): string {
      const med = data.medyan_tlm2 ?? 0;
      const guven = data.guven_skoru ?? 0;
      const lok = data.lokasyon ? String(data.lokasyon) : "seçilen bölge";
      const tip = imarTipi && imarTipi !== "belirsiz" ? imarTipi : "belirsiz imar";
      const band =
        med > 0
          ? `Medyan yaklaşık ${fmt(med)} ₺/m² (güven %${guven}).`
          : "Bu bölgede emsal henüz ince — bandı imar varsayımıyla geniş tutun.";
      const alan =
        Number.isFinite(m2) && m2 > 0 && med > 0
          ? ` ${fmt(m2)} m² için orta senaryo ~${fmt(Math.round(med * m2))} ₺.`
          : "";
      const imarNot =
        tip === "tarim"
          ? " Tarım tipi seçildi — yapılaşma kısıtı fiyatı baskılar."
          : tip === "ticari"
            ? " Ticari imar varsayımı bandı yukarı çeker."
            : ` İmar tipi: ${tip}.`;
      const sonraki =
        data.kaynak === "il-fallback"
          ? " Sonraki adım: mahalle netleştir veya eklentide resmi parsel doğrula."
          : " Fizibilite ve kat karşılığı panelleriyle senaryoyu stres test et.";
      return `${lok} için ${band}${alan}${imarNot}${sonraki}`;
    }

    function syncSliderFromInput(input: HTMLInputElement, slider: HTMLInputElement) {
      const v = parseFloat(input.value);
      if (Number.isFinite(v)) slider.value = String(v);
    }
    function syncInputFromSlider(slider: HTMLInputElement, input: HTMLInputElement) {
      input.value = slider.value;
    }
    function debouncedResorgu() {
      if (!sonSorguVar) return;
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => form.requestSubmit(), 450);
    }
    emsalSlider?.addEventListener("input", () => {
      syncInputFromSlider(emsalSlider, emsalInput);
      debouncedResorgu();
    });
    taksSlider?.addEventListener("input", () => {
      syncInputFromSlider(taksSlider, taksInput);
      debouncedResorgu();
    });
    emsalInput?.addEventListener("change", () => {
      syncSliderFromInput(emsalInput, emsalSlider);
      debouncedResorgu();
    });
    taksInput?.addEventListener("change", () => {
      syncSliderFromInput(taksInput, taksSlider);
      debouncedResorgu();
    });

    async function tucbsIpucuYukle(lat: number, lng: number) {
      if (!tucbsIpucu || !tucbsMetin) return;
      const bolge = tucbsSlugIlIcin(ilHidden.value);
      if (!bolge) {
        tucbsIpucu.classList.remove("hidden");
        tucbsMetin.textContent = "Bu il için TUCBS ÇDP kapsamı yok. Resmi imar → eklenti.";
        return;
      }
      tucbsIpucu.classList.remove("hidden");
      tucbsMetin.textContent = `${bolge.bolgeAd} sorgulanıyor…`;
      try {
        const res = await fetch(
          `${PUBLIC_API_BASE}/proxy/tucbs?wms=${encodeURIComponent(bolge.slug)}&lat=${lat}&lng=${lng}`,
          { signal: AbortSignal.timeout(8000) },
        );
        if (!res.ok) {
          tucbsMetin.textContent = "ÇDP yanıtı alınamadı (üst plan).";
          return;
        }
        const data = await res.json();
        const ozet = tucbsFeatureOzet(data);
        tucbsMetin.textContent = ozet
          ? `${ozet} · ${bolge.bolgeAd}`
          : `${bolge.bolgeAd}: bu noktada özellik yok / kapsam dışı.`;
      } catch {
        tucbsIpucu.classList.add("hidden");
      }
    }

    const ILLER: [string, string][] = [
      ["istanbul","İstanbul"],["ankara","Ankara"],["izmir","İzmir"],["bursa","Bursa"],["antalya","Antalya"],
      ["adana","Adana"],["konya","Konya"],["gaziantep","Gaziantep"],["mersin","Mersin"],["diyarbakir","Diyarbakır"],
      ["kayseri","Kayseri"],["samsun","Samsun"],["eskisehir","Eskişehir"],["denizli","Denizli"],["sanliurfa","Şanlıurfa"],
      ["trabzon","Trabzon"],["hatay","Hatay"],["manisa","Manisa"],["kahramanmaras","Kahramanmaraş"],["balikesir","Balıkesir"],
      ["aydin","Aydın"],["tekirdag","Tekirdağ"],["sakarya","Sakarya"],["mugla","Muğla"],["kocaeli","Kocaeli"],
      ["malatya","Malatya"],["erzurum","Erzurum"],["van","Van"],["ordu","Ordu"],["yalova","Yalova"],
      ["canakkale","Çanakkale"],["edirne","Edirne"],["adiyaman","Adıyaman"],["afyonkarahisar","Afyonkarahisar"],
      ["agri","Ağrı"],["aksaray","Aksaray"],["amasya","Amasya"],["ardahan","Ardahan"],["artvin","Artvin"],
      ["bartin","Bartın"],["batman","Batman"],["bayburt","Bayburt"],["bilecik","Bilecik"],["bingol","Bingöl"],
      ["bitlis","Bitlis"],["bolu","Bolu"],["burdur","Burdur"],["cankiri","Çankırı"],["corum","Çorum"],
      ["duzce","Düzce"],["elazig","Elazığ"],["erzincan","Erzincan"],["giresun","Giresun"],["gumushane","Gümüşhane"],
      ["hakkari","Hakkari"],["igdir","Iğdır"],["isparta","Isparta"],["karabuk","Karabük"],["karaman","Karaman"],
      ["kars","Kars"],["kastamonu","Kastamonu"],["kirikkale","Kırıkkale"],["kirklareli","Kırklareli"],
      ["kirsehir","Kırşehir"],["kilis","Kilis"],["kutahya","Kütahya"],["mardin","Mardin"],["mus","Muş"],
      ["nevsehir","Nevşehir"],["nigde","Niğde"],["osmaniye","Osmaniye"],["rize","Rize"],["siirt","Siirt"],
      ["sinop","Sinop"],["sivas","Sivas"],["sirnak","Şırnak"],["tokat","Tokat"],["tunceli","Tunceli"],
      ["usak","Uşak"],["zonguldak","Zonguldak"],
    ];

    function displaySlug(s: string) {
      return s.split(/[-\s]/).filter(Boolean).map(w => w.charAt(0).toLocaleUpperCase("tr") + w.slice(1)).join(" ");
    }

    // ── Generic Combobox factory ──────────────────────────────────────────────
    function makeCombobox(opts: {
      inputEl: HTMLInputElement;
      listEl: HTMLUListElement;
      hiddenEl: HTMLInputElement;
      fieldEl: HTMLDivElement;
      onSelect?: (value: string, label: string) => void;
    }) {
      let items: { value: string; label: string }[] = [];
      let activeIdx = -1;

      function normalize(s: string) {
        return s.toLocaleLowerCase("tr").replace(/ğ/g,"g").replace(/ü/g,"u").replace(/ş/g,"s")
          .replace(/ı/g,"i").replace(/ö/g,"o").replace(/ç/g,"c");
      }

      function renderList(filtered: { value: string; label: string }[]) {
        listEl.innerHTML = "";
        activeIdx = -1;
        if (filtered.length === 0) {
          listEl.innerHTML = `<li class="combobox-empty">Sonuç bulunamadı</li>`;
          return;
        }
        filtered.forEach((item, i) => {
          const li = document.createElement("li");
          li.role = "option";
          li.className = "combobox-option";
          li.setAttribute("aria-selected", item.value === hiddenEl.value ? "true" : "false");
          li.dataset["value"] = item.value;
          li.innerHTML = `<svg class="combobox-option-check" viewBox="0 0 12 12" fill="currentColor"><path d="M10 3L5 8.5 2 5.5"/></svg>${item.label}`;
          li.addEventListener("mousedown", (e) => {
            e.preventDefault();
            selectItem(item);
          });
          listEl.appendChild(li);
        });
      }

      function selectItem(item: { value: string; label: string }) {
        hiddenEl.value = item.value;
        inputEl.value = item.label;
        closeList();
        opts.onSelect?.(item.value, item.label);
      }

      function openList() {
        const q = normalize(inputEl.value.trim());
        const filtered = q
          ? items.filter(it => normalize(it.label).includes(q) || normalize(it.value).includes(q))
          : items;
        renderList(filtered);
        listEl.classList.remove("hidden");
        fieldEl.setAttribute("data-open", "true");
        inputEl.setAttribute("aria-expanded", "true");
      }

      function closeList() {
        listEl.classList.add("hidden");
        fieldEl.removeAttribute("data-open");
        inputEl.setAttribute("aria-expanded", "false");
        activeIdx = -1;
      }

      inputEl.addEventListener("focus", () => openList());
      inputEl.addEventListener("input", () => { hiddenEl.value = ""; openList(); });
      inputEl.addEventListener("blur", () => setTimeout(closeList, 150));
      inputEl.addEventListener("keydown", (e) => {
        const lis = listEl.querySelectorAll<HTMLLIElement>(".combobox-option[data-value]");
        if (e.key === "ArrowDown") {
          e.preventDefault();
          activeIdx = Math.min(activeIdx + 1, lis.length - 1);
          lis.forEach((l, i) => l.classList.toggle("combobox-active", i === activeIdx));
          lis[activeIdx]?.scrollIntoView({ block: "nearest" });
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          activeIdx = Math.max(activeIdx - 1, 0);
          lis.forEach((l, i) => l.classList.toggle("combobox-active", i === activeIdx));
          lis[activeIdx]?.scrollIntoView({ block: "nearest" });
        } else if (e.key === "Enter") {
          e.preventDefault();
          const active = lis[activeIdx];
          if (active?.dataset["value"]) {
            const val = active.dataset["value"];
            const item = items.find(it => it.value === val);
            if (item) selectItem(item);
          }
        } else if (e.key === "Escape") {
          closeList();
        }
      });

      return {
        setItems(newItems: { value: string; label: string }[]) {
          items = newItems;
        },
        setValue(value: string, label?: string) {
          hiddenEl.value = value;
          inputEl.value = label ?? (items.find(it => it.value === value)?.label ?? displaySlug(value));
        },
        enable() {
          inputEl.disabled = false;
          fieldEl.classList.remove("combobox-disabled");
          inputEl.placeholder = "Ara…";
        },
        disable(placeholder = "Önce il seçin") {
          inputEl.disabled = true;
          inputEl.value = "";
          hiddenEl.value = "";
          fieldEl.classList.add("combobox-disabled");
          inputEl.placeholder = placeholder;
        },
        setLoading() {
          listEl.innerHTML = `<li class="combobox-loading">Yükleniyor…</li>`;
          listEl.classList.remove("hidden");
        },
      };
    }

    // ── İl combobox ──
    const ilCombo = makeCombobox({
      inputEl: ilInput,
      listEl: $<HTMLUListElement>("il-listbox"),
      hiddenEl: ilHidden,
      fieldEl: $<HTMLDivElement>("il-combo"),
      onSelect: (value) => {
        void ilceYukle(value);
        belediyePortalGuncelle();
        // mahalle sıfırla
        mahalleCombo.disable("Önce ilçe seçin");
        ilceCombo.disable("Yükleniyor…");
      },
    });
    ilCombo.setItems(ILLER.map(([v, l]) => ({ value: v, label: l })));

    // ── İlçe combobox ──
    const ilceCombo = makeCombobox({
      inputEl: ilceInput,
      listEl: $<HTMLUListElement>("ilce-listbox"),
      hiddenEl: ilceHidden,
      fieldEl: $<HTMLDivElement>("ilce-field"),
      onSelect: (_value) => {
        mahalleCombo.enable();
        mahalleCombo.setItems([]);
        mahalleHidden.value = "";
        mahalleInput2.value = "";
      },
    });

    // ── Mahalle combobox ──
    const mahalleCombo = makeCombobox({
      inputEl: mahalleInput2,
      listEl: $<HTMLUListElement>("mahalle-listbox"),
      hiddenEl: mahalleHidden,
      fieldEl: $<HTMLDivElement>("mahalle-field"),
    });

    async function ilceYukle(ilNorm: string) {
      ilceCombo.disable("Yükleniyor…");
      ilceCombo.setLoading();
      try {
        const res = await fetch(`${PUBLIC_API_BASE}/fiyat/toplu-ilce-ozet/${ilNorm}?kategori=arsa`);
        const data = await res.json();
        const list = (data.ilceler ?? []) as Array<{ ilce_norm: string }>;
        if (list.length === 0) {
          ilceCombo.enable();
          ilceCombo.setItems([{ value: "", label: "İlçe yok — mahalle yazın" }]);
        } else {
          const sorted = list.sort((a, b) => a.ilce_norm.localeCompare(b.ilce_norm, "tr"));
          ilceCombo.setItems(sorted.map(ic => ({ value: ic.ilce_norm, label: displaySlug(ic.ilce_norm) })));
          ilceCombo.enable();
        }
      } catch {
        ilceCombo.enable();
        ilceCombo.setItems([{ value: "", label: "Yüklenemedi — tekrar dene" }]);
      }
    }

    function belediyePortalGuncelle() {
      const wrap = document.getElementById("belediye-portal");
      const link = document.getElementById("belediye-portal-link") as HTMLAnchorElement | null;
      const p = belediyePortalIlIcin(ilHidden.value);
      if (!wrap || !link) return;
      if (!p) { wrap.classList.add("hidden"); return; }
      link.href = p.url;
      link.textContent = `${p.ad} →`;
      wrap.classList.remove("hidden");
    }

    // ── State ──
    let map: any = null;
    let marker: any = null;
    let currentLat = 0, currentLng = 0;

    // ── MapLibre init ──
    function initHarita() {
      const ml = (window as any).maplibregl;
      if (!ml || !document.getElementById("sorgu-harita")) return;

      map = new ml.Map({
        container: "sorgu-harita",
        style: "https://tiles.openfreemap.org/styles/positron",
        center: [35.2433, 38.9637], // Türkiye merkezi
        zoom: 5.5,
        attributionControl: false,
      });

      map.addControl(new ml.AttributionControl({ compact: true }), "bottom-right");
      map.addControl(new ml.NavigationControl({ showCompass: false }), "bottom-right");

      map.on("click", (e: any) => {
        const { lng, lat } = e.lngLat;
        setKoordinat(lat, lng, true);
      });

      map.on("load", () => {
        // İpucunu gizle
        haritaIpucu?.classList.add("opacity-0");
        setTimeout(() => haritaIpucu?.classList.add("hidden"), 500);
      });
    }

    function setKoordinat(lat: number, lng: number, autoSorgu = false) {
      currentLat = lat;
      currentLng = lng;
      latInput.value = lat.toFixed(5);
      lngInput.value = lng.toFixed(5);

      // Badge güncelle
      if (koordBadge) {
        koordBadge.textContent = `${lat.toFixed(4)}, ${lng.toFixed(4)}`;
        koordBadge.classList.remove("hidden");
      }

      // Marker koy/taşı
      const ml = (window as any).maplibregl;
      if (map && ml) {
        if (marker) {
          marker.setLngLat([lng, lat]);
        } else {
          marker = new ml.Marker({ color: "#1B2A4A" })
            .setLngLat([lng, lat])
            .addTo(map);
        }
        // Zoom in eğer çok uzaksa
        if (map.getZoom() < 11) {
          map.flyTo({ center: [lng, lat], zoom: 13, duration: 1200, essential: true });
        } else {
          map.easeTo({ center: [lng, lat], duration: 400 });
        }
      }

      void tucbsIpucuYukle(lat, lng);
      if (autoSorgu) setTimeout(() => form.requestSubmit(), 300);
    }

    // ── Geocoding ──
    async function geocode(q: string): Promise<{ lat: number; lng: number; display: string } | null> {
      const url = `https://nominatim.openstreetmap.org/search?format=json&limit=1&countrycodes=tr&q=${encodeURIComponent(q)}`;
      const res = await fetch(url, { headers: { Accept: "application/json" } });
      if (!res.ok) return null;
      const arr = await res.json();
      if (!Array.isArray(arr) || arr.length === 0) return null;
      return { lat: parseFloat(arr[0].lat), lng: parseFloat(arr[0].lon), display: arr[0].display_name };
    }

    adresBtn.addEventListener("click", async () => {
      const q = adresInput.value.trim();
      if (!q) return;
      adresBtn.textContent = "…";
      adresStatus.textContent = "Aranıyor…";
      adresStatus.className = "text-xs text-slate-400 mt-1.5 px-1";
      try {
        const r = await geocode(q);
        if (!r) {
          adresStatus.textContent = "Bulunamadı — daha geniş bir yer adı deneyin.";
          adresStatus.className = "text-xs text-amber-700 mt-1.5 px-1";
          return;
        }
        adresStatus.textContent = `✓ ${r.display.slice(0, 70)}`;
        adresStatus.className = "text-xs text-emerald-700 mt-1.5 px-1";
        setKoordinat(r.lat, r.lng, true);
      } catch {
        adresStatus.textContent = "Geocoding hatası — koordinat girin.";
        adresStatus.className = "text-xs text-red-700 mt-1.5 px-1";
      } finally {
        adresBtn.textContent = "Bul";
      }
    });
    adresInput.addEventListener("keydown", (e) => { if (e.key === "Enter") { e.preventDefault(); adresBtn.click(); } });

    // ── Konum ──
    konumBtn?.addEventListener("click", () => {
      if (!navigator.geolocation) return;
      konumBtn.classList.add("animate-pulse");
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          konumBtn.classList.remove("animate-pulse");
          setKoordinat(pos.coords.latitude, pos.coords.longitude, true);
        },
        () => konumBtn.classList.remove("animate-pulse"),
      );
    });

    // ─── Sorgu submit ───
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const lat = parseFloat(latInput.value);
      const lng = parseFloat(lngInput.value);
      const m2 = parseFloat(m2Input.value);
      const kategori = kategoriInput.value;
      const il = ilSelect.value;
      const ilceRaw = ilceSelect.value;
      const ilce = ilceRaw === "_manuel" ? "" : ilceRaw;
      const mahalle = mahalleInput.value.trim();
      const imar_tipi = imarTipiSelect.value;
      const emsal = parseFloat(emsalInput.value);
      const taks = parseFloat(taksInput.value);

      const hasCoords = Number.isFinite(lat) && Number.isFinite(lng);
      if (!hasCoords && !il) {
        alert("İl seçin veya haritadan konum işaretleyin.");
        return;
      }

      // Koordinat yoksa geocode
      if (!hasCoords && il) {
        const q = [mahalle, ilce && ilce !== "_manuel" ? displaySlug(ilce) : "", displaySlug(il), "Türkiye"]
          .filter(Boolean).join(" ");
        submitBtn.disabled = true;
        submitLabel.textContent = "Konum aranıyor…";
        try {
          const r = await geocode(q);
          if (r) setKoordinat(r.lat, r.lng, false);
        } catch { /* devam — lokasyon API ile */ }
        submitLabel.textContent = "Değer Hesapla";
      }

      const lat2 = parseFloat(latInput.value);
      const lng2 = parseFloat(lngInput.value);

      sonucBos.classList.add("hidden");
      sonucSkeleton.classList.remove("hidden");
      sonucIcerik.classList.add("hidden");
      submitBtn.disabled = true;

      try {
        const body: Record<string, unknown> = { kategori, imar_tipi };
        if (Number.isFinite(lat2) && Number.isFinite(lng2)) {
          body.lat = lat2;
          body.lng = lng2;
        }
        if (il) body.il = il;
        if (ilce) body.ilce = ilce;
        if (mahalle) body.mahalle = mahalle;
        if (Number.isFinite(m2) && m2 > 0) body.m2 = m2;
        if (Number.isFinite(emsal) && emsal > 0) body.emsal = emsal;
        if (Number.isFinite(taks) && taks > 0) body.taks = taks;

        const res = await fetch(`${PUBLIC_API_BASE}/sorgu`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        submitBtn.disabled = false;
        sonucSkeleton.classList.add("hidden");

        if (!res.ok) {
          sonucIcerik.classList.remove("hidden");
          sonucIcerik.innerHTML = `<div class="bg-red-50 text-red-700 p-3 rounded-lg text-sm">❌ ${data.error ?? "Sorgu hatası"}</div>`;
          return;
        }

        // Kaynak rozeti
        const kaynakRozet: Record<string, { label: string; class: string }> = {
          "spatial-radius": { label: "Spatial Emsal", class: "bg-emerald-100 text-emerald-800" },
          "mahalle-istatistik": { label: "Mahalle İstatistiği", class: "bg-blue-100 text-blue-800" },
          "ilce-istatistik": { label: "İlçe İstatistiği", class: "bg-sky-100 text-sky-800" },
          "il-fallback": { label: "İl Baseline (yaklaşık)", class: "bg-amber-100 text-amber-800" },
