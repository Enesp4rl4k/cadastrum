# Cadastrum Site — Environment Variables
#
# Bu dosyayı kopyalayın ve `.env` olarak kaydedin (gitignore'da):
#   cp .env.example .env
#
# Astro PUBLIC_* prefix'i ile başlayan değişkenleri client-side bundle'a inject eder.

# Backend API base URL — Cloudflare Worker
# Custom domain bağlandığında: https://api.cadastrum.com.tr/v1
PUBLIC_API_BASE=https://cadastrum-api.cadastrum-tr.workers.dev/v1

# LemonSqueezy variant ID'leri (üyelik checkout linkleri için)
# https://app.lemonsqueezy.com/products → variant ID'leri
PUBLIC_LEMON_PRO_VARIANT=
PUBLIC_LEMON_PROPLUS_VARIANT=
PUBLIC_LEMON_KURUMSAL_VARIANT=

# Cloudflare Pages deploy için (CI/CD)
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...
